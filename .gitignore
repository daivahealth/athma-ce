# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/

# Prisma generated clients (custom `output` path in schema.prisma).
# Regenerated by `prisma generate`, which every package's build/dev
# script already runs - never rely on these being pre-committed.
# Includes platform-specific native query-engine binaries, which are
# actively wrong to commit (e.g. a macOS-only .dylib.node is useless
# on Linux/Windows CI or deploy targets).
generated/
**/generated/

# Next.js
.next/
**/.next/
out/
**/out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files
.env
.env.*
!.env.example
!.env.sample

# OS/Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Caches
.cache/
**/.cache/
.turbo/
**/.turbo/

# TypeScript
*.tsbuildinfo

# Prisma local db files
backend/**/prisma/*.db
backend/**/prisma/*.db-journal

# Uploaded files
**/uploads/

# Claude
.claude/worktrees/
.claude/plans/
