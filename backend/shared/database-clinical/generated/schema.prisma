}

model PatientConsent {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // Consent Details
  consentType     String  @map("consent_type") @db.VarChar(100)
  consentCategory String  @map("consent_category") @db.VarChar(50)
  consentStatus   String  @map("consent_status") @db.VarChar(20)
  consentScope    String? @map("consent_scope") @db.Text

  // Consent Metadata
  purpose     String  @map("purpose") @db.Text
  description String? @map("description") @db.Text
  legalBasis  String? @map("legal_basis") @db.VarChar(50)

  // Validity
  effectiveFrom  DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveUntil DateTime? @map("effective_until") @db.Timestamptz(6)
  isActive       Boolean   @default(true) @map("is_active")

  // Capture Method
  captureMethod      String   @map("capture_method") @db.VarChar(50)
  capturedBy         String?  @map("captured_by") @db.Uuid
  capturedAt         DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)
  capturedAtFacility String?  @map("captured_at_facility") @db.Uuid

  // Evidence
  signatureUrl        String? @map("signature_url") @db.Text
  documentUrl         String? @map("document_url") @db.Text
  witnessedBy         String? @map("witnessed_by") @db.Uuid
  witnessSignatureUrl String? @map("witness_signature_url") @db.Text

  // Revocation
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedBy        String?   @map("revoked_by") @db.Uuid
  revocationReason String?   @map("revocation_reason") @db.Text
  revocationMethod String?   @map("revocation_method") @db.VarChar(50)

  // Metadata
  metadata         Json?   @default("{}")
  version          Int     @default(1)
  parentConsentId  String? @map("parent_consent_id") @db.Uuid
  linkedEntityType String? @map("linked_entity_type") @db.VarChar(50)
  linkedEntityId   String? @map("linked_entity_id") @db.Uuid

  // System
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, isActive], map: "idx_patient_consent_patient_active")
  @@index([tenantId, consentType, consentStatus], map: "idx_patient_consent_type_status")
  @@index([tenantId, consentCategory], map: "idx_patient_consent_category")
  @@index([tenantId, effectiveFrom, effectiveUntil], map: "idx_patient_consent_validity")
  @@index([tenantId, linkedEntityType, linkedEntityId], map: "idx_patient_consent_linked")
  @@map("patient_consents")
}

model ConsentTemplate {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Template Details
  templateCode    String @unique @map("template_code") @db.VarChar(100)
