/// Patient device connection
model PatientDeviceConnection {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // Device platform
  platform   String  @map("platform") @db.VarChar(50) // apple_health, fitbit, oura, garmin, dexcom, libre, whoop
  deviceType String? @map("device_type") @db.VarChar(50) // watch, ring, cgm, scale, etc.
  deviceName String? @map("device_name") @db.VarChar(100)

  // OAuth credentials (encrypted)
  accessToken    String?   @map("access_token") @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)

  // Platform-specific identifiers
  platformUserId   String? @map("platform_user_id") @db.VarChar(255)
  platformDeviceId String? @map("platform_device_id") @db.VarChar(255)

  // Connection status
  status         DeviceConnectionStatus @default(PENDING) @map("status")
  lastSyncAt     DateTime?              @map("last_sync_at") @db.Timestamptz(6)
  lastSyncStatus String?                @map("last_sync_status") @db.VarChar(50)

  // Data permissions granted
  permissionsGranted Json? @map("permissions_granted") @db.JsonB // ['heart_rate', 'steps', 'sleep', 'glucose', etc.]

  // Sync configuration
  syncEnabled         Boolean @default(true) @map("sync_enabled")
  syncIntervalMinutes Int     @default(60) @map("sync_interval_minutes")

  // Error tracking
  lastErrorAt       DateTime? @map("last_error_at") @db.Timestamptz(6)
  lastErrorMessage  String?   @map("last_error_message") @db.Text
  consecutiveErrors Int       @default(0) @map("consecutive_errors")

  // Audit
  connectedAt    DateTime  @default(now()) @map("connected_at") @db.Timestamptz(6)
  disconnectedAt DateTime? @map("disconnected_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  patient       Patient              @relation(fields: [patientId], references: [id])
  syncLogs      DeviceSyncLog[]
  healthMetrics DeviceHealthMetric[]

  @@unique([tenantId, patientId, platform], map: "unique_patient_platform")
  @@index([tenantId, patientId], map: "idx_device_conn_tenant_patient")
  @@index([tenantId, status], map: "idx_device_conn_tenant_status")
  @@map("patient_device_connections")
}

/// Device sync operation log
model DeviceSyncLog {
  id           String @id @default(uuid()) @map("id") @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  connectionId String @map("connection_id") @db.Uuid
  patientId    String @map("patient_id") @db.Uuid

  // Sync operation
  syncType String           @map("sync_type") @db.VarChar(50) // full, incremental, manual
  status   DeviceSyncStatus @default(PENDING) @map("status")

  // Timing
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)

  // Data range
  dataStartDate DateTime? @map("data_start_date") @db.Timestamptz(6)
  dataEndDate   DateTime? @map("data_end_date") @db.Timestamptz(6)

  // Results
  recordsProcessed Int @default(0) @map("records_processed")
  recordsInserted  Int @default(0) @map("records_inserted")
  recordsUpdated   Int @default(0) @map("records_updated")
  recordsSkipped   Int @default(0) @map("records_skipped")

  // Errors
  errorMessage String? @map("error_message") @db.Text
  errorDetails Json?   @map("error_details") @db.JsonB

  // Relations
  connection PatientDeviceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, connectionId], map: "idx_sync_log_tenant_connection")
  @@index([tenantId, patientId, startedAt], map: "idx_sync_log_tenant_patient_date")
  @@map("device_sync_logs")
}

/// Health metrics from devices
model DeviceHealthMetric {
  id           String @id @default(uuid()) @map("id") @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  patientId    String @map("patient_id") @db.Uuid
  connectionId String @map("connection_id") @db.Uuid

  // Metric identification
  metricType    String  @map("metric_type") @db.VarChar(50) // heart_rate, steps, sleep, glucose, hrv, spo2, weight, blood_pressure
  metricSubtype String? @map("metric_subtype") @db.VarChar(50) // resting_hr, max_hr, deep_sleep, etc.

  // Timestamp of the reading
  recordedAt      DateTime @map("recorded_at") @db.Timestamptz(6)
  recordedAtLocal String?  @map("recorded_at_local") @db.VarChar(30) // Local time string for display

  // Value
  value Decimal @map("value") @db.Decimal(12, 4)
  unit  String  @map("unit") @db.VarChar(20)

  // For range values (e.g., blood pressure, glucose ranges)
  valueMin Decimal? @map("value_min") @db.Decimal(12, 4)
  valueMax Decimal? @map("value_max") @db.Decimal(12, 4)
  valueAvg Decimal? @map("value_avg") @db.Decimal(12, 4)

  // Data quality
  confidence Decimal? @map("confidence") @db.Decimal(5, 2) // 0-100
  source     String   @map("source") @db.VarChar(50) // device model or app name

  // Additional metadata
  metadata Json? @map("metadata") @db.JsonB

  // Deduplication
  platformRecordId String? @map("platform_record_id") @db.VarChar(255)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  connection PatientDeviceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  patient    Patient                 @relation(fields: [patientId], references: [id])

  @@unique([connectionId, metricType, platformRecordId], map: "unique_device_metric_record")
  @@index([tenantId, patientId, metricType], map: "idx_device_metric_tenant_patient_type")
  @@index([tenantId, patientId, recordedAt], map: "idx_device_metric_tenant_patient_date")
  @@index([tenantId, patientId, metricType, recordedAt], map: "idx_device_metric_full")
  @@map("device_health_metrics")
}

// ============================================================================
// AI SEMANTIC SEARCH - Document Embeddings
// ============================================================================

/// Clinical document embeddings for semantic search
/// Uses pgvector for efficient similarity search
/// Note: The embedding column uses Unsupported type for pgvector's vector type
model ClinicalDocumentEmbedding {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Source reference
  documentType String @map("document_type") @db.VarChar(50) // 'encounter_note', 'discharge_summary'
  documentId   String @map("document_id") @db.Uuid

  // Chunk info
  chunkIndex       Int    @default(0) @map("chunk_index")
  chunkText        String @map("chunk_text") @db.Text
  chunkStartOffset Int?   @map("chunk_start_offset")
  chunkEndOffset   Int?   @map("chunk_end_offset")

  // Vector embedding (1536 dims for text-embedding-3-small)
  // Using Unsupported because Prisma doesn't natively support pgvector
  // This column should be created with: embedding vector(1536)
  embedding Unsupported("vector(1536)")?

  // Denormalized metadata for filtered search (IDs)
  patientId     String   @map("patient_id") @db.Uuid
  encounterId   String?  @map("encounter_id") @db.Uuid
  facilityId    String   @map("facility_id") @db.Uuid
  departmentId  String?  @map("department_id") @db.Uuid
  specialtyCode String?  @map("specialty_code") @db.VarChar(50)
  documentDate  DateTime @map("document_date") @db.Timestamptz(6)

  // Denormalized patient metadata (for filtering without cross-DB joins)
  patientName     String? @map("patient_name") @db.VarChar(200)
  patientMrn      String? @map("patient_mrn") @db.VarChar(50)
  patientGender   String? @map("patient_gender") @db.VarChar(20)
  patientAgeAtDoc Int?    @map("patient_age_at_doc")

  // Denormalized encounter metadata
  encounterNumber String? @map("encounter_number") @db.VarChar(50)
  encounterType   String? @map("encounter_type") @db.VarChar(50)

  // Denormalized author metadata
  authorStaffId String? @map("author_staff_id") @db.Uuid
  authorName    String? @map("author_name") @db.VarChar(200)

  // Denormalized facility/department names
  departmentName String? @map("department_name") @db.VarChar(200)
  facilityName   String? @map("facility_name") @db.VarChar(200)

  isActive       Boolean  @default(true) @map("is_active")
  embeddedAt     DateTime @default(now()) @map("embedded_at") @db.Timestamptz(6)
  embeddingModel String   @map("embedding_model") @db.VarChar(100)

  @@unique([tenantId, documentType, documentId, chunkIndex], map: "ux_document_embedding_unique")
  @@index([tenantId, patientId, isActive], map: "idx_emb_tenant_patient")
  @@index([tenantId, documentDate, isActive], map: "idx_emb_tenant_date")
  @@index([tenantId, documentType, isActive], map: "idx_emb_tenant_type")
  @@index([tenantId, facilityId, isActive], map: "idx_emb_tenant_facility")
  @@index([tenantId, patientMrn, isActive], map: "idx_emb_tenant_mrn")
  @@index([tenantId, encounterType, isActive], map: "idx_emb_tenant_enc_type")
  @@index([tenantId, authorStaffId, isActive], map: "idx_emb_tenant_author")
  @@map("clinical_document_embeddings")
}

/// Embedding sync status - Tracks documents pending embedding
model EmbeddingSyncStatus {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  documentType  String    @map("document_type") @db.VarChar(50)
  documentId    String    @map("document_id") @db.Uuid
  status        String    @db.VarChar(20) // 'pending', 'processing', 'completed', 'failed'
  lastAttemptAt DateTime? @map("last_attempt_at") @db.Timestamptz(6)
  attemptCount  Int       @default(0) @map("attempt_count")
  errorMessage  String?   @map("error_message") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, documentType, documentId], map: "ux_embedding_sync_document")
  @@index([status, attemptCount], map: "idx_embedding_sync_pending")
  @@index([tenantId, status], map: "idx_embedding_sync_tenant_status")
  @@map("embedding_sync_status")
}

// ============================================================================
// CLINICAL ANALYTICS - Structured observation & coding tables
// ============================================================================

/// Clinical Observations - FHIR Observation pattern for structured clinical measurements
/// Stores vitals, lab results, imaging findings, assessment scores as individually coded rows.
/// Note: The underlying table is partitioned by tenant_id + observed_at via raw SQL migration.
/// Prisma model is used for type generation and non-partitioned dev environments.
model ClinicalObservation {
  id          String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  patientId   String  @map("patient_id") @db.Uuid
  encounterId String? @map("encounter_id") @db.Uuid
  orderId     String? @map("order_id") @db.Uuid

  // Observation coding (LOINC for vitals/labs, SNOMED for clinical findings)
  code          String  @db.VarChar(20)
  codeSystem    String  @map("code_system") @db.VarChar(20) // LOINC, SNOMED-CT
  displayName   String  @map("display_name") @db.VarChar(255)
  displayNameAr String? @map("display_name_ar") @db.VarChar(255)
  category      String  @db.VarChar(50) // vital-signs, laboratory, imaging, exam, score

  // Value - one of these will be populated per observation
  valueNumeric    Decimal? @map("value_numeric") @db.Decimal(12, 4)
  valueString     String?  @map("value_string") @db.Text
  valueCode       String?  @map("value_code") @db.VarChar(50)
  valueCodeSystem String?  @map("value_code_system") @db.VarChar(20)

  // Unit of measurement
  unit String? @db.VarChar(50)

  // Reference ranges for interpretation
  refRangeLow    Decimal? @map("ref_range_low") @db.Decimal(12, 4)
  refRangeHigh   Decimal? @map("ref_range_high") @db.Decimal(12, 4)
  interpretation String?  @db.VarChar(20) // normal, high, low, critical_high, critical_low, abnormal

  // Provenance
  observedAt DateTime @map("observed_at") @db.Timestamptz(6)
  observedBy String?  @map("observed_by") @db.Uuid
  sourceType String   @map("source_type") @db.VarChar(30) // triage, lab_result, imaging_result, assessment, manual
  sourceId   String?  @map("source_id") @db.Uuid

  // Relations
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, patientId, code], map: "idx_obs_tenant_patient_code")
  @@index([tenantId, code, observedAt], map: "idx_obs_tenant_code_time")
  @@index([tenantId, encounterId], map: "idx_obs_tenant_encounter")
  @@index([tenantId, category, observedAt], map: "idx_obs_tenant_category_time")
  @@index([tenantId, orderId], map: "idx_obs_tenant_order")
  @@index([tenantId, patientId, category, observedAt], map: "idx_obs_tenant_patient_category_time")
  @@map("clinical_observations")
}

/// Observation Code Catalog - Reference table for LOINC/SNOMED observation codes
model ObservationCodeCatalog {
  id            String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid // NULL = global
  code          String   @db.VarChar(20)
  codeSystem    String   @map("code_system") @db.VarChar(20) // LOINC, SNOMED-CT
  displayName   String   @map("display_name") @db.VarChar(255)
  displayNameAr String?  @map("display_name_ar") @db.VarChar(255)
  category      String   @db.VarChar(50) // vital-signs, laboratory, imaging, score
  labDomain     String?  @map("lab_domain") @db.VarChar(50) // hematology, chemistry, microbiology, coagulation, urinalysis
  dataType      String   @map("data_type") @db.VarChar(20) // numeric, string, coded
  defaultUnit   String?  @map("default_unit") @db.VarChar(50)
  refRangeLow   Decimal? @map("ref_range_low") @db.Decimal(12, 4)
  refRangeHigh  Decimal? @map("ref_range_high") @db.Decimal(12, 4)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  labTestTemplates LabTestResultTemplate[]

  @@unique([tenantId, code, codeSystem], map: "ux_obs_code_system")
  @@index([tenantId, category, isActive], map: "idx_obs_catalog_tenant_category")
  @@map("observation_code_catalog")
}

/// Encounter Clinical Codings - Structured coded data captured during AI-assisted charting
/// Written when clinician accepts/rejects AI coding suggestions or manually adds codes.
/// Pairs ICD-10 with SNOMED equivalents. Tracks AI provenance (confidence, rationale).
model EncounterClinicalCoding {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Primary code
  code          String  @db.VarChar(20) // E11.9, J06.9, 73211009
  codeSystem    String  @map("code_system") @db.VarChar(20) // ICD-10, SNOMED-CT, CPT, LOINC
  displayName   String  @map("display_name") @db.VarChar(500)
  displayNameAr String? @map("display_name_ar") @db.VarChar(500)

  // Paired SNOMED code (when primary is ICD-10, store SNOMED equivalent)
  snomedCode    String? @map("snomed_code") @db.VarChar(20)
  snomedDisplay String? @map("snomed_display") @db.VarChar(500)

  // Classification
  codingType String @map("coding_type") @db.VarChar(30) // diagnosis, symptom, finding, procedure, medication

  // AI provenance
  confidence     Float?  @map("confidence") // 0.0-1.0 from AI
  rationale      String? @map("rationale") @db.Text
  aiSuggestionId String? @map("ai_suggestion_id") @db.Uuid // FK to ai_note_suggestions

  // Source context (which part of the note triggered this)
  sourceBlockType String? @map("source_block_type") @db.VarChar(50) // chiefHpi, history, notes, assessment
  sourceText      String? @map("source_text") @db.Text

  // Clinician action
  status     String    @default("accepted") @map("status") @db.VarChar(20) // accepted, rejected, modified, manual
  reviewedBy String?   @map("reviewed_by") @db.Uuid
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  // Catalog validation
  catalogMatch Boolean  @default(false) @map("catalog_match")
  isBillable   Boolean? @map("is_billable")

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, encounterId], map: "idx_clinical_codings_encounter")
  @@index([tenantId, patientId], map: "idx_clinical_codings_patient")
  @@index([tenantId, code, codeSystem], map: "idx_clinical_codings_code")
  @@index([tenantId, codingType, createdAt], map: "idx_clinical_codings_type_date")
  @@index([tenantId, status], map: "idx_clinical_codings_status")
  @@map("encounter_clinical_codings")
}

