  durationMinutes Int?      @map("duration_minutes")

  // Performers
  primaryPerformer String?  @map("primary_performer") @db.Uuid
  assistants       String[] @db.Uuid // array of staff UUIDs

  // Clinical details
  estimatedBloodLoss String? @map("estimated_blood_loss") @db.VarChar(50)
  implantsUsed       Json?   @map("implants_used") @db.JsonB // array of { name, manufacturer, lot }

  // Authorship
  reportedBy String?   @map("reported_by") @db.Uuid
  reportedAt DateTime? @map("reported_at") @db.Timestamptz(6)

  comments String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  order     ClinicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  encounter Encounter     @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId], map: "idx_procedure_report_order")
  @@index([tenantId, patientId], map: "idx_procedure_report_patient")
  @@index([tenantId, encounterId], map: "idx_procedure_report_encounter")
  @@index([tenantId, reportStatus], map: "idx_procedure_report_status")
  @@index([tenantId, patientId, reportStatus], map: "idx_procedure_report_patient_status")
  @@map("procedure_reports")
}

