}

model ValueSetConcept {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  valueSetId    String    @map("value_set_id") @db.Uuid
  valueSetCode  String    @map("value_set_code") @db.VarChar(100)
  code          String    @db.VarChar(100)
  display       String    @db.VarChar(500)
  definition    String?   @db.Text
  systemCode    String?   @map("system_code") @db.VarChar(100)
  parentId      String?   @map("parent_id") @db.Uuid
  sortOrder     Int       @default(0) @map("sort_order")
  isDefault     Boolean   @default(false) @map("is_default")
  status        String    @default("active") @db.VarChar(20)
  effectiveFrom DateTime? @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid

  valueSet        ValueSet                     @relation(fields: [valueSetId], references: [id], onDelete: Cascade)
  valueSetByCode  ValueSet                     @relation("ValueSetByCode", fields: [valueSetCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  parent          ValueSetConcept?             @relation("ConceptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
