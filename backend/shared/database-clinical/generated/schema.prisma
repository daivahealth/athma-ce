// ============================================================================
// CLINICAL REPORTING - Structured results for Lab, Imaging, Procedure orders
// ============================================================================

/// Audit trail for all report status transitions (shared across report types)
model ReportStatusHistory {
  id         String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  reportType String   @map("report_type") @db.VarChar(20) // lab, imaging, procedure
  reportId   String   @map("report_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(20)
  toStatus   String   @map("to_status") @db.VarChar(20)
  changedBy  String   @map("changed_by") @db.Uuid
  changedAt  DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  reason     String?  @db.Text // required for amendments/corrections
  version    Int      @default(1)

  @@index([tenantId, reportType, reportId], map: "idx_report_status_history")
  @@index([tenantId, changedAt], map: "idx_report_status_history_time")
  @@map("report_status_history")
}

/// Lab Report - Structured laboratory test results with specimen tracking and verification
model LabReport {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  orderId     String @map("order_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Report status workflow: DRAFT -> PRELIMINARY -> FINAL -> AMENDED
  reportStatus      String  @default("DRAFT") @map("report_status") @db.VarChar(20)
  version           Int     @default(1)
  previousVersionId String? @map("previous_version_id") @db.Uuid

  // Specimen information
  specimenType   String?   @map("specimen_type") @db.VarChar(100)
  collectionDate DateTime? @map("collection_date") @db.Timestamptz(6)
  receivedDate   DateTime? @map("received_date") @db.Timestamptz(6)

  // Authorship
  reportedBy String?   @map("reported_by") @db.Uuid // lab tech who entered results
  verifiedBy String?   @map("verified_by") @db.Uuid // pathologist/supervisor sign-off
  reportedAt DateTime? @map("reported_at") @db.Timestamptz(6)
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(6)

  // Notes
  comments      String? @db.Text
  internalNotes String? @map("internal_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  order     ClinicalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  encounter Encounter       @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  items     LabResultItem[]

  @@index([tenantId, orderId], map: "idx_lab_report_order")
  @@index([tenantId, patientId], map: "idx_lab_report_patient")
  @@index([tenantId, encounterId], map: "idx_lab_report_encounter")
  @@index([tenantId, reportStatus], map: "idx_lab_report_status")
  @@index([tenantId, patientId, reportStatus], map: "idx_lab_report_patient_status")
  @@map("lab_reports")
}

/// Lab Result Item - Individual analyte/test component within a lab report
model LabResultItem {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  labReportId String @map("lab_report_id") @db.Uuid
  sortOrder   Int    @default(0) @map("sort_order")

  // Test identification (LOINC coding)
  testCode   String  @map("test_code") @db.VarChar(20)
  codeSystem String  @default("LOINC") @map("code_system") @db.VarChar(20)
  testName   String  @map("test_name") @db.VarChar(255)
  testNameAr String? @map("test_name_ar") @db.VarChar(255)

  // Result value - one of these will be populated per item
  valueNumeric Decimal? @map("value_numeric") @db.Decimal(12, 4)
  valueString  String?  @map("value_string") @db.Text
  valueCode    String?  @map("value_code") @db.VarChar(50)

  // Unit of measurement and reference ranges
  unit         String?  @db.VarChar(50)
  refRangeLow  Decimal? @map("ref_range_low") @db.Decimal(12, 4)
  refRangeHigh Decimal? @map("ref_range_high") @db.Decimal(12, 4)
  refRangeText String?  @map("ref_range_text") @db.VarChar(100) // e.g., "Negative", "< 5.0"

  // Interpretation
  interpretation String? @db.VarChar(20) // normal, high, low, critical_high, critical_low, abnormal
  abnormalFlag   Boolean @default(false) @map("abnormal_flag")
  criticalFlag   Boolean @default(false) @map("critical_flag")

  // Notes
  comment String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  labReport LabReport @relation(fields: [labReportId], references: [id], onDelete: Cascade)

  @@index([tenantId, labReportId], map: "idx_lab_result_item_report")
  @@index([tenantId, testCode], map: "idx_lab_result_item_code")
  @@map("lab_result_items")
}

