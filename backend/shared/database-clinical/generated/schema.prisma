/// Inpatient Event - Comprehensive audit trail of all admission-related events
/// Captures state transitions, transfers, flag changes, and all clinical actions
/// This provides complete timeline, analytics, and audit compliance
model InpatientEvent {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid

  // Core References
  admissionId String @map("admission_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Event Type
  eventType InpatientEventType @map("event_type")

  // Status Change Tracking (optional - only populated for status change events)
  fromAdmissionStatus InpatientAdmissionStatus? @map("from_admission_status")
  toAdmissionStatus   InpatientAdmissionStatus? @map("to_admission_status")

  fromDischargeStatus InpatientDischargeStatus? @map("from_discharge_status")
  toDischargeStatus   InpatientDischargeStatus? @map("to_discharge_status")

  fromAcuity InpatientAcuity? @map("from_acuity")
  toAcuity   InpatientAcuity? @map("to_acuity")

  // Location Change Tracking (for transfers - Foundation IDs)
  fromWardId  String? @map("from_ward_id") @db.Uuid
  fromSpaceId String? @map("from_space_id") @db.Uuid
  fromBedId   String? @map("from_bed_id") @db.Uuid

  toWardId  String? @map("to_ward_id") @db.Uuid
  toSpaceId String? @map("to_space_id") @db.Uuid
  toBedId   String? @map("to_bed_id") @db.Uuid

  // Event Context
  reason   String? @db.Text
  metadata Json?   @db.JsonB // Additional event-specific data

  // Performer
  performedBy String   @map("performed_by") @db.Uuid // Staff ID from Foundation
  performedAt DateTime @default(now()) @map("performed_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId, performedAt], map: "idx_events_admission_time")
  @@index([tenantId, facilityId, performedAt], map: "idx_events_facility_time")
  @@index([tenantId, patientId, performedAt], map: "idx_events_patient_time")
  @@index([tenantId, eventType, performedAt], map: "idx_events_type_time")
  @@index([tenantId, performedBy, performedAt], map: "idx_events_performer_time")
  @@map("inpatient_events")
}

// ============================================================================
// CARE CHANNEL COMMUNICATION - Care Team Collaboration
// ============================================================================

/// Care Channel - One per admission for care team communication
/// Combines human chat and automated clinical transaction messages in unified timeline
model CareChannel {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid

  // Admission Link (1:1 relationship)
  admissionId String @unique @map("admission_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  // Channel Metadata
  channelName String?       @map("channel_name") @db.VarChar(255)
  status      ChannelStatus @default(ACTIVE) @map("status")

  // Lifecycle Timestamps
  activatedAt   DateTime  @default(now()) @map("activated_at") @db.Timestamptz(6)
  closedAt      DateTime? @map("closed_at") @db.Timestamptz(6)
  closedBy      String?   @map("closed_by") @db.Uuid
  closureReason String?   @map("closure_reason") @db.VarChar(100) // discharged, transferred_out, patient_expired

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid

  // Relations
  admission          InpatientAdmission  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  members            CareChannelMember[]
  messages           ChannelMessage[]
  checklistInstances ChecklistInstance[]

  @@index([tenantId, admissionId], map: "idx_channel_tenant_admission")
  @@index([tenantId, facilityId, status], map: "idx_channel_tenant_facility_status")
  @@index([tenantId, patientId], map: "idx_channel_tenant_patient")
  @@map("care_channels")
}

/// Care Channel Member - Care team membership with temporal tracking
model CareChannelMember {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  channelId String @map("channel_id") @db.Uuid

  // Staff Identity (from Foundation service)
  staffId String @map("staff_id") @db.Uuid

  // Care Team Role
  memberRole CareTeamRole @map("member_role")

  // Temporal Membership Tracking
  addedAt       DateTime  @default(now()) @map("added_at") @db.Timestamptz(6)
  removedAt     DateTime? @map("removed_at") @db.Timestamptz(6)
  addedBy       String    @map("added_by") @db.Uuid
  removedBy     String?   @map("removed_by") @db.Uuid
  removalReason String?   @map("removal_reason") @db.Text

  // Member Preferences (optional for MVP, prepare for future)
  notificationsEnabled Boolean @default(true) @map("notifications_enabled")

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  channel CareChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, staffId, addedAt], name: "unique_member_per_addition")
  @@index([tenantId, channelId, removedAt], map: "idx_member_channel_active")
  @@index([tenantId, staffId, removedAt], map: "idx_member_staff_active")
  @@map("care_channel_members")
}

/// Channel Message - Unified timeline of chat and system events
/// Supports both human text messages and automated clinical transaction messages
model ChannelMessage {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid
  channelId  String @map("channel_id") @db.Uuid

  // Message Classification
  messageType    MessageType @map("message_type")
  messageSubtype String?     @map("message_subtype") @db.VarChar(100) // order_created, bed_transfer, discharge_intimation, etc.

  // Content
  bodyText    String? @map("body_text") @db.Text // Human-readable text
  payloadJson Json?   @map("payload_json") @db.JsonB // Structured event data

  // Linked Entity (Transaction Source)
  linkedEntityType String? @map("linked_entity_type") @db.VarChar(50) // clinical_order, bed_assignment, discharge_checklist
  linkedEntityId   String? @map("linked_entity_id") @db.Uuid

  // Checklist Integration (for interactive checklist messages)
  checklistInstanceId String? @unique @map("checklist_instance_id") @db.Uuid

  // Message Metadata
  visibility MessageVisibility @default(CARE_TEAM) @map("visibility")
  priority   MessagePriority   @default(NORMAL) @map("priority")

  // Author (staff_id for human messages, null for system messages)
  authorStaffId   String? @map("author_staff_id") @db.Uuid
  isSystemMessage Boolean @default(false) @map("is_system_message")

  // Idempotency (CRITICAL for preventing duplicate system messages)
  idempotencyKey String? @unique @map("idempotency_key") @db.VarChar(255)

  // Soft Delete (append-only, no hard deletes)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  channel           CareChannel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  checklistInstance ChecklistInstance?

  @@index([tenantId, channelId, createdAt], map: "idx_message_channel_timeline")
  @@index([tenantId, linkedEntityType, linkedEntityId], map: "idx_message_linked_entity")
  @@index([tenantId, channelId, messageType], map: "idx_message_channel_type")
  @@index([tenantId, authorStaffId], map: "idx_message_author")
  @@index([idempotencyKey], map: "idx_message_idempotency")
  @@map("channel_messages")
}

