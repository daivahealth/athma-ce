/// Administrative services catalog for non-clinical services
/// Covers registration, consultation fees, admission, room charges, nursing procedures, etc.
/// This is distinct from clinical catalogs (Lab, Imaging, Procedures, Medications)
model AdministrativeService {
  id                 String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String?  @map("tenant_id") @db.Uuid // NULL = global service
  serviceName        String   @map("service_name") @db.VarChar(255)
  serviceCode        String?  @map("service_code") @db.VarChar(100) // Internal code
  billingCode        String?  @map("billing_code") @db.VarChar(100) // CPT or local billing code
  billingCodeType    String?  @map("billing_code_type") @db.VarChar(50) // CPT, LOCAL, CUSTOM
  billingDescription String?  @map("billing_description") @db.VarChar(255)
  serviceCategory    String   @map("service_category") @db.VarChar(100) // registration, consultation, admission, room_charge, administrative, nursing, therapy
  serviceType        String?  @map("service_type") @db.VarChar(100) // new_patient, follow_up, emergency, routine
  department         String?  @db.VarChar(100) // general, emergency, OPD, IPD
  careSetting        String?  @map("care_setting") @db.VarChar(20) // OP, IP, DAYCARE, ANY
  description        String?  @db.Text
  durationMinutes    Int?     @map("duration_minutes") // Expected duration for consultation/therapy services
  requiresStaff      Boolean  @default(false) @map("requires_staff") // Does this service require specific staff assignment?
  staffType          String?  @map("staff_type") @db.VarChar(100) // doctor, nurse, therapist, admin
  requiresRoom       Boolean  @default(false) @map("requires_room") // Does this service require room booking?
  roomType           String?  @map("room_type") @db.VarChar(100) // consultation_room, treatment_room, ward
  isTaxable          Boolean  @default(true) @map("is_taxable")
  isActive           Boolean  @default(true) @map("is_active")
  metadata           Json? // Extended properties
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, serviceCode], map: "unique_tenant_admin_service_code")
  @@index([tenantId])
  @@index([serviceCategory])
  @@index([serviceType])
  @@index([department])
  @@index([careSetting])
  @@index([isActive])
  @@map("administrative_services")
}

// ============================================================================
// VITAL SIGNS TEMPLATES
// ============================================================================

/// Configurable vital signs templates for different care settings, age groups, and specialties
model VitalSignsTemplate {
  id           String @id @default(uuid()) @map("id") @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  templateCode String @map("template_code") @db.VarChar(50) // e.g., "default_opd_vitals"
  version      Int    @default(1)
  name         Json // { "en": "Default OPD Vitals", "ar": "..." }
  description  Json? // { "en": "...", "ar": "..." }

  // Context for template applicability
  careSetting String[] @map("care_setting") // ["OPD", "ER", "IPD", "ICU"]
  ageGroup    String[] @map("age_group") // ["newborn", "infant", "child", "adolescent", "adult", "elderly"]
  specialties String[] // ["GEN_MED", "CARDIO", "PEDIATRICS", etc.]

  // Template structure (JSON)
  groups Json // Array of vital sign groups with items

  // Metadata
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default") // Default template for context
  metadata  Json? // Extended properties
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, templateCode], map: "unique_tenant_template_code")
  @@index([tenantId])
  @@index([careSetting])
  @@index([ageGroup])
  @@index([specialties])
  @@index([isActive])
  @@index([isDefault])
  @@map("vital_signs_templates")
}

// ============================================================================
// INPATIENT MODULE - CLINICAL WORKFLOWS
// ============================================================================
// NOTE: Ward, Space (patient rooms), Bed structures are managed in Foundation service
// Clinical service only stores IDs and resolves details via Foundation API
// Foundation hierarchy: Facility → Department → Ward → Space → Bed

/// Inpatient Admission - Core admission record linked to Encounter
model InpatientAdmission {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid

  // Patient & Encounter
  patientId   String @map("patient_id") @db.Uuid
  encounterId String @unique @map("encounter_id") @db.Uuid // Links to Encounter with encounterClass = 'IMP'

  // Admission Details
  admissionNumber String   @unique @map("admission_number") @db.VarChar(50)
  admissionDate   DateTime @map("admission_date") @db.Timestamptz(6)
  admissionType   String   @map("admission_type") @db.VarChar(50) // elective, emergency, maternity, day_case, transfer
  admissionSource String   @map("admission_source") @db.VarChar(50) // emergency_room, outpatient_dept, transfer_in, direct, physician_referral

  // Clinical Team
  attendingPhysicianId          String   @map("attending_physician_id") @db.Uuid // From Foundation Staff
  attendingPhysicianDisplayName String?  @map("attending_physician_display_name") @db.VarChar(255) // Denormalized for fast access
  consultingPhysicians          String[] @map("consulting_physicians") // Array of staff UUIDs
  primaryNurseId                String?  @map("primary_nurse_id") @db.Uuid

  // Current Location (IDs reference Foundation service entities - resolve via API)
  currentWardId    String? @map("current_ward_id") @db.Uuid // Foundation: Ward
  currentWardName  String? @map("current_ward_name") @db.VarChar(255) // Denormalized for fast access
  currentSpaceId   String? @map("current_space_id") @db.Uuid // Foundation: Space (patient room)
  currentBedId     String? @map("current_bed_id") @db.Uuid // Foundation: Bed
  currentBedNumber String? @map("current_bed_number") @db.VarChar(50) // Denormalized for fast access

  // Status - Using orthogonal status model
  admissionStatus InpatientAdmissionStatus @default(ADMITTED) @map("admission_status")
  dischargeStatus InpatientDischargeStatus @default(NONE) @map("discharge_status")
  acuity          InpatientAcuity          @default(STABLE) @map("acuity")

  // Ward Board Flags - Denormalized for fast rendering
  // Example: {"npo":true,"fallRisk":"high","telemetry":true,"isolation":false,"allergies":true}
  boardFlags Json? @map("board_flags") @db.JsonB

  // Legacy MVP: Alert Flags (kept for backward compatibility during migration)
  clinicalAlerts String[] @default([]) @map("clinical_alerts") // critical, isolation, fall_risk, npo, allergies, dnr, covid
  isolationType  String?  @map("isolation_type") @db.VarChar(50) // contact, droplet, airborne, protective
  fallRiskScore  Int?     @map("fall_risk_score") // 1-5 scale (1=low, 5=high)

  // MVP: Vitals Tracking for Ward Dashboard
  lastVitalsAt    DateTime? @map("last_vitals_at") @db.Timestamptz(6)
  nextVitalsAt    DateTime? @map("next_vitals_at") @db.Timestamptz(6)
  vitalsFrequency String?   @map("vitals_frequency") @db.VarChar(20) // q1h, q2h, q4h, q8h, q12h, daily

  // Discharge Planning
  expectedDischargeDate DateTime? @map("expected_discharge_date") @db.Date
  dischargePlannedBy    String?   @map("discharge_planned_by") @db.Uuid
  dischargeNotes        String?   @map("discharge_notes") @db.Text

  // Discharge Details
  actualDischargeDate  DateTime? @map("actual_discharge_date") @db.Timestamptz(6)
  dischargeType        String?   @map("discharge_type") @db.VarChar(50) // routine, against_medical_advice, transfer, deceased, absconded
  dischargeDestination String?   @map("discharge_destination") @db.VarChar(100) // home, transfer_facility, nursing_home, rehabilitation, deceased
  dischargedBy         String?   @map("discharged_by") @db.Uuid

  // Insurance & Financial
  insuranceAuthNumber String?   @map("insurance_auth_number") @db.VarChar(100)
  insuranceAuthDate   DateTime? @map("insurance_auth_date") @db.Date
  estimatedCost       Decimal?  @map("estimated_cost") @db.Decimal(12, 2)

  // Length of Stay Tracking
  lengthOfStayDays Int? @map("length_of_stay_days") // Calculated field

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  patient              Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter            Encounter                 @relation(fields: [encounterId], references: [id])
  bedAssignments       BedAssignment[]
  inpatientAssessments InpatientAssessment[]
  carePlans            CarePlan[]
  nursingRounds        NursingRound[]
  intakeOutputRecords  IntakeOutput[]
  discharge            InpatientDischarge? // New discharge transaction model
  dischargeSummary     ClinicalDischargeSummary?
  dischargeChecklist   DischargeChecklist? // Legacy - kept for backward compatibility
  events               InpatientEvent[]
  careChannel          CareChannel?
  checklistInstances   ChecklistInstance[]

  @@index([tenantId, patientId], map: "idx_admissions_tenant_patient")
  @@index([tenantId, facilityId], map: "idx_admissions_tenant_facility")
  @@index([tenantId, admissionDate], map: "idx_admissions_tenant_date")
  @@index([tenantId, admissionStatus], map: "idx_admissions_tenant_admission_status")
  @@index([tenantId, dischargeStatus], map: "idx_admissions_tenant_discharge_status")
  @@index([tenantId, acuity], map: "idx_admissions_tenant_acuity")
  @@index([tenantId, attendingPhysicianId], map: "idx_admissions_tenant_physician")
  @@index([tenantId, currentWardId], map: "idx_admissions_tenant_ward")
  @@index([tenantId, currentBedId], map: "idx_admissions_tenant_bed")
  @@index([tenantId, facilityId, admissionStatus], map: "idx_admissions_facility_status")
  @@index([tenantId, facilityId, dischargeStatus], map: "idx_admissions_facility_discharge")
  @@index([tenantId, currentWardId, admissionStatus], map: "idx_admissions_ward_status") // Ward board query
  @@index([tenantId, currentWardId, nextVitalsAt], map: "idx_admissions_ward_vitals") // Dashboard vitals overdue
  @@map("inpatient_admissions")
}

/// Bed Assignment - Track bed assignment history and transfers
/// Clinical tracking of patient bed assignments. Bed/Ward/Space details are in Foundation.
model BedAssignment {
  id          String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  admissionId String? @map("admission_id") @db.Uuid
  patientId   String? @map("patient_id") @db.Uuid

  // Bed Location (IDs reference Foundation service entities - resolve via API)
  bedId   String @map("bed_id") @db.Uuid // Foundation: Bed
  wardId  String @map("ward_id") @db.Uuid // Foundation: Ward
  spaceId String @map("space_id") @db.Uuid // Foundation: Space (patient room)

  // Assignment Period
  assignedAt DateTime  @map("assigned_at") @db.Timestamptz(6)
  releasedAt DateTime? @map("released_at") @db.Timestamptz(6)

  // Transfer Tracking
  isTransfer     Boolean @default(false) @map("is_transfer")
  transferReason String? @map("transfer_reason") @db.Text
  transferType   String? @map("transfer_type") @db.VarChar(50) // clinical_need, bed_availability, patient_request, infection_control

  // Assignment Details
  assignedBy String  @map("assigned_by") @db.Uuid
  releasedBy String? @map("released_by") @db.Uuid
  notes      String? @db.Text

  // Bed Cleaning Tracking
  cleaningRequired    Boolean   @default(false) @map("cleaning_required")
  cleaningCompletedAt DateTime? @map("cleaning_completed_at") @db.Timestamptz(6)
  cleaningCompletedBy String?   @map("cleaning_completed_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission? @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId], map: "idx_bed_assignments_tenant_admission")
  @@index([tenantId, patientId], map: "idx_bed_assignments_tenant_patient")
  @@index([tenantId, bedId], map: "idx_bed_assignments_tenant_bed")
  @@index([tenantId, bedId, releasedAt], map: "idx_bed_assignments_occupancy") // Fast occupancy check
  @@index([tenantId, assignedAt], map: "idx_bed_assignments_tenant_date")
  @@index([tenantId, wardId], map: "idx_bed_assignments_tenant_ward")
  @@index([tenantId, spaceId], map: "idx_bed_assignments_tenant_space")
  @@map("bed_assignments")
}

/// Inpatient Assessment - Comprehensive clinical assessments by doctors and nurses with flexible JSONB data
/// Used for: Initial Assessment (doctor), Nursing Assessments (nurse), Shift Assessments, Focused Assessments
model InpatientAssessment {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  admissionId String @map("admission_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Assessment Details
  assessmentType String   @map("assessment_type") @db.VarChar(50) // initial_assessment, nursing_admission, shift, focused, discharge, post_transfer
  assessmentDate DateTime @map("assessment_date") @db.Timestamptz(6)

  // Vital Signs (can reference Encounter vitalSigns or store separately)
  vitalSigns Json? @map("vital_signs") @db.JsonB

  // Assessment Data (Flexible JSONB structure)
  assessmentData Json @map("assessment_data") @db.JsonB
  // Example structure:
  // {
  //   "consciousness": "alert",
  //   "orientation": "oriented_x3",
  //   "pain_score": 3,
  //   "pain_location": "lower_back",
  //   "mobility": "ambulatory",
  //   "fall_risk_score": 2,
  //   "skin_integrity": "intact",
  //   "wounds": [],
  //   "respiratory": { "pattern": "regular", "oxygen_support": "room_air" },
  //   "cardiovascular": { "rhythm": "regular" },
  //   "gastrointestinal": { "appetite": "good", "bowel_sounds": "normal" },
  //   "genitourinary": { "voiding": "normal" },
  //   "psychosocial": { "mood": "calm", "anxiety_level": "low" }
  // }

  // Clinical Findings
  abnormalFindings String? @map("abnormal_findings") @db.Text
  interventions    String? @db.Text

  // Authorship
  assessedBy String  @map("assessed_by") @db.Uuid
  reviewedBy String? @map("reviewed_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId], map: "idx_inpatient_assessments_tenant_admission")
  @@index([tenantId, patientId], map: "idx_inpatient_assessments_tenant_patient")
  @@index([tenantId, assessmentDate], map: "idx_inpatient_assessments_tenant_date")
  @@index([tenantId, assessmentType], map: "idx_inpatient_assessments_tenant_type")
  @@map("inpatient_assessments")
}

/// Care Plan - Nursing care plans with goals and interventions
model CarePlan {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  admissionId String @map("admission_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Care Plan Details
  planTitle        String @map("plan_title") @db.VarChar(200)
  nursingDiagnosis String @map("nursing_diagnosis") @db.Text // NANDA diagnosis

  // Goals (JSONB array)
  goals Json @db.JsonB
  // Example: [
  //   { "goal": "Patient will ambulate 50 feet", "target_date": "2024-01-10", "status": "in_progress" }
  // ]

  // Interventions (JSONB array)
  interventions Json @db.JsonB
  // Example: [
  //   { "intervention": "Assist with ambulation twice daily", "frequency": "BID", "status": "active" }
  // ]

  // Priority & Status
  priority Int    @default(2) // 1=high, 2=medium, 3=low
  status   String @default("active") @map("status") @db.VarChar(20) // active, achieved, discontinued, revised

  // Dates
  startDate  DateTime  @map("start_date") @db.Date
  targetDate DateTime? @map("target_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date

  // Evaluation
  evaluation    String? @db.Text
  outcomeStatus String? @map("outcome_status") @db.VarChar(50) // achieved, partially_achieved, not_achieved

  // Authorship
  createdBy String  @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId], map: "idx_care_plans_tenant_admission")
  @@index([tenantId, patientId], map: "idx_care_plans_tenant_patient")
  @@index([tenantId, status], map: "idx_care_plans_tenant_status")
  @@index([tenantId, priority], map: "idx_care_plans_tenant_priority")
  @@map("care_plans")
}

/// Nursing Round - Regular nursing rounds and patient checks
model NursingRound {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  admissionId String @map("admission_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Round Details
  roundType String   @map("round_type") @db.VarChar(50) // hourly, medication, comfort, safety, physician, multidisciplinary
  roundDate DateTime @map("round_date") @db.Timestamptz(6)
  shiftType String?  @map("shift_type") @db.VarChar(20) // morning, afternoon, night

  // Checklist Data (Flexible JSONB)
  checklistData Json @map("checklist_data") @db.JsonB
  // Example: {
  //   "patient_identification_verified": true,
  //   "vitals_stable": true,
  //   "pain_assessed": true,
  //   "medications_given": true,
  //   "fall_precautions_in_place": true,
  //   "call_bell_within_reach": true,
  //   "iv_site_checked": true
  // }

  // Findings
  findings         String? @db.Text
  issuesIdentified String? @map("issues_identified") @db.Text
  actionsPerformed String? @map("actions_performed") @db.Text

  // Authorship
  performedBy String @map("performed_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId], map: "idx_nursing_rounds_tenant_admission")
  @@index([tenantId, patientId], map: "idx_nursing_rounds_tenant_patient")
  @@index([tenantId, roundDate], map: "idx_nursing_rounds_tenant_date")
  @@index([tenantId, roundType], map: "idx_nursing_rounds_tenant_type")
  @@map("nursing_rounds")
}

/// Intake Output - Fluid intake and output tracking
model IntakeOutput {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  admissionId String @map("admission_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Record Details
  recordDate DateTime @map("record_date") @db.Timestamptz(6)
  recordType String   @map("record_type") @db.VarChar(10) // intake, output
  shiftType  String?  @map("shift_type") @db.VarChar(20) // morning, afternoon, night

  // Intake Details (if recordType = 'intake')
  intakeType        String?  @map("intake_type") @db.VarChar(50) // oral, iv, feeding_tube, blood_transfusion, tpn
  intakeAmount      Decimal? @map("intake_amount") @db.Decimal(8, 2) // in mL
  intakeDescription String?  @map("intake_description") @db.VarChar(200) // water, juice, IV saline, etc.

  // Output Details (if recordType = 'output')
  outputType        String?  @map("output_type") @db.VarChar(50) // urine, stool, vomit, drainage, blood_loss, perspiration
  outputAmount      Decimal? @map("output_amount") @db.Decimal(8, 2) // in mL
  outputDescription String?  @map("output_description") @db.VarChar(200) // foley catheter, drain site, etc.

  // Additional Details
  notes String? @db.Text

  // Authorship
  recordedBy String @map("recorded_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  admission InpatientAdmission @relation(fields: [admissionId], references: [id])

  @@index([tenantId, admissionId], map: "idx_intake_output_tenant_admission")
  @@index([tenantId, patientId], map: "idx_intake_output_tenant_patient")
  @@index([tenantId, recordDate], map: "idx_intake_output_tenant_date")
  @@index([tenantId, recordType], map: "idx_intake_output_tenant_type")
  @@map("intake_output")
}

/// Inpatient Discharge - Comprehensive discharge transaction model
/// Separates discharge workflow from admission for better tracking and audit
model InpatientDischarge {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid

  // References
  admissionId   String   @unique @map("admission_id") @db.Uuid // 1:1 with admission
  patientId     String   @map("patient_id") @db.Uuid
  encounterId   String   @map("encounter_id") @db.Uuid
  admissionDate DateTime @map("admission_date") @db.Timestamptz(6) // Copied from admission for quick reference

  // Discharge Planning Stage
  status DischargeTransactionStatus @default(PLANNING) @map("status") // PLANNING, READY, APPROVED, EXECUTED, CANCELLED

  initiatedBy String   @map("initiated_by") @db.Uuid // Case manager/physician who started
  initiatedAt DateTime @default(now()) @map("initiated_at") @db.Timestamptz(6)

  // Target discharge
  targetDischargeDate DateTime? @map("target_discharge_date") @db.Date
  targetDischargeTime String?   @map("target_discharge_time") @db.VarChar(10) // HH:MM format

  // Checklist tracking (links to generic checklist system)
  checklistInstanceId  String?   @unique @map("checklist_instance_id") @db.Uuid
  checklistCompletedAt DateTime? @map("checklist_completed_at") @db.Timestamptz(6)
  checklistCompletedBy String?   @map("checklist_completed_by") @db.Uuid
  checklistVerifiedAt  DateTime? @map("checklist_verified_at") @db.Timestamptz(6)
  checklistVerifiedBy  String?   @map("checklist_verified_by") @db.Uuid

  // Ready for discharge
  readyMarkedAt DateTime? @map("ready_marked_at") @db.Timestamptz(6)
  readyMarkedBy String?   @map("ready_marked_by") @db.Uuid
  readyRemarks  String?   @map("ready_remarks") @db.Text

  // Approval workflow (if required by facility policy)
  approvalRequired Boolean   @default(false) @map("approval_required")
  approvedBy       String?   @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz(6)
  approvalRemarks  String?   @map("approval_remarks") @db.Text

  // Actual discharge execution
  actualDischargeDate DateTime? @map("actual_discharge_date") @db.Timestamptz(6)
  actualDischargeTime String?   @map("actual_discharge_time") @db.VarChar(10) // HH:MM format
  dischargedBy        String?   @map("discharged_by") @db.Uuid // Nurse/physician who executed

  // Discharge details
  dischargeType        DischargeType?        @map("discharge_type") // ROUTINE, AGAINST_MEDICAL_ADVICE, etc.
  dischargeDestination DischargeDestination? @map("discharge_destination") // HOME, SNF, etc.
  dischargeDisposition String?               @map("discharge_disposition") @db.VarChar(100) // Additional details

  // Clinical information
  dischargeSummaryId   String? @unique @map("discharge_summary_id") @db.Uuid // Link to discharge summary document
  finalDiagnosis       Json?   @map("final_diagnosis") @db.JsonB // Array of ICD codes
  dischargeMedications Json?   @map("discharge_medications") @db.JsonB // Medications to continue
  followUpInstructions String? @map("follow_up_instructions") @db.Text
  dietInstructions     String? @map("diet_instructions") @db.Text
  activityRestrictions String? @map("activity_restrictions") @db.Text

  // Follow-up care
  followUpAppointments Json?   @map("follow_up_appointments") @db.JsonB // Array of appointments
  homeHealthOrdered    Boolean @default(false) @map("home_health_ordered")
  homeHealthAgency     String? @map("home_health_agency") @db.VarChar(200)
  dmeOrdered           Boolean @default(false) @map("dme_ordered") // Durable Medical Equipment
  dmeDescription       String? @map("dme_description") @db.Text
  transportArranged    Boolean @default(false) @map("transport_arranged")
  transportMode        String? @map("transport_mode") @db.VarChar(100) // ambulance, family, taxi

  // Patient education
  educationProvided  Boolean  @default(false) @map("education_provided")
  educationTopics    String[] @map("education_topics") // medication, wound_care, diet, etc.
  educationMaterials Json?    @map("education_materials") @db.JsonB // Documents given

  // Administrative
  billingCleared         Boolean @default(false) @map("billing_cleared")
  insuranceNotified      Boolean @default(false) @map("insurance_notified")
  medicalRecordsComplete Boolean @default(false) @map("medical_records_complete")
  belongingsReturned     Boolean @default(false) @map("belongings_returned")

  // Cancellation
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy        String?   @map("cancelled_by") @db.Uuid
  cancellationReason String?   @map("cancellation_reason") @db.Text

  // Metrics
  lengthOfStayDays      Int? @map("length_of_stay_days")
  planningDurationHours Int? @map("planning_duration_hours") // Hours from initiation to execution

  // Additional notes
  internalNotes String? @map("internal_notes") @db.Text // Staff-only notes
  patientNotes  String? @map("patient_notes") @db.Text // Notes to patient/family

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  admission         InpatientAdmission        @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  checklistInstance ChecklistInstance?        @relation(fields: [checklistInstanceId], references: [id])
  dischargeSummary  ClinicalDischargeSummary? @relation(fields: [dischargeSummaryId], references: [id])

  @@index([tenantId, admissionId], map: "idx_inpatient_discharge_tenant_admission")
  @@index([tenantId, patientId], map: "idx_inpatient_discharge_tenant_patient")
  @@index([tenantId, status], map: "idx_inpatient_discharge_tenant_status")
  @@index([tenantId, targetDischargeDate], map: "idx_inpatient_discharge_target_date")
  @@index([tenantId, actualDischargeDate], map: "idx_inpatient_discharge_actual_date")
  @@map("inpatient_discharges")
}

/// Clinical Discharge Summary - Versioned discharge summary document
