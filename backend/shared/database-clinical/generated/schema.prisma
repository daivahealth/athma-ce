/// Lab Test Result Template - maps an orderable lab test/panel to expected analytes
model LabTestResultTemplate {
  id                       String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId                 String?  @map("tenant_id") @db.Uuid // null = global template
  labTestMasterId          String   @map("lab_test_master_id") @db.Uuid
  parentTemplateId         String?  @map("parent_template_id") @db.Uuid
  nodeType                 String   @default("analyte") @map("node_type") @db.VarChar(20) // group, analyte
