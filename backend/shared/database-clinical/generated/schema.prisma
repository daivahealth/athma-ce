  bodySystem                String   @map("body_system") @db.VarChar(100) // cardiovascular, respiratory
  procedureType             String?  @map("procedure_type") @db.VarChar(100) // minor, major, endoscopic
  anesthesiaType            String?  @map("anesthesia_type") @db.VarChar(50) // local, regional, general, none
  facilityRequired          String?  @map("facility_required") @db.VarChar(50) // clinic, hospital, surgery_center
  estimatedDurationMinutes  Int?     @map("estimated_duration_minutes")
  preparationInstructions   String?  @map("preparation_instructions") @db.Text
  postProcedureInstructions String?  @map("post_procedure_instructions") @db.Text
