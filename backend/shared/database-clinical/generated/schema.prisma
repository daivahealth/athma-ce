  biomarker BiomarkerDefinition @relation(fields: [biomarkerId], references: [id])
  patient   Patient             @relation(fields: [patientId], references: [id])

  @@index([tenantId, patientId, biomarkerId], map: "idx_biomarker_result_tenant_patient_marker")
  @@index([tenantId, patientId, collectedAt], map: "idx_biomarker_result_tenant_patient_date")
