/// Wellness assessment template master
model WellnessAssessmentTemplate {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Template identification
  code        String  @map("code") @db.VarChar(50)
  name        String  @map("name") @db.VarChar(255)
  description String? @map("description") @db.Text
  version     Int     @default(1) @map("version")

  // Assessment configuration
  category         String @map("category") @db.VarChar(50) // wellness, longevity, lifestyle, fitness, mental_health
  estimatedMinutes Int?   @map("estimated_minutes")

  // Sections and questions stored as JSON
  sections Json @map("sections") @db.JsonB // [{name, order, questions: [{key, type, label, options, required, scoring}]}]

  // Scoring configuration
  scoringAlgorithm String  @default("weighted_average") @map("scoring_algorithm") @db.VarChar(50)
  scoringConfig    Json?   @map("scoring_config") @db.JsonB // weights, thresholds, categories
  maxScore         Decimal @default(100) @map("max_score") @db.Decimal(10, 2)

  // Biological age calculation (optional)
  includesBioAge Boolean @default(false) @map("includes_bio_age")
  bioAgeFormula  Json?   @map("bio_age_formula") @db.JsonB

  // Status
  isActive    Boolean   @default(true) @map("is_active")
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid

  // Relations
  assessments WellnessAssessment[]

  @@unique([tenantId, code, version], map: "unique_wellness_template_code_version")
  @@index([tenantId, isActive], map: "idx_wellness_template_tenant_active")
  @@index([tenantId, category], map: "idx_wellness_template_tenant_category")
  @@map("wellness_assessment_templates")
}

/// Patient wellness assessment instance
model WellnessAssessment {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid

  // Patient context
  patientId   String  @map("patient_id") @db.Uuid
  encounterId String? @map("encounter_id") @db.Uuid

  // Template reference
  templateId      String @map("template_id") @db.Uuid
  templateVersion Int    @map("template_version")

  // Assessment data
  responses Json @map("responses") @db.JsonB // {questionKey: value, ...}

  // Calculated scores
  overallScore     Decimal? @map("overall_score") @db.Decimal(10, 2)
  categoryScores   Json?    @map("category_scores") @db.JsonB // {categoryName: score, ...}
  biologicalAge    Int?     @map("biological_age")
  chronologicalAge Int?     @map("chronological_age")

  // Status
  status WellnessAssessmentStatus @default(DRAFT) @map("status")

  // Timing
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy  String?   @map("reviewed_by") @db.Uuid

  // Recommendations (from provider/AI)
  recommendations Json?   @map("recommendations") @db.JsonB
  notes           String? @map("notes") @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid

  // Relations
  template WellnessAssessmentTemplate @relation(fields: [templateId], references: [id])
  patient  Patient                    @relation(fields: [patientId], references: [id])

  @@index([tenantId, patientId], map: "idx_wellness_assessment_tenant_patient")
  @@index([tenantId, status], map: "idx_wellness_assessment_tenant_status")
  @@index([tenantId, templateId], map: "idx_wellness_assessment_tenant_template")
  @@map("wellness_assessments")
}

/// Wellness score history for trend tracking
model WellnessScoreHistory {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // Score data
  assessmentId String? @map("assessment_id") @db.Uuid
  scoreType    String  @map("score_type") @db.VarChar(50) // overall, category_name, biological_age
  scoreValue   Decimal @map("score_value") @db.Decimal(10, 2)

  // Context
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  source     String   @default("assessment") @map("source") @db.VarChar(50) // assessment, manual, device

  // Metadata
  metadata Json? @map("metadata") @db.JsonB

  @@index([tenantId, patientId, scoreType], map: "idx_score_history_tenant_patient_type")
  @@index([tenantId, patientId, recordedAt], map: "idx_score_history_tenant_patient_date")
  @@map("wellness_score_history")
}

