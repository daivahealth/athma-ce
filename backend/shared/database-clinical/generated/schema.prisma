generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider   = "postgresql"
  url        = env("CLINICAL_DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

// ============================================================================
// ENUMS - Inpatient Status Management
// ============================================================================

/// Clinical lifecycle status for inpatient admission
enum InpatientAdmissionStatus {
  ADMITTED // Admission created
  ACTIVE // Under care
  ON_LEAVE // Temporary leave
  DISCHARGE_PLANNING // Discharge planning in progress
  DISCHARGED // Patient discharged
  EXPIRED // Patient deceased
  ABSCONDED // Patient left without authorization
  CANCELLED // Admission cancelled before bed occupied
}

/// Discharge workflow status
enum InpatientDischargeStatus {
  NONE // No discharge planning
  FIT_FOR_DISCHARGE // Medically fit for discharge
  INITIATED // Discharge process initiated
  READY // Summary, meds, bill, transport completed
  CONFIRMED // Final discharge confirmation done
}

/// Clinical acuity level for monitoring and prioritization
enum InpatientAcuity {
  STABLE // Stable condition
  WATCH // Requires monitoring
  CRITICAL // Critical condition
}

/// Event types for inpatient audit trail
enum InpatientEventType {
  ADMISSION_CREATED
  STATUS_CHANGED
  DISCHARGE_STATUS_CHANGED
  BED_ASSIGNED
  BED_RELEASED
  TRANSFERRED
  FLAG_ADDED
  FLAG_REMOVED
  ACUITY_CHANGED
  NOTE_ADDED
  DISCHARGE_CONFIRMED
}

model Patient {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  mrn      String @unique @map("mrn") @db.VarChar(50)
  tenantId String @map("tenant_id") @db.Uuid

  // Identity
  nationalId     String? @map("national_id") @db.VarChar(50)
  nationalIdType String? @map("national_id_type") @db.VarChar(50)
  issuingCountry String? @map("issuing_country") @db.VarChar(2)

  // Demographics
  title             String?  @map("title") @db.VarChar(20)
  firstName         String   @map("first_name") @db.VarChar(100)
  lastName          String   @map("last_name") @db.VarChar(100)
  middleName        String?  @map("middle_name") @db.VarChar(100)
  displayName       String?  @map("display_name") @db.VarChar(255)
  dateOfBirth       DateTime @map("date_of_birth") @db.Date
  gender            String   @db.VarChar(10)
  maritalStatus     String?  @map("marital_status") @db.VarChar(20)
  nationality       String?  @map("nationality") @db.VarChar(100)
  preferredLanguage String?  @default("en") @map("preferred_language") @db.VarChar(10)

  // Contact
  phoneNumber String? @map("phone_number") @db.VarChar(20)
  email       String? @db.VarChar(255)

  // Address
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String? @db.VarChar(100)
  state        String? @db.VarChar(100)
  postalCode   String? @map("postal_code") @db.VarChar(20)
  country      String? @db.VarChar(2)

  // Medical
  bloodGroup       String? @map("blood_group") @db.VarChar(10)
  emergencyContact Json?   @map("emergency_contact")
  insuranceInfo    Json?   @map("insurance_info")

  // Registration Context
  createdBy          String  @map("created_by") @db.Uuid
  createdAtFacility  String  @map("created_at_facility") @db.Uuid
  registrationSource String  @default("manual") @map("registration_source") @db.VarChar(20)
  registrationNotes  String? @map("registration_notes") @db.Text

  // Update Context
  updatedBy         String? @map("updated_by") @db.Uuid
  updatedAtFacility String? @map("updated_at_facility") @db.Uuid

  // System
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  appointments      Appointment[]
  encounters        Encounter[]
  documents         PatientDocument[]
  history           PatientHistory[]
  consents          PatientConsent[]
  appointmentSeries AppointmentSeries[]

  @@index([tenantId, mrn], map: "idx_patients_tenant_mrn")
  @@index([tenantId, nationalId], map: "idx_patients_tenant_national_id")
  @@index([tenantId, firstName, lastName], map: "idx_patients_tenant_name")
  @@index([tenantId, nationalIdType, issuingCountry], map: "idx_patients_tenant_id_type_country")
  @@index([tenantId, createdBy], map: "idx_patients_tenant_created_by")
  @@index([tenantId, createdAtFacility], map: "idx_patients_tenant_created_facility")
  @@index([tenantId, registrationSource], map: "idx_patients_tenant_reg_source")
  @@map("patients")
}

model Appointment {
  id                 String                @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  patientId          String                @map("patient_id") @db.Uuid
  facilityId         String                @map("facility_id") @db.Uuid
  spaceId            String?               @map("space_id") @db.Uuid
  staffId            String?               @map("staff_id") @db.Uuid
  appointmentType    String                @map("appointment_type")
  status             String                @default("scheduled")
  startTime          DateTime              @map("start_time") @db.Timestamptz(6)
  endTime            DateTime              @map("end_time") @db.Timestamptz(6)
  duration           Int                   @default(30)
  notes              String?
  visitType          String?               @map("visit_type")
  linkedEncounterId  String?               @map("linked_encounter_id") @db.Uuid
  seriesId           String?               @map("series_id")
  cancellationReason String?               @map("cancellation_reason")
  rescheduleReason   String?               @map("reschedule_reason")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient            Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounters         Encounter[]
  resources          AppointmentResource[]

  @@index([tenantId, patientId], map: "idx_appointments_tenant_patient_id")
  @@index([tenantId, startTime], map: "idx_appointments_tenant_start_time")
  @@index([tenantId, status], map: "idx_appointments_tenant_status")
  @@index([tenantId, staffId], map: "idx_appointments_tenant_staff_id")
  @@index([tenantId, facilityId], map: "idx_appointments_tenant_facility_id")
  @@map("appointments")
}

model Encounter {
  id                   String       @id @default(uuid()) @map("id") @db.Uuid
  encounterNumber      String       @unique @map("encounter_number") @db.VarChar(50)
  tenantId             String       @map("tenant_id") @db.Uuid
  patientId            String       @map("patient_id") @db.Uuid
  facilityId           String       @map("facility_id") @db.Uuid
  appointmentId        String?      @map("appointment_id") @db.Uuid
  primaryStaffId       String       @map("primary_staff_id") @db.Uuid
  encounterClass       String       @default("AMB") @map("encounter_class")
  encounterType        String       @default("outpatient") @map("encounter_type") @db.VarChar(50)
  status               String       @default("planned")
  priority             String       @default("routine")
  startTime            DateTime     @map("start_time") @db.Timestamptz(6)
  endTime              DateTime?    @map("end_time") @db.Timestamptz(6)
  encounterSource      String       @default("appointment") @map("encounter_source")
  walkInDetails        Json?        @map("walk_in_details")
  chiefComplaint       String?      @map("chief_complaint")
  presentingSymptoms   String?      @map("presenting_symptoms")
  vitalSigns           Json?        @default("{}") @map("vital_signs")
  allergies            Json?        @default("[]")
  currentMedications   Json?        @default("[]") @map("current_medications")
  medicalHistory       String?      @map("medical_history")
  socialHistory        String?      @map("social_history")
  familyHistory        String?      @map("family_history")
  notes                String?
  dischargeDisposition String?      @map("discharge_disposition")
  followUpInstructions String?      @map("follow_up_instructions")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointment          Appointment? @relation(fields: [appointmentId], references: [id])
  patient              Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Relations to new clinical models
  encounterNotes     EncounterNote[]
  diagnoses          EncounterDiagnosis[]
  clinicalOrders     ClinicalOrder[]
  prescriptionOrders PrescriptionOrder[]
  aiNoteSuggestions  AiNoteSuggestion[]
  triage             Triage?
  inpatientAdmission InpatientAdmission?

  @@index([tenantId, patientId], map: "idx_encounters_tenant_patient_id")
  @@index([tenantId, startTime], map: "idx_encounters_tenant_start_time")
  @@index([tenantId, status], map: "idx_encounters_tenant_status")
  @@index([tenantId, patientId, primaryStaffId, startTime], map: "idx_encounters_patient_staff_date")
  @@map("encounters")
}

// ========================================
// TRIAGE MODEL
// ========================================

model Triage {
  id            String @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String @map("tenant_id") @db.Uuid
  encounterId   String @unique @map("encounter_id") @db.Uuid
  patientId     String @map("patient_id") @db.Uuid
  triageStaffId String @map("triage_staff_id") @db.Uuid

  // Triage Priority (Simple 1-5 scale)
  triageLevel Int @map("triage_level")

  // Clinical Assessment - Combined field
  chiefComplaintsAndHPI String @map("chief_complaints_and_hpi") @db.Text

  // Vital Signs (JSON - same structure as encounter vitals)
  vitalSigns Json @default("{}") @map("vital_signs")

  // Pain Assessment
  painScore Int? @map("pain_score")

  // Allergies & Medications
  allergies          Json @default("[]") @map("allergies")
  currentMedications Json @default("[]") @map("current_medications")

  // Triage Notes
  triageNotes String? @map("triage_notes") @db.Text

  // Timestamps
  triageTime DateTime @default(now()) @map("triage_time") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId], map: "idx_triage_encounter_id")
  @@index([tenantId, patientId], map: "idx_triage_tenant_patient_id")
  @@index([tenantId, triageLevel], map: "idx_triage_tenant_level")
  @@index([tenantId, triageTime], map: "idx_triage_tenant_time")
  @@map("triage")
}

// ========================================
// CLINICAL DOCUMENTATION MODELS
// ========================================

// Encounter Notes (Header - one per note type/language per encounter)
model EncounterNote {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Note Type & Language
  noteType String @map("note_type") @db.VarChar(50) // soap, h_and_p, progress, discharge, procedure, consultation
  language String @default("en") @map("language") @db.VarChar(2) // en, ar

  // Metadata
  title   String? @map("title") @db.VarChar(200)
  status  String  @default("draft") @map("status") @db.VarChar(20) // draft, final, amended, signed
  version Int     @default(1) @map("version")

  // Authorship & Signing
  authorStaffId String    @map("author_staff_id") @db.Uuid
  coSignStaffId String?   @map("co_sign_staff_id") @db.Uuid
  signedAt      DateTime? @map("signed_at") @db.Timestamptz(6)
  coSignedAt    DateTime? @map("co_signed_at") @db.Timestamptz(6)

  // Amendment tracking
  amendmentReason String? @map("amendment_reason") @db.Text
  supersededBy    String? @map("superseded_by") @db.Uuid // points to new version

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter              @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  sections  EncounterNoteSection[]

  @@index([tenantId, encounterId], map: "idx_encounter_notes_encounter")
  @@index([tenantId, patientId], map: "idx_encounter_notes_patient")
  @@index([tenantId, noteType, status], map: "idx_encounter_notes_type_status")
  @@index([tenantId, authorStaffId], map: "idx_encounter_notes_author")
  @@map("encounter_notes")
}

// Encounter Note Sections (Flexible JSONB sections)
model EncounterNoteSection {
  id     String @id @default(uuid()) @map("id") @db.Uuid
  noteId String @map("note_id") @db.Uuid

  // Section Identifier
  sectionCode String @map("section_code") @db.VarChar(50) // subjective, objective, assessment, plan, hpi, ros, physical_exam, etc.
  sectionName String @map("section_name") @db.VarChar(100)
  sortOrder   Int    @default(0) @map("sort_order")

  // Content (flexible JSONB for structured or free-text)
  content Json @map("content") // { "text": "...", "structured": {...} }

  // Metadata
  isEmpty   Boolean  @default(false) @map("is_empty")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounterNote EncounterNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, sortOrder], map: "idx_encounter_note_sections_note")
  @@map("encounter_note_sections")
}

// Encounter Diagnoses (ICD-10 codes)
model EncounterDiagnosis {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // ICD-10 Code
  icdCode    String @map("icd_code") @db.VarChar(20)
  icdVersion String @default("ICD-10") @map("icd_version") @db.VarChar(20)

  // Display Names (EN/AR from catalog)
  diagnosisName   String  @map("diagnosis_name") @db.VarChar(500)
  diagnosisNameAr String? @map("diagnosis_name_ar") @db.VarChar(500)

  // Diagnosis Classification
  diagnosisType String @map("diagnosis_type") @db.VarChar(50) // primary, secondary, rule_out, differential
  diagnosisRank Int?   @map("diagnosis_rank") // 1 = primary, 2+ = secondary

  // Clinical Context
  isPresentOnAdmission Boolean   @default(false) @map("is_present_on_admission")
  isChronic            Boolean   @default(false) @map("is_chronic")
  onsetDate            DateTime? @map("onset_date") @db.Date

  // Notes
  clinicalNotes String? @map("clinical_notes") @db.Text

  // Authorship
  diagnosedBy String   @map("diagnosed_by") @db.Uuid
  diagnosedAt DateTime @default(now()) @map("diagnosed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_encounter_dx_encounter")
  @@index([tenantId, patientId], map: "idx_encounter_dx_patient")
  @@index([tenantId, icdCode], map: "idx_encounter_dx_code")
  @@index([tenantId, diagnosisType], map: "idx_encounter_dx_type")
  @@map("encounter_diagnoses")
}

// Clinical Orders (Labs, Imaging, Procedures)
model ClinicalOrder {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Order Type & Code
  orderType  String @map("order_type") @db.VarChar(50) // lab, imaging, procedure
  orderCode  String @map("order_code") @db.VarChar(50) // LOINC, CPT, SNOMED
  codeSystem String @map("code_system") @db.VarChar(20) // LOINC, CPT

  // Display Names (EN/AR from catalog)
  orderName   String  @map("order_name") @db.VarChar(500)
  orderNameAr String? @map("order_name_ar") @db.VarChar(500)

  // Order Details
  priority String @default("routine") @map("priority") @db.VarChar(20) // stat, urgent, routine
  status   String @default("ordered") @map("status") @db.VarChar(20) // ordered, in_progress, completed, cancelled

  // Clinical Context
  clinicalIndication  String? @map("clinical_indication") @db.Text
  specialInstructions String? @map("special_instructions") @db.Text

  // Results (for labs/imaging)
  resultStatus String?   @map("result_status") @db.VarChar(20) // pending, preliminary, final, amended
  resultData   Json?     @map("result_data") // structured results
  resultNotes  String?   @map("result_notes") @db.Text
  resultedAt   DateTime? @map("resulted_at") @db.Timestamptz(6)

  // Authorship
  orderedBy   String    @map("ordered_by") @db.Uuid
  orderedAt   DateTime  @default(now()) @map("ordered_at") @db.Timestamptz(6)
  performedBy String?   @map("performed_by") @db.Uuid
  performedAt DateTime? @map("performed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_orders_encounter")
  @@index([tenantId, patientId], map: "idx_orders_patient")
  @@index([tenantId, orderType, status], map: "idx_orders_type_status")
  @@index([tenantId, orderCode], map: "idx_orders_code")
  @@map("clinical_orders")
}

// Prescription Orders (Medications)
model PrescriptionOrder {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Drug Code (NDC or local formulary)
  drugCode   String @map("drug_code") @db.VarChar(50)
  codeSystem String @default("NDC") @map("code_system") @db.VarChar(20) // NDC, RxNorm, local

  // Display Names (EN/AR from catalog)
  drugName    String  @map("drug_name") @db.VarChar(500)
  drugNameAr  String? @map("drug_name_ar") @db.VarChar(500)
  genericName String? @map("generic_name") @db.VarChar(500)

  // Prescription Details
  dosage    String  @map("dosage") @db.VarChar(100) // e.g., "500mg"
  route     String  @map("route") @db.VarChar(50) // oral, IV, topical, etc.
  frequency String  @map("frequency") @db.VarChar(100) // e.g., "twice daily"
  duration  String? @map("duration") @db.VarChar(100) // e.g., "7 days"
  quantity  String? @map("quantity") @db.VarChar(50)
  refills   Int     @default(0) @map("refills")

  // Instructions
  instructions   String? @map("instructions") @db.Text
  instructionsAr String? @map("instructions_ar") @db.Text

  // Status
  status String @default("active") @map("status") @db.VarChar(20) // active, completed, cancelled, discontinued

  // Authorship
  prescribedBy String   @map("prescribed_by") @db.Uuid
  prescribedAt DateTime @default(now()) @map("prescribed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_rx_encounter")
  @@index([tenantId, patientId], map: "idx_rx_patient")
  @@index([tenantId, drugCode], map: "idx_rx_drug_code")
  @@index([tenantId, status], map: "idx_rx_status")
  @@map("prescription_orders")
}

// AI Note Suggestions (For future AI integration)
model AiNoteSuggestion {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  // AI Model Info
  modelVersion   String @map("model_version") @db.VarChar(50)
  suggestionType String @map("suggestion_type") @db.VarChar(50) // note_draft, diagnosis, order, medication

  // Suggestion Content
  suggestedContent Json   @map("suggested_content")
  confidenceScore  Float? @map("confidence_score")

  // User Action
  status     String    @default("pending") @map("status") @db.VarChar(20) // pending, accepted, rejected, modified
  reviewedBy String?   @map("reviewed_by") @db.Uuid
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_ai_suggestions_encounter")
  @@index([tenantId, status], map: "idx_ai_suggestions_status")
  @@map("ai_note_suggestions")
}

model PatientDocument {
  id                 String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  documentType       String    @map("document_type") @db.VarChar(50)
  documentNumber     String    @map("document_number") @db.VarChar(100)
  issuingCountry     String    @map("issuing_country") @db.VarChar(2)
  issuingAuthority   String?   @map("issuing_authority") @db.VarChar(200)
  issueDate          DateTime? @map("issue_date") @db.Date
  expiryDate         DateTime? @map("expiry_date") @db.Date
  isPrimaryIdentity  Boolean   @default(false) @map("is_primary_identity")
  documentUrl        String?   @map("document_url") @db.Text
  verificationStatus String    @default("pending") @map("verification_status") @db.VarChar(20)
  verifiedBy         String?   @map("verified_by") @db.Uuid
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  verificationNotes  String?   @map("verification_notes") @db.Text
  metadata           Json?     @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId], map: "idx_patient_documents_tenant_patient")
  @@index([tenantId, documentType, documentNumber], map: "idx_patient_documents_tenant_type_number")
  @@index([tenantId, verificationStatus], map: "idx_patient_documents_tenant_verification")
  @@index([tenantId, isPrimaryIdentity], map: "idx_patient_documents_tenant_primary")
  @@map("patient_documents")
}

model PatientHistory {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // What changed
  fieldName  String  @map("field_name") @db.VarChar(100)
  oldValue   String? @map("old_value") @db.Text
  newValue   String? @map("new_value") @db.Text
  changeType String  @map("change_type") @db.VarChar(20)

  // Why changed
  changeReason     String? @map("change_reason") @db.Text
  supportingDocUrl String? @map("supporting_doc_url") @db.Text

  // Who changed
  changedBy  String  @map("changed_by") @db.Uuid
  approvedBy String? @map("approved_by") @db.Uuid

  // Where/When changed
  changedAtFacility String?  @map("changed_at_facility") @db.Uuid
  changedAt         DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  // Patient consent
  patientConsent Boolean @default(false) @map("patient_consent")
