  parentTemplate         LabTestResultTemplate?  @relation("LabTestResultTemplateHierarchy", fields: [parentTemplateId], references: [id], onDelete: Cascade)
  childTemplates         LabTestResultTemplate[] @relation("LabTestResultTemplateHierarchy")
  observationCodeCatalog ObservationCodeCatalog? @relation(fields: [observationCodeCatalogId], references: [id], onDelete: Cascade)

  @@unique([labTestMasterId, observationCodeCatalogId], map: "ux_lab_test_result_template_component")
  @@index([tenantId, labTestMasterId, isActive], map: "idx_lab_test_result_template_test")
  @@index([tenantId, parentTemplateId], map: "idx_lab_test_result_template_parent")
  @@index([tenantId, observationCodeCatalogId], map: "idx_lab_test_result_template_obs")
  @@map("lab_test_result_templates")
}

