  referenceMin Decimal? @map("reference_min") @db.Decimal(10, 4)
  referenceMax Decimal? @map("reference_max") @db.Decimal(10, 4)
  optimalMin   Decimal? @map("optimal_min") @db.Decimal(10, 4)
  optimalMax   Decimal? @map("optimal_max") @db.Decimal(10, 4)

  // Interpretation
  interpretation String?  @map("interpretation") @db.VarChar(20) // low, optimal, high, critical_low, critical_high
  percentile     Decimal? @map("percentile") @db.Decimal(5, 2)

