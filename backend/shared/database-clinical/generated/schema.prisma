generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider   = "postgresql"
  url        = env("CLINICAL_DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

// ============================================================================
// ENUMS - Inpatient Status Management
// ============================================================================

/// Clinical lifecycle status for inpatient admission
enum InpatientAdmissionStatus {
  ADMITTED // Admission created
  ACTIVE // Under care
  ON_LEAVE // Temporary leave
  DISCHARGE_PLANNING // Discharge planning in progress
  DISCHARGED // Patient discharged
  EXPIRED // Patient deceased
  ABSCONDED // Patient left without authorization
  CANCELLED // Admission cancelled before bed occupied
}

/// Discharge workflow status
enum InpatientDischargeStatus {
  NONE // No discharge planning
  FIT_FOR_DISCHARGE // Medically fit for discharge
  INITIATED // Discharge process initiated
  READY // Summary, meds, bill, transport completed
  CONFIRMED // Final discharge confirmation done
}

/// Clinical acuity level for monitoring and prioritization
enum InpatientAcuity {
  STABLE // Stable condition
  WATCH // Requires monitoring
  CRITICAL // Critical condition
}

/// Event types for inpatient audit trail
enum InpatientEventType {
  ADMISSION_CREATED
  STATUS_CHANGED
  DISCHARGE_STATUS_CHANGED
  BED_ASSIGNED
  BED_RELEASED
  TRANSFERRED
  FLAG_ADDED
  FLAG_REMOVED
  ACUITY_CHANGED
  NOTE_ADDED
  DISCHARGE_CONFIRMED
}

// ============================================================================
// ENUMS - Care Channel Communication
// ============================================================================

/// Care channel status
enum ChannelStatus {
  ACTIVE // Admission active, channel open
  CLOSED // Admission discharged/cancelled
  ARCHIVED // Historical data, read-only
}

/// Care team member roles
enum CareTeamRole {
  ATTENDING_PHYSICIAN // Primary responsible physician
  RESIDENT_PHYSICIAN // Resident doctor
  CONSULTING_PHYSICIAN // Specialist consultant
  PRIMARY_NURSE // Primary assigned nurse
  CHARGE_NURSE // Shift supervisor
  STAFF_NURSE // General nursing staff
  PHARMACIST // Clinical pharmacist
  CASE_MANAGER // Discharge planner/social worker
  RESPIRATORY_THERAPIST // RT specialist
  PHYSICAL_THERAPIST // PT specialist
  DIETITIAN // Nutritionist
  OTHER // Catch-all for other roles
}

/// Message types in care channel
enum MessageType {
  TEXT // Human chat message
  SYSTEM // System notification (generic)
  CLINICAL_EVENT // Clinical transaction event (order, med, procedure)
  CHECKLIST // Interactive checklist message
  TASK // Task assignment or reminder (future)
  ALERT // High-priority alert (future)
  ATTACHMENT // File attachment reference (future)
}

/// Message visibility levels
enum MessageVisibility {
  CARE_TEAM // All care team members (MVP default)
  NURSING_ONLY // Nurses only (Phase 2)
  DOCTORS_ONLY // Physicians only (Phase 2)
}

/// Message priority levels
enum MessagePriority {
  NORMAL
  HIGH
  URGENT
}

// ============================================================================
// ENUMS - Generic Checklist System
// ============================================================================

/// Checklist template categories
enum ChecklistCategory {
  DISCHARGE // Patient discharge planning
  SURGERY // Surgical procedures
  PRE_OPERATIVE // Pre-op assessment
  POST_OPERATIVE // Post-op recovery
  ADMISSION // Admission intake
  TRANSFER // Inter-facility transfer
  OUTPATIENT_VISIT // Outpatient appointment
  PROCEDURE // General procedures
  EMERGENCY // Emergency department
  ANESTHESIA // Anesthesia checklist
  INFECTION_CONTROL // Infection prevention
  FALL_PREVENTION // Fall risk assessment
  PAIN_MANAGEMENT // Pain assessment
  WOUND_CARE // Wound management
  CUSTOM // Tenant-defined custom type
}

/// Status of checklist template
enum ChecklistTemplateStatus {
  DRAFT // Being created/edited
  ACTIVE // Available for use
  DEPRECATED // Old version, no longer recommended
  ARCHIVED // No longer in use
}

/// Field type for checklist items
enum ChecklistItemType {
  BOOLEAN // Yes/No checkbox
  TEXT // Free text input
  TEXT_AREA // Multi-line text
  DATE // Date picker
  DATETIME // Date + time picker
  TIME // Time picker
  NUMBER // Numeric input
  SELECT_SINGLE // Dropdown (single choice)
  SELECT_MULTIPLE // Multi-select dropdown
  STAFF_SELECTOR // Choose a staff member
  SECTION_HEADER // Just a header/divider
  FILE_UPLOAD // Attach document/image
}

/// Status of checklist instance
enum ChecklistInstanceStatus {
  NOT_STARTED // Created but not yet filled
  IN_PROGRESS // Partially completed
  COMPLETED // All required items filled
  VERIFIED // Reviewed and verified by supervisor
  CANCELLED // Checklist cancelled/voided
}

/// Context where checklist is being used
enum ChecklistContext {
  INPATIENT_ADMISSION // Linked to inpatient admission
  OUTPATIENT_ENCOUNTER // Linked to outpatient encounter
  STANDALONE // Not linked to specific encounter
  CARE_CHANNEL // Part of care channel workflow
}

// ============================================================================
// ENUMS - Discharge Transaction
// ============================================================================

/// Discharge transaction status (separate from admission discharge status)
enum DischargeTransactionStatus {
  PLANNING // Discharge planning initiated
  READY // Checklist verified, medically ready
  APPROVED // Final approval given (if required)
  EXECUTED // Patient discharged
  CANCELLED // Discharge cancelled/postponed
}

/// Type of discharge
enum DischargeType {
  ROUTINE // Normal discharge
  AGAINST_MEDICAL_ADVICE // Patient left AMA
  TRANSFER_ACUTE_CARE // Transfer to another acute care facility
  TRANSFER_SNF // Transfer to skilled nursing facility
  TRANSFER_REHABILITATION // Transfer to rehabilitation facility
  EXPIRED // Patient deceased
  ELOPED // Patient left without notification
  LEFT_WITHOUT_BEING_SEEN // Patient left before being seen
}

/// Discharge destination
enum DischargeDestination {
  HOME // Home without services
  HOME_WITH_HOME_HEALTH // Home with home health services
  SKILLED_NURSING_FACILITY // SNF/Nursing home
  ACUTE_CARE_HOSPITAL // Another acute care hospital
  REHABILITATION_FACILITY // Inpatient rehab facility
  HOSPICE_HOME // Hospice at home
  HOSPICE_FACILITY // Hospice facility
  PSYCHIATRIC_FACILITY // Psychiatric hospital
  DECEASED // Expired in hospital
  OTHER // Other destination
}

/// Discharge summary status (versioned clinical document lifecycle)
enum DischargeSummaryStatus {
  DRAFT
  IN_REVIEW
  FINAL
  SIGNED
  VOID
}

/// Note template type/category
enum NoteTemplateType {
  GENERAL // General clinical note
  SOAP // SOAP note (Subjective, Objective, Assessment, Plan)
  DISCHARGE_SUMMARY // Discharge summary
  PROGRESS_NOTE // Progress note
  ADMISSION_NOTE // Admission note
  CONSULTATION // Consultation note
  OPERATIVE_NOTE // Operative/Surgical note
  PROCEDURE_NOTE // Procedure note
  PHYSICAL_THERAPY // Physical therapy note
  OCCUPATIONAL_THERAPY // Occupational therapy note
  NURSING_NOTE // Nursing note
  PSYCHIATRIC_EVALUATION // Psychiatric evaluation
  EMERGENCY_DEPARTMENT // Emergency department note
  FOLLOW_UP // Follow-up visit note
  TRANSFER_NOTE // Transfer note
  DEATH_NOTE // Death/Expiry note
  OTHER // Other note types
}

// ============================================================================
// ENUMS - OT MODULE
// ============================================================================

enum OTRequestPriority {
  ELECTIVE
  URGENT
  EMERGENCY
}

enum OTRequestStatus {
  DRAFT
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum OTScheduleStatus {
  PLANNED
  CONFIRMED
  PATIENT_READY
  PATIENT_IN_OT
  ANAESTHESIA_STARTED
  SURGERY_STARTED
  SURGERY_COMPLETED
  PATIENT_SHIFTED_TO_RECOVERY
  CANCELLED
  POSTPONED
}

enum OTTeamRole {
  PRIMARY_SURGEON
  ASSISTANT_SURGEON
  ANAESTHETIST
  SCRUB_NURSE
  CIRCULATING_NURSE
  OT_TECHNICIAN
  PERFUSIONIST
  RADIOLOGY_TECHNICIAN
}

enum OTReportStatus {
  DRAFT
  SIGNED
  AMENDED
  CANCELLED
}

// ============================================================================
// MODELS - Generic Checklist System
// ============================================================================

/// Checklist template master (reusable definition)
model ChecklistTemplate {
  id         String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  facilityId String? @map("facility_id") @db.Uuid

  // Template identification
  code        String                  @map("code") @db.VarChar(50)
  name        String                  @map("name") @db.VarChar(255)
  description String?                 @map("description") @db.Text
  category    ChecklistCategory       @map("category")
  version     Int                     @default(1) @map("version")
  status      ChecklistTemplateStatus @default(DRAFT) @map("status")

  // Applicability rules
  applicableToInpatient    Boolean  @default(true) @map("applicable_to_inpatient")
  applicableToOutpatient   Boolean  @default(false) @map("applicable_to_outpatient")
  applicableEncounterTypes String[] @default([]) @map("applicable_encounter_types")
  applicableDepartments    String[] @default([]) @map("applicable_departments")

  // Completion rules
  requiresAllItems         Boolean @default(false) @map("requires_all_items")
  minimumCompletionPercent Int?    @map("minimum_completion_percent")

  // Approval workflow (configurable)
  requiresVerification  Boolean  @default(false) @map("requires_verification")
  verificationRoles     String[] @default([]) @map("verification_roles")
  allowSelfVerification Boolean  @default(false) @map("allow_self_verification")

  // Auto-creation rules (configurable)
  autoCreateEnabled    Boolean  @default(false) @map("auto_create_enabled")
  autoCreateOn         String[] @default([]) @map("auto_create_on")
  autoCreateConditions Json?    @map("auto_create_conditions") @db.JsonB
  autoCreateDueHours   Int?     @map("auto_create_due_hours")

  // Permissions
  allowedRoles String[] @default([]) @map("allowed_roles")

  // Metadata
  estimatedMinutes Int? @map("estimated_minutes")

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  items     ChecklistTemplateItem[]
  instances ChecklistInstance[]

  @@unique([tenantId, code, version], map: "unique_template_code_version")
  @@index([tenantId, status], map: "idx_template_tenant_status")
  @@index([tenantId, category], map: "idx_template_tenant_category")
  @@map("checklist_template")
}

/// Individual items/fields in a checklist template
model ChecklistTemplateItem {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  templateId String @map("template_id") @db.Uuid

  // Item definition
  itemKey     String            @map("item_key") @db.VarChar(100)
  itemType    ChecklistItemType @map("item_type")
  label       String            @map("label") @db.VarChar(255)
  helpText    String?           @map("help_text") @db.Text
  placeholder String?           @map("placeholder") @db.VarChar(255)

  // Ordering
  sectionName String? @map("section_name") @db.VarChar(100)
  sortOrder   Int     @map("sort_order")

  // Validation
  isRequired      Boolean @default(false) @map("is_required")
  validationRules Json?   @map("validation_rules") @db.JsonB

  // Options (for SELECT_SINGLE, SELECT_MULTIPLE)
  options Json? @map("options") @db.JsonB

  // Conditional display
  showIfCondition Json? @map("show_if_condition") @db.JsonB

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  template  ChecklistTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses ChecklistInstanceResponse[]

  @@unique([templateId, itemKey], map: "unique_template_item_key")
  @@index([tenantId, templateId], map: "idx_item_tenant_template")
  @@map("checklist_template_item")
}

/// Runtime instance of a checklist being filled
model ChecklistInstance {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  facilityId String @map("facility_id") @db.Uuid
  templateId String @map("template_id") @db.Uuid

  // Context links
  patientId        String           @map("patient_id") @db.Uuid
  encounterId      String?          @map("encounter_id") @db.Uuid
  admissionId      String?          @map("admission_id") @db.Uuid
  careChannelId    String?          @map("care_channel_id") @db.Uuid
  channelMessageId String?          @unique @map("channel_message_id") @db.Uuid
  context          ChecklistContext @map("context")

  // Status
  status            ChecklistInstanceStatus @default(NOT_STARTED) @map("status")
  completionPercent Int                     @default(0) @map("completion_percent")

  // Timing
  dueAt       DateTime? @map("due_at") @db.Timestamptz(6)
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz(6)

  // Ownership
  completedBy String? @map("completed_by") @db.Uuid
  verifiedBy  String? @map("verified_by") @db.Uuid

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid

  // Relations
  template       ChecklistTemplate           @relation(fields: [templateId], references: [id])
  admission      InpatientAdmission?         @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  careChannel    CareChannel?                @relation(fields: [careChannelId], references: [id], onDelete: Cascade)
  channelMessage ChannelMessage?             @relation(fields: [channelMessageId], references: [id])
  discharge      InpatientDischarge? // Reverse relation from InpatientDischarge
  responses      ChecklistInstanceResponse[]

  @@index([tenantId, admissionId], map: "idx_instance_tenant_admission")
  @@index([tenantId, careChannelId], map: "idx_instance_tenant_channel")
  @@index([tenantId, patientId], map: "idx_instance_tenant_patient")
  @@index([tenantId, status], map: "idx_instance_tenant_status")
  @@index([tenantId, dueAt], map: "idx_instance_tenant_due")
  @@map("checklist_instance")
}

/// Individual responses to checklist items
model ChecklistInstanceResponse {
  id             String @id @default(uuid()) @map("id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  instanceId     String @map("instance_id") @db.Uuid
  templateItemId String @map("template_item_id") @db.Uuid

  // Response value (polymorphic storage)
  valueBoolean  Boolean?  @map("value_boolean")
  valueText     String?   @map("value_text") @db.Text
  valueNumber   Float?    @map("value_number")
  valueDate     DateTime? @map("value_date") @db.Date
  valueDatetime DateTime? @map("value_datetime") @db.Timestamptz(6)
  valueTime     String?   @map("value_time") @db.VarChar(8)
  valueJson     Json?     @map("value_json") @db.JsonB

  // Metadata
  answeredBy String?   @map("answered_by") @db.Uuid
  answeredAt DateTime? @map("answered_at") @db.Timestamptz(6)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  instance     ChecklistInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])

  @@unique([instanceId, templateItemId], map: "unique_instance_item_response")
  @@index([tenantId, instanceId], map: "idx_response_tenant_instance")
  @@map("checklist_instance_response")
}

model Patient {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  mrn      String @unique @map("mrn") @db.VarChar(50)
  tenantId String @map("tenant_id") @db.Uuid

  // Identity
  nationalId     String? @map("national_id") @db.VarChar(50)
  nationalIdType String? @map("national_id_type") @db.VarChar(50)
  issuingCountry String? @map("issuing_country") @db.VarChar(2)

  // Demographics
  title             String?  @map("title") @db.VarChar(20)
  firstName         String   @map("first_name") @db.VarChar(100)
  lastName          String   @map("last_name") @db.VarChar(100)
  middleName        String?  @map("middle_name") @db.VarChar(100)
  displayName       String?  @map("display_name") @db.VarChar(255)
  dateOfBirth       DateTime @map("date_of_birth") @db.Date
  gender            String   @db.VarChar(10)
  maritalStatus     String?  @map("marital_status") @db.VarChar(20)
  nationality       String?  @map("nationality") @db.VarChar(100)
  preferredLanguage String?  @default("en") @map("preferred_language") @db.VarChar(10)

  // Contact
  phoneNumber String? @map("phone_number") @db.VarChar(20)
  email       String? @db.VarChar(255)

  // Address
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String? @db.VarChar(100)
  state        String? @db.VarChar(100)
  postalCode   String? @map("postal_code") @db.VarChar(20)
  country      String? @db.VarChar(2)

  // Medical
  bloodGroup       String? @map("blood_group") @db.VarChar(10)
  emergencyContact Json?   @map("emergency_contact")
  insuranceInfo    Json?   @map("insurance_info")

  // Registration Context
  createdBy          String  @map("created_by") @db.Uuid
  createdAtFacility  String  @map("created_at_facility") @db.Uuid
  registrationSource String  @default("manual") @map("registration_source") @db.VarChar(20)
  registrationNotes  String? @map("registration_notes") @db.Text

  // Update Context
  updatedBy         String? @map("updated_by") @db.Uuid
  updatedAtFacility String? @map("updated_at_facility") @db.Uuid

  // System
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  appointments        Appointment[]
  encounters          Encounter[]
  inpatientAdmissions InpatientAdmission[]
  documents           PatientDocument[]
  history             PatientHistory[]
  consents            PatientConsent[]
  appointmentSeries   AppointmentSeries[]

  // Wellness & Longevity Relations
  wellnessAssessments     WellnessAssessment[]
  biomarkerResults        BiomarkerResult[]
  biomarkerAlerts         BiomarkerAlert[]
  programEnrollments      WellnessProgramEnrollment[]
  longevityTreatments     LongevityTreatment[]
  screeningSchedules      PatientScreeningSchedule[]
  nutritionPlans          NutritionPlan[]
  exercisePrescriptions   ExercisePrescription[]
  deviceConnections       PatientDeviceConnection[]
  deviceHealthMetrics     DeviceHealthMetric[]
  membershipSubscriptions MembershipSubscription[]
  clinicalObservations    ClinicalObservation[]
  clinicalCodings         EncounterClinicalCoding[]

  @@index([tenantId, mrn], map: "idx_patients_tenant_mrn")
  @@index([tenantId, nationalId], map: "idx_patients_tenant_national_id")
  @@index([tenantId, firstName, lastName], map: "idx_patients_tenant_name")
  @@index([tenantId, nationalIdType, issuingCountry], map: "idx_patients_tenant_id_type_country")
  @@index([tenantId, createdBy], map: "idx_patients_tenant_created_by")
  @@index([tenantId, createdAtFacility], map: "idx_patients_tenant_created_facility")
  @@index([tenantId, registrationSource], map: "idx_patients_tenant_reg_source")
  @@map("patients")
}

model Appointment {
  id                 String                @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  patientId          String                @map("patient_id") @db.Uuid
  facilityId         String                @map("facility_id") @db.Uuid
  spaceId            String?               @map("space_id") @db.Uuid
  staffId            String?               @map("staff_id") @db.Uuid
  staffDisplayName   String?               @map("staff_display_name") @db.VarChar(255)
  appointmentType    String                @map("appointment_type")
  status             String                @default("scheduled")
  startTime          DateTime              @map("start_time") @db.Timestamptz(6)
  endTime            DateTime              @map("end_time") @db.Timestamptz(6)
  duration           Int                   @default(30)
  notes              String?
  visitType          String?               @map("visit_type")
  linkedEncounterId  String?               @map("linked_encounter_id") @db.Uuid
  seriesId           String?               @map("series_id")
  cancellationReason String?               @map("cancellation_reason")
  rescheduleReason   String?               @map("reschedule_reason")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient            Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounters         Encounter[]
  resources          AppointmentResource[]

  @@index([tenantId, patientId], map: "idx_appointments_tenant_patient_id")
  @@index([tenantId, startTime], map: "idx_appointments_tenant_start_time")
  @@index([tenantId, status], map: "idx_appointments_tenant_status")
  @@index([tenantId, staffId], map: "idx_appointments_tenant_staff_id")
  @@index([tenantId, facilityId], map: "idx_appointments_tenant_facility_id")
  @@map("appointments")
}

model Encounter {
  id                   String       @id @default(uuid()) @map("id") @db.Uuid
  encounterNumber      String       @unique @map("encounter_number") @db.VarChar(50)
  tenantId             String       @map("tenant_id") @db.Uuid
  patientId            String       @map("patient_id") @db.Uuid
  facilityId           String       @map("facility_id") @db.Uuid
  facilityName         String?      @map("facility_name") @db.VarChar(200) // Denormalized for search
  departmentId         String?      @map("department_id") @db.Uuid
  departmentName       String?      @map("department_name") @db.VarChar(200) // Denormalized for search
  appointmentId        String?      @map("appointment_id") @db.Uuid
  primaryStaffId       String       @map("primary_staff_id") @db.Uuid
  encounterClass       String       @default("AMB") @map("encounter_class")
  encounterType        String       @default("outpatient") @map("encounter_type") @db.VarChar(50)
  status               String       @default("planned")
  priority             String       @default("routine")
  startTime            DateTime     @map("start_time") @db.Timestamptz(6)
  endTime              DateTime?    @map("end_time") @db.Timestamptz(6)
  encounterSource      String       @default("appointment") @map("encounter_source")
  walkInDetails        Json?        @map("walk_in_details")
  chiefComplaint       String?      @map("chief_complaint")
  presentingSymptoms   String?      @map("presenting_symptoms")
  vitalSigns           Json?        @default("{}") @map("vital_signs")
  allergies            Json?        @default("[]")
  currentMedications   Json?        @default("[]") @map("current_medications")
  medicalHistory       String?      @map("medical_history")
  socialHistory        String?      @map("social_history")
  familyHistory        String?      @map("family_history")
  notes                String?
  dischargeDisposition String?      @map("discharge_disposition")
  followUpInstructions String?      @map("follow_up_instructions")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointment          Appointment? @relation(fields: [appointmentId], references: [id])
  patient              Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Relations to new clinical models
  encounterNotes       EncounterNote[]
  diagnoses            EncounterDiagnosis[]
  clinicalOrders       ClinicalOrder[]
  packageOrders        PackageOrder[]
  prescriptionOrders   PrescriptionOrder[]
  prescriptions        Prescription[]
  aiNoteSuggestions    AiNoteSuggestion[]
  clinicalObservations ClinicalObservation[]
  clinicalCodings      EncounterClinicalCoding[]
  labReports           LabReport[]
  pathologyReports     PathologyReport[]
  imagingReports       ImagingReport[]
  procedureReports     ProcedureReport[]
  triage               Triage?
  inpatientAdmission   InpatientAdmission?

  @@index([tenantId, patientId], map: "idx_encounters_tenant_patient_id")
  @@index([tenantId, startTime], map: "idx_encounters_tenant_start_time")
  @@index([tenantId, status], map: "idx_encounters_tenant_status")
  @@index([tenantId, patientId, primaryStaffId, startTime], map: "idx_encounters_patient_staff_date")
  @@map("encounters")
}

// ========================================
// TRIAGE MODEL
// ========================================

model Triage {
  id            String @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String @map("tenant_id") @db.Uuid
  encounterId   String @unique @map("encounter_id") @db.Uuid
  patientId     String @map("patient_id") @db.Uuid
  triageStaffId String @map("triage_staff_id") @db.Uuid

  // Triage Priority (Simple 1-5 scale)
  triageLevel Int @map("triage_level")

  // Clinical Assessment - Combined field
  chiefComplaintsAndHPI String @map("chief_complaints_and_hpi") @db.Text

  // Vital Signs (JSON - same structure as encounter vitals)
  vitalSigns Json @default("{}") @map("vital_signs")

  // Pain Assessment
  painScore Int? @map("pain_score")

  // Allergies & Medications
  allergies          Json @default("[]") @map("allergies")
  currentMedications Json @default("[]") @map("current_medications")

  // Triage Notes
  triageNotes String? @map("triage_notes") @db.Text

  // Timestamps
  triageTime DateTime @default(now()) @map("triage_time") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId], map: "idx_triage_encounter_id")
  @@index([tenantId, patientId], map: "idx_triage_tenant_patient_id")
  @@index([tenantId, triageLevel], map: "idx_triage_tenant_level")
  @@index([tenantId, triageTime], map: "idx_triage_tenant_time")
  @@map("triage")
}

// ========================================
// CLINICAL DOCUMENTATION MODELS
// ========================================

// Encounter Notes (Header - one per note type/language per encounter)
model EncounterNote {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Note Type & Language
  noteType String @map("note_type") @db.VarChar(50) // soap, h_and_p, progress, discharge, procedure, consultation
  language String @default("en") @map("language") @db.VarChar(2) // en, ar

  // Metadata
  title   String? @map("title") @db.VarChar(200)
  status  String  @default("draft") @map("status") @db.VarChar(20) // draft, final, amended, signed
  version Int     @default(1) @map("version")

  // Authorship & Signing
  authorStaffId     String    @map("author_staff_id") @db.Uuid
  authorDisplayName String?   @map("author_display_name") @db.VarChar(200) // Denormalized for search
  coSignStaffId     String?   @map("co_sign_staff_id") @db.Uuid
  signedAt          DateTime? @map("signed_at") @db.Timestamptz(6)
  coSignedAt        DateTime? @map("co_signed_at") @db.Timestamptz(6)

  // Amendment tracking
  amendmentReason String? @map("amendment_reason") @db.Text
  supersededBy    String? @map("superseded_by") @db.Uuid // points to new version

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Content (flexible JSONB for all note data)
  content Json? @map("content") @db.JsonB // { noteType, version, tiptapJson?, blocks?, sections? }

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_encounter_notes_encounter")
  @@index([tenantId, patientId], map: "idx_encounter_notes_patient")
  @@index([tenantId, noteType, status], map: "idx_encounter_notes_type_status")
  @@index([tenantId, authorStaffId], map: "idx_encounter_notes_author")
  @@map("encounter_notes")
}

// Encounter Diagnoses (ICD-10 codes)
model EncounterDiagnosis {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // ICD-10 Code
  icdCode    String @map("icd_code") @db.VarChar(20)
  icdVersion String @default("ICD-10") @map("icd_version") @db.VarChar(20)

  // Display Names (EN/AR from catalog)
  diagnosisName   String  @map("diagnosis_name") @db.VarChar(500)
  diagnosisNameAr String? @map("diagnosis_name_ar") @db.VarChar(500)

  // Diagnosis Classification
  diagnosisType String @map("diagnosis_type") @db.VarChar(50) // primary, secondary, rule_out, differential
  diagnosisRank Int?   @map("diagnosis_rank") // 1 = primary, 2+ = secondary

  // Clinical Context
  isPresentOnAdmission Boolean   @default(false) @map("is_present_on_admission")
  isChronic            Boolean   @default(false) @map("is_chronic")
  onsetDate            DateTime? @map("onset_date") @db.Date

  // Notes
  clinicalNotes String? @map("clinical_notes") @db.Text

  // Authorship
  diagnosedBy String   @map("diagnosed_by") @db.Uuid
  diagnosedAt DateTime @default(now()) @map("diagnosed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_encounter_dx_encounter")
  @@index([tenantId, patientId], map: "idx_encounter_dx_patient")
  @@index([tenantId, icdCode], map: "idx_encounter_dx_code")
  @@index([tenantId, diagnosisType], map: "idx_encounter_dx_type")
  @@map("encounter_diagnoses")
}

// Clinical Orders (Labs, Imaging, Procedures)
model ClinicalOrder {
  id             String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  encounterId    String  @map("encounter_id") @db.Uuid
  patientId      String  @map("patient_id") @db.Uuid
  packageOrderId String? @map("package_order_id") @db.Uuid

  // Order Type & Code
  orderType  String @map("order_type") @db.VarChar(50) // lab, imaging, procedure
  orderCode  String @map("order_code") @db.VarChar(50) // LOINC, CPT, SNOMED
  codeSystem String @map("code_system") @db.VarChar(20) // LOINC, CPT

  // Display Names (EN/AR from catalog)
  orderName   String  @map("order_name") @db.VarChar(500)
  orderNameAr String? @map("order_name_ar") @db.VarChar(500)

  // Order Details
  priority String @default("routine") @map("priority") @db.VarChar(20) // stat, urgent, routine
  status   String @default("ordered") @map("status") @db.VarChar(20) // ordered, in_progress, completed, cancelled

  // Clinical Context
  clinicalIndication  String? @map("clinical_indication") @db.Text
  specialInstructions String? @map("special_instructions") @db.Text

  // Results (for labs/imaging)
  resultStatus String?   @map("result_status") @db.VarChar(20) // pending, preliminary, final, amended
  resultData   Json?     @map("result_data") // structured results
  resultNotes  String?   @map("result_notes") @db.Text
  resultedAt   DateTime? @map("resulted_at") @db.Timestamptz(6)

  // Authorship
  orderedBy   String    @map("ordered_by") @db.Uuid
  orderedAt   DateTime  @default(now()) @map("ordered_at") @db.Timestamptz(6)
  performedBy String?   @map("performed_by") @db.Uuid
  performedAt DateTime? @map("performed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter             Encounter              @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  packageOrder          PackageOrder?          @relation(fields: [packageOrderId], references: [id], onDelete: SetNull)
  labOrderTests         LabOrderTest[]
  labSpecimens          LabSpecimen[]
  imagingOrderDetails   ImagingOrderDetail[]
  procedureOrderDetails ProcedureOrderDetail[]
  labReports            LabReport[]
  pathologyReports      PathologyReport[]
  imagingReports        ImagingReport[]
  procedureReports      ProcedureReport[]

  @@index([tenantId, encounterId], map: "idx_orders_encounter")
  @@index([tenantId, patientId], map: "idx_orders_patient")
  @@index([tenantId, packageOrderId], map: "idx_orders_package_order")
  @@index([tenantId, orderType, status], map: "idx_orders_type_status")
  @@index([tenantId, orderCode], map: "idx_orders_code")
  @@map("clinical_orders")
}

// Prescription Header (groups multiple drug lines into one clinical document)
model Prescription {
  id                 String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  prescriptionNumber String  @map("prescription_number") @db.VarChar(50) // e.g. RX-202604-00001
  version            Int     @default(1) @map("version")
  parentId           String? @map("parent_id") @db.Uuid // set on amendments

  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // active | completed | cancelled | amended
  status String @default("active") @map("status") @db.VarChar(20)

  prescribedBy     String   @map("prescribed_by") @db.Uuid
  prescribedByName String?  @map("prescribed_by_name") @db.VarChar(255) // denormalized display name
  prescribedAt     DateTime @default(now()) @map("prescribed_at") @db.Timestamptz(6)
  notes            String?  @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter  Encounter           @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  orders     PrescriptionOrder[]
  parent     Prescription?       @relation("PrescriptionAmendments", fields: [parentId], references: [id])
  amendments Prescription[]      @relation("PrescriptionAmendments")

  @@unique([tenantId, prescriptionNumber], map: "ux_prescription_number")
  @@index([tenantId, encounterId], map: "idx_prescription_encounter")
  @@index([tenantId, patientId], map: "idx_prescription_patient")
  @@index([tenantId, status], map: "idx_prescription_status")
  @@map("prescriptions")
}

// Prescription Orders (Medications — line items under a Prescription header)
model PrescriptionOrder {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Drug Code (NDC or local formulary)
  drugCode   String @map("drug_code") @db.VarChar(50)
  codeSystem String @default("NDC") @map("code_system") @db.VarChar(20) // NDC, RxNorm, local

  // Display Names (EN/AR from catalog)
  drugName    String  @map("drug_name") @db.VarChar(500)
  drugNameAr  String? @map("drug_name_ar") @db.VarChar(500)
  genericName String? @map("generic_name") @db.VarChar(500)

  // Prescription Details
  dosage    String  @map("dosage") @db.VarChar(100) // e.g., "500mg"
  route     String  @map("route") @db.VarChar(50) // oral, IV, topical, etc.
  frequency String  @map("frequency") @db.VarChar(100) // e.g., "twice daily"
  duration  String? @map("duration") @db.VarChar(100) // e.g., "7 days"
  quantity  String? @map("quantity") @db.VarChar(50)
  refills   Int     @default(0) @map("refills")

  // Instructions
  instructions   String? @map("instructions") @db.Text
  instructionsAr String? @map("instructions_ar") @db.Text

  // Status
  status String @default("active") @map("status") @db.VarChar(20) // active, completed, cancelled, discontinued

  // Link to Prescription header (nullable for legacy rows)
  prescriptionId String? @map("prescription_id") @db.Uuid

  // Authorship
  prescribedBy String   @map("prescribed_by") @db.Uuid
  prescribedAt DateTime @default(now()) @map("prescribed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  encounter    Encounter     @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])

  @@index([tenantId, encounterId], map: "idx_rx_encounter")
  @@index([tenantId, patientId], map: "idx_rx_patient")
  @@index([tenantId, drugCode], map: "idx_rx_drug_code")
  @@index([tenantId, status], map: "idx_rx_status")
  @@index([tenantId, prescriptionId], map: "idx_rx_prescription")
  @@map("prescription_orders")
}

// AI Note Suggestions (For future AI integration)
model AiNoteSuggestion {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  // AI Model Info
  modelVersion   String @map("model_version") @db.VarChar(50)
  suggestionType String @map("suggestion_type") @db.VarChar(50) // note_draft, diagnosis, order, medication

  // Suggestion Content
  suggestedContent Json   @map("suggested_content")
  confidenceScore  Float? @map("confidence_score")

  // User Action
  status     String    @default("pending") @map("status") @db.VarChar(20) // pending, accepted, rejected, modified
  reviewedBy String?   @map("reviewed_by") @db.Uuid
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId], map: "idx_ai_suggestions_encounter")
  @@index([tenantId, status], map: "idx_ai_suggestions_status")
  @@map("ai_note_suggestions")
}

model PatientDocument {
  id                 String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  documentType       String    @map("document_type") @db.VarChar(50)
  documentNumber     String    @map("document_number") @db.VarChar(100)
  issuingCountry     String    @map("issuing_country") @db.VarChar(2)
  issuingAuthority   String?   @map("issuing_authority") @db.VarChar(200)
  issueDate          DateTime? @map("issue_date") @db.Date
  expiryDate         DateTime? @map("expiry_date") @db.Date
  isPrimaryIdentity  Boolean   @default(false) @map("is_primary_identity")
  documentUrl        String?   @map("document_url") @db.Text
  verificationStatus String    @default("pending") @map("verification_status") @db.VarChar(20)
  verifiedBy         String?   @map("verified_by") @db.Uuid
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  verificationNotes  String?   @map("verification_notes") @db.Text
  metadata           Json?     @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId], map: "idx_patient_documents_tenant_patient")
  @@index([tenantId, documentType, documentNumber], map: "idx_patient_documents_tenant_type_number")
  @@index([tenantId, verificationStatus], map: "idx_patient_documents_tenant_verification")
  @@index([tenantId, isPrimaryIdentity], map: "idx_patient_documents_tenant_primary")
  @@map("patient_documents")
}

model PatientHistory {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // What changed
  fieldName  String  @map("field_name") @db.VarChar(100)
  oldValue   String? @map("old_value") @db.Text
  newValue   String? @map("new_value") @db.Text
  changeType String  @map("change_type") @db.VarChar(20)

  // Why changed
  changeReason     String? @map("change_reason") @db.Text
  supportingDocUrl String? @map("supporting_doc_url") @db.Text

  // Who changed
  changedBy  String  @map("changed_by") @db.Uuid
  approvedBy String? @map("approved_by") @db.Uuid

  // Where/When changed
  changedAtFacility String?  @map("changed_at_facility") @db.Uuid
  changedAt         DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  // Patient consent
  patientConsent Boolean @default(false) @map("patient_consent")
  consentDocUrl  String? @map("consent_doc_url") @db.Text

  // Metadata
  ipAddress String? @map("ip_address") @db.VarChar(50)
  userAgent String? @map("user_agent") @db.Text

  // Relations
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, changedAt], map: "idx_patient_history_patient_time")
  @@index([tenantId, fieldName], map: "idx_patient_history_field")
  @@index([tenantId, changedBy], map: "idx_patient_history_changed_by")
  @@index([tenantId, changeType], map: "idx_patient_history_change_type")
  @@map("patient_history")
}

model PatientConsent {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  patientId String @map("patient_id") @db.Uuid

  // Consent Details
  consentType     String  @map("consent_type") @db.VarChar(100)
  consentCategory String  @map("consent_category") @db.VarChar(50)
  consentStatus   String  @map("consent_status") @db.VarChar(20)
  consentScope    String? @map("consent_scope") @db.Text

  // Consent Metadata
  purpose     String  @map("purpose") @db.Text
  description String? @map("description") @db.Text
  legalBasis  String? @map("legal_basis") @db.VarChar(50)

  // Validity
  effectiveFrom  DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveUntil DateTime? @map("effective_until") @db.Timestamptz(6)
  isActive       Boolean   @default(true) @map("is_active")

  // Capture Method
  captureMethod      String   @map("capture_method") @db.VarChar(50)
  capturedBy         String?  @map("captured_by") @db.Uuid
  capturedAt         DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)
  capturedAtFacility String?  @map("captured_at_facility") @db.Uuid

  // Evidence
  signatureUrl        String? @map("signature_url") @db.Text
  documentUrl         String? @map("document_url") @db.Text
  witnessedBy         String? @map("witnessed_by") @db.Uuid
  witnessSignatureUrl String? @map("witness_signature_url") @db.Text

  // Revocation
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedBy        String?   @map("revoked_by") @db.Uuid
  revocationReason String?   @map("revocation_reason") @db.Text
  revocationMethod String?   @map("revocation_method") @db.VarChar(50)

  // Metadata
  metadata         Json?   @default("{}")
  version          Int     @default(1)
  parentConsentId  String? @map("parent_consent_id") @db.Uuid
  linkedEntityType String? @map("linked_entity_type") @db.VarChar(50)
  linkedEntityId   String? @map("linked_entity_id") @db.Uuid

  // System
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, isActive], map: "idx_patient_consent_patient_active")
  @@index([tenantId, consentType, consentStatus], map: "idx_patient_consent_type_status")
  @@index([tenantId, consentCategory], map: "idx_patient_consent_category")
  @@index([tenantId, effectiveFrom, effectiveUntil], map: "idx_patient_consent_validity")
  @@index([tenantId, linkedEntityType, linkedEntityId], map: "idx_patient_consent_linked")
  @@map("patient_consents")
}

model ConsentTemplate {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Template Details
  templateCode    String @unique @map("template_code") @db.VarChar(100)
  consentType     String @map("consent_type") @db.VarChar(100)
  consentCategory String @map("consent_category") @db.VarChar(50)

  // Content
  title       Json  @map("title")
  description Json  @map("description")
  content     Json  @map("content")
  legalText   Json? @map("legal_text")

  // Configuration
  isRequired      Boolean @default(false) @map("is_required")
  requiresWitness Boolean @default(false) @map("requires_witness")
  validityDays    Int?    @map("validity_days")
  autoRenew       Boolean @default(false) @map("auto_renew")

  // Versioning
  version    Int     @default(1)
  status     String  @default("active") @db.VarChar(20)
  supersedes String? @map("supersedes") @db.Uuid

  // Metadata
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, consentType], map: "idx_consent_template_type")
  @@index([tenantId, consentCategory], map: "idx_consent_template_category")
  @@index([tenantId, status], map: "idx_consent_template_status")
  @@map("consent_templates")
}

// ========================================
// SCHEDULING MODELS
// Add these models to the end of schema.prisma
// ========================================

// Staff Schedules (Weekly Recurring Availability)
model StaffSchedule {
  id               String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  staffId          String    @map("staff_id") @db.Uuid
  facilityId       String?   @map("facility_id") @db.Uuid
  employeeId       String?   @map("employee_id") @db.VarChar(50)
  staffDisplayName String?   @map("staff_display_name") @db.VarChar(200)
  staffType        String?   @map("staff_type") @db.VarChar(50)
  dayOfWeek        Int       @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime        String    @map("start_time")
  endTime          String    @map("end_time")
  isAvailable      Boolean   @default(true) @map("is_available")
  scheduleType     String    @default("regular") @map("schedule_type") @db.VarChar(50)
  notes            String?   @db.Text
  effectiveFrom    DateTime  @default(now()) @map("effective_from") @db.Date
  effectiveTo      DateTime? @map("effective_to") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid

  @@unique([staffId, dayOfWeek, startTime, effectiveFrom], map: "staff_schedules_unique_slot")
  @@index([tenantId, staffId], map: "idx_staff_schedules_tenant_staff")
  @@index([dayOfWeek, startTime], map: "idx_staff_schedules_day_time")
  @@index([effectiveFrom, effectiveTo], map: "idx_staff_schedules_effective_dates")
  @@index([facilityId], map: "idx_staff_schedules_facility")
  @@map("staff_schedules")
}

// Equipment Schedules (Weekly Recurring Availability)
model EquipmentSchedule {
  id              String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  equipmentId     String    @map("equipment_id") @db.Uuid
  facilityId      String?   @map("facility_id") @db.Uuid
  dayOfWeek       Int       @map("day_of_week")
  startTime       String    @map("start_time")
  endTime         String    @map("end_time")
  isAvailable     Boolean   @default(true) @map("is_available")
