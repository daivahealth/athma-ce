  effectiveFrom   DateTime  @default(now()) @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  @@unique([equipmentId, dayOfWeek, startTime, effectiveFrom], map: "equipment_schedules_unique_slot")
  @@index([tenantId, equipmentId], map: "idx_equipment_schedules_tenant_equipment")
  @@index([dayOfWeek, startTime], map: "idx_equipment_schedules_day_time")
  @@index([effectiveFrom, effectiveTo], map: "idx_equipment_schedules_effective_dates")
  @@index([maintenanceType], map: "idx_equipment_schedules_maintenance")
