/// Biomarker definition catalog
model BiomarkerDefinition {
  id       String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid // null = global catalog

  // Biomarker identification
  code        String  @map("code") @db.VarChar(50)
  name        String  @map("name") @db.VarChar(255)
  description String? @map("description") @db.Text

  // Categorization
  category    String  @map("category") @db.VarChar(50) // hormonal, metabolic, inflammatory, cardiovascular, longevity, etc.
  subcategory String? @map("subcategory") @db.VarChar(50)

  // Units and measurement
  unit      String @map("unit") @db.VarChar(50)
  precision Int    @default(2) @map("precision")

  // Reference ranges (age/gender-specific)
  referenceRanges Json @map("reference_ranges") @db.JsonB // [{ageMin, ageMax, gender, min, max, optimal_min, optimal_max}]

  // Optimal longevity ranges (may differ from standard reference)
  optimalRanges Json? @map("optimal_ranges") @db.JsonB

  // Alert thresholds
