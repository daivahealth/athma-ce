  studyInstanceUid String? @map("study_instance_uid") @db.VarChar(128)

  // Authorship
  reportedBy String?   @map("reported_by") @db.Uuid // radiologist
  reviewedBy String?   @map("reviewed_by") @db.Uuid
  reportedAt DateTime? @map("reported_at") @db.Timestamptz(6)
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz(6)

  comments String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  order     ClinicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  encounter Encounter     @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId], map: "idx_imaging_report_order")
  @@index([tenantId, patientId], map: "idx_imaging_report_patient")
  @@index([tenantId, encounterId], map: "idx_imaging_report_encounter")
  @@index([tenantId, reportStatus], map: "idx_imaging_report_status")
  @@index([tenantId, criticalFinding], map: "idx_imaging_report_critical")
  @@index([tenantId, patientId, reportStatus], map: "idx_imaging_report_patient_status")
  @@map("imaging_reports")
}

/// Procedure Report - Structured procedure notes with timing, performers, and specimens
model ProcedureReport {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  orderId     String @map("order_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Report status workflow: DRAFT -> PRELIMINARY -> FINAL -> AMENDED
  reportStatus      String  @default("DRAFT") @map("report_status") @db.VarChar(20)
  version           Int     @default(1)
  previousVersionId String? @map("previous_version_id") @db.Uuid

  // Structured procedure sections (legacy — kept for backward compatibility)
  indication                String? @db.Text
  procedureDescription      String? @map("procedure_description") @db.Text
  findings                  String? @db.Text
  complications             String? @db.Text
  specimens                 Json?   @db.JsonB // array of { type, sentTo, label }
  postProcedureInstructions String? @map("post_procedure_instructions") @db.Text

  // Block editor content (Tiptap JSON) — replaces structured sections above
  reportContent Json? @map("report_content") @db.JsonB

  // Anesthesia details
  anesthesiaType     String? @map("anesthesia_type") @db.VarChar(30) // none, local, regional, general, sedation
  anesthesiaProvider String? @map("anesthesia_provider") @db.Uuid

  // Timing
  startTime       DateTime? @map("start_time") @db.Timestamptz(6)
