generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider   = "postgresql"
  url        = env("FOUNDATION_DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model Tenant {
  id                String               @id @default(uuid()) @map("id") @db.Uuid
  name              String               @unique
  domain            String               @unique
  status            String               @default("active")
  settings          Json                 @default("{}")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  facilities        Facility[]
  roles             Role[]
  staff             Staff[]
  staffSpecialties  StaffSpecialty[]
  users             User[]
  configs           TenantConfig[]
  medications       MedicationMaster[]
  labTests          LabTestMaster[]
  imagingStudies    ImagingStudyMaster[]
  procedures        ProcedureMaster[]
  diagnosisVersions DiagnosisVersion[]
  diagnoses         DiagnosisMaster[]
  noteTemplates     NoteTemplate[]

  @@map("tenants")
}

model User {
  id                    String              @id @default(uuid()) @map("id") @db.Uuid
  tenantId              String              @map("tenant_id") @db.Uuid
  email                 String
  firstName             String              @map("first_name")
  lastName              String              @map("last_name")
  passwordHash          String              @map("password_hash")
  role                  String
  status                String              @default("active")
  permissions           Json                @default("{}")
  staffId               String?             @map("staff_id") @db.Uuid
  defaultFacilityId     String?             @map("default_facility_id") @db.Uuid
  lastLogin             DateTime?           @map("last_login") @db.Timestamptz(6)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  mfaAttempts           UserMfaAttempt[]
  mfaBackupCodes        UserMfaBackupCode[]
  mfaSettings           UserMfaSettings?
  userRoles             UserRole[]
  trustedDevices        UserTrustedDevice[]
  userFacilities        UserFacility[]
  grantedFacilityAccess UserFacility[]      @relation("FacilityAccessGrantor")
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff                 Staff?              @relation(fields: [staffId], references: [id], onDelete: SetNull)
  defaultFacility       Facility?           @relation("UserDefaultFacility", fields: [defaultFacilityId], references: [id])

  @@unique([tenantId, email])
  @@unique([staffId])
  @@index([tenantId, defaultFacilityId])
  @@index([tenantId, staffId])
  @@map("users")
}

model Facility {
  id            String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  name          String
  code          String? @db.VarChar(50)
  facilityType  String  @default("clinic") @map("facility_type")
  licenseNumber String? @map("license_number")

  // Location Information
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  emirate      String?
  postalCode   String? @map("postal_code")
  country      String  @default("UAE")

  // Geocode Information
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  googlePlaceId String?  @map("google_place_id") @db.VarChar(255)

  // Contact Information
  phoneNumber String? @map("phone_number")
  email       String?
  website     String?

  // Building Details
  buildingNumber String?  @map("building_number") @db.VarChar(50)
  floorNumbers   String[] @map("floor_numbers")
  totalFloors    Int?     @map("total_floors")

  // Operational Details
  capacity       Int?
  operatingHours Json?  @map("operating_hours")
  status         String @default("active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments      Department[]
  userFacilities   UserFacility[]
  defaultForUsers  User[]           @relation("UserDefaultFacility")
  spaces           Space[]
  staffSpecialties StaffSpecialty[]
  configs          FacilityConfig[]

  @@unique([tenantId, code])
  @@index([tenantId, facilityType])
  @@index([tenantId, city])
  @@index([tenantId, emirate])
  @@index([latitude, longitude])
  @@map("facilities")
}

model Department {
  id               String   @id @default(uuid()) @map("id") @db.Uuid
  facilityId       String   @map("facility_id") @db.Uuid
  name             String
  code             String?  @db.VarChar(50)
  departmentType   String   @map("department_type")
  specialtyId      String?  @map("specialty_id") @db.Uuid
  headOfDepartment String?  @map("head_of_department") @db.Uuid
  floorNumber      String?  @map("floor_number") @db.VarChar(10)
  phoneExtension   String?  @map("phone_extension") @db.VarChar(20)
  operatingHours   Json?    @map("operating_hours")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  facility  Facility   @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  specialty Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  hod       Staff?     @relation("DepartmentHead", fields: [headOfDepartment], references: [id])
  wards     Ward[]
  clinics   Clinic[]
  spaces    Space[]

  @@unique([facilityId, code])
  @@index([facilityId, departmentType])
  @@index([specialtyId])
  @@map("departments")
}

model Ward {
  id             String   @id @default(uuid()) @map("id") @db.Uuid
  departmentId   String   @map("department_id") @db.Uuid
  name           String
  code           String?  @db.VarChar(50)
  wardType       String   @map("ward_type")
  floorNumber    String?  @map("floor_number") @db.VarChar(10)
  totalBeds      Int      @default(0) @map("total_beds")
  availableBeds  Int      @default(0) @map("available_beds")
  nursingStation String?  @map("nursing_station")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  beds       Bed[]

  @@unique([departmentId, code])
  @@index([departmentId, wardType])
  @@map("wards")
}

model Bed {
  id               String    @id @default(uuid()) @map("id") @db.Uuid
  wardId           String    @map("ward_id") @db.Uuid
  bedNumber        String    @map("bed_number") @db.VarChar(20)
  bedType          String    @map("bed_type")
  features         Json?
  status           String    @default("available")
  currentPatientId String?   @map("current_patient_id") @db.Uuid
  assignedAt       DateTime? @map("assigned_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  ward Ward @relation(fields: [wardId], references: [id], onDelete: Cascade)

  @@unique([wardId, bedNumber])
  @@index([wardId, status])
  @@index([currentPatientId])
  @@map("beds")
}

model Clinic {
  id             String   @id @default(uuid()) @map("id") @db.Uuid
  departmentId   String   @map("department_id") @db.Uuid
  name           String
  code           String?  @db.VarChar(50)
  specialty      String?
  floorNumber    String?  @map("floor_number") @db.VarChar(10)
  totalRooms     Int      @default(0) @map("total_rooms")
  operatingHours Json?    @map("operating_hours")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  spaces     Space[]

  @@unique([departmentId, code])
  @@index([departmentId, specialty])
  @@map("clinics")
}

model Space {
  id           String   @id @default(uuid()) @map("id") @db.Uuid
  facilityId   String   @map("facility_id") @db.Uuid
  departmentId String?  @map("department_id") @db.Uuid
  clinicId     String?  @map("clinic_id") @db.Uuid
  name         String
  spaceNumber  String?  @map("space_number")
  spaceType    String   @map("space_type")
  floorNumber  String?  @map("floor_number") @db.VarChar(10)
  equipment    Json     @default("[]")
  capacity     Int      @default(1)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  facility   Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  clinic     Clinic?     @relation(fields: [clinicId], references: [id])

  @@index([facilityId, departmentId])
  @@index([clinicId])
  @@map("spaces")
}

model Staff {
  id               String           @id @default(uuid()) @map("id") @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  prefix           String?          @map("prefix") @db.VarChar(20)
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  middleName       String?          @map("middle_name")
  dateOfBirth      DateTime         @map("date_of_birth") @db.Date
  gender           String
  nationality      String           @default("UAE")
  phoneNumber      String?          @map("phone_number")
  email            String?
  employeeId       String           @map("employee_id")
  staffType        String           @map("staff_type")
  specialties      Json             @default("[]")
  licenseNumber    String?          @map("license_number")
  licenseExpiry    DateTime?        @map("license_expiry") @db.Date
  qualification    String?          @map("qualification") @db.VarChar(150)
  languages        String[]         @default([]) @map("languages") @db.VarChar(50)
  displayName      String?          @map("display_name") @db.VarChar(255)
  status           String           @default("active")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  departments      Department[]     @relation("DepartmentHead")
  user             User?
  staffSpecialties StaffSpecialty[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId])
  @@map("staff")
}

model Specialty {
  id               String                   @id @default(uuid()) @map("id") @db.Uuid
  code             String                   @unique @db.VarChar(50)
  name             String                   @db.VarChar(150)
  description      String?                  @db.Text
  isActive         Boolean                  @default(true) @map("is_active")
  sortOrder        Int                      @default(0) @map("sort_order")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  staffSpecialties StaffSpecialty[]
  translations     SpecialtyTranslation[]
  authorityCodes   SpecialtyCodeAuthority[]
  departments      Department[]
  noteTemplates    NoteTemplate[]

  @@index([code])
  @@map("specialties")
}

model SpecialtyCodeAuthority {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  specialtyId   String    @map("specialty_id") @db.Uuid
  authority     String    @db.VarChar(20)
  authorityCode String    @map("authority_code") @db.VarChar(50)
  authorityName String?   @map("authority_name") @db.VarChar(150)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  specialty     Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([specialtyId, authority], map: "ux_specialty_authority")
  @@index([authority, authorityCode])
  @@map("specialty_codes_authority")
}

model StaffSpecialty {
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  staffId     String    @map("staff_id") @db.Uuid
  facilityId  String    @map("facility_id") @db.Uuid
  specialtyId String    @map("specialty_id") @db.Uuid
  primaryFlag Boolean   @default(false) @map("primary_flag")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  facility    Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@unique([staffId, specialtyId, facilityId], map: "ux_staff_specialty_facility")
  @@index([staffId])
  @@index([specialtyId])
  @@index([tenantId])
  @@index([facilityId])
  @@index([facilityId, specialtyId])
  @@index([facilityId, staffId])
  @@map("staff_specialties")
}

model SpecialtyTranslation {
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  specialtyId String    @map("specialty_id") @db.Uuid
  lang        String    @db.Char(2)
  displayName String    @map("display_name") @db.Text
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([specialtyId, lang], map: "ux_specialty_lang")
  @@index([specialtyId, lang])
  @@map("specialty_translations")
}

model Role {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  code            String
  name            String
  description     String?
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  code            String           @unique
  name            String
  description     String?
  resource        String?
  action          String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @map("id") @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String    @id @default(uuid()) @map("id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  roleId     String    @map("role_id") @db.Uuid
  assignedBy String?   @map("assigned_by") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserMfaSettings {
  id               String    @id @default(uuid()) @map("id") @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  totpEnabled      Boolean   @default(false) @map("totp_enabled")
  totpSecret       String?   @map("totp_secret")
  smsEnabled       Boolean   @default(false) @map("sms_enabled")
  smsPhoneNumber   String?   @map("sms_phone_number")
  emailEnabled     Boolean   @default(false) @map("email_enabled")
  backupCodesCount Int       @default(0) @map("backup_codes_count")
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_mfa_settings")
}

model UserMfaBackupCode {
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_mfa_backup_codes")
}

model UserMfaAttempt {
  id        String   @id @default(uuid()) @map("id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  method    String
  success   Boolean
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_mfa_attempts")
}

model UserTrustedDevice {
  id                String    @id @default(uuid()) @map("id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  deviceFingerprint String    @map("device_fingerprint")
  deviceName        String?   @map("device_name")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  trustedAt         DateTime  @default(now()) @map("trusted_at") @db.Timestamptz(6)
  lastUsedAt        DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamptz(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_trusted_devices")
}

model UserFacility {
  id          String    @id @default(uuid()) @map("id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  facilityId  String    @map("facility_id") @db.Uuid
  isDefault   Boolean   @default(false) @map("is_default")
  accessLevel String    @default("standard") @map("access_level")
  grantedAt   DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  grantedBy   String?   @map("granted_by") @db.Uuid
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility      Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  grantedByUser User?    @relation("FacilityAccessGrantor", fields: [grantedBy], references: [id])

  @@unique([userId, facilityId])
  @@index([userId, isDefault])
  @@index([facilityId, revokedAt])
  @@map("user_facilities")
}

// ============================================
// Configuration Management Models
// ============================================

model InstanceConfig {
  id            String   @id @default(uuid()) @map("id") @db.Uuid
  configKey     String   @unique @map("config_key")
  value         Json
  valueType     String   @map("value_type") // 'string', 'number', 'boolean', 'json'
  category      String
  description   String?
  isOverridable Boolean  @default(true) @map("is_overridable")
  isSensitive   Boolean  @default(false) @map("is_sensitive")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String?  @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid

  @@index([category])
  @@map("instance_configs")
}

model TenantConfig {
  id        String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  configKey String   @map("config_key")
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, configKey], map: "unique_tenant_config")
  @@index([tenantId])
  @@map("tenant_configs")
}

model FacilityConfig {
  id         String   @id @default(uuid()) @map("id") @db.Uuid
  facilityId String   @map("facility_id") @db.Uuid
  configKey  String   @map("config_key")
  value      Json
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy  String?  @map("created_by") @db.Uuid
  updatedBy  String?  @map("updated_by") @db.Uuid

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, configKey], map: "unique_facility_config")
  @@index([facilityId])
  @@map("facility_configs")
}

model ConfigAuditLog {
  id           String   @id @default(uuid()) @map("id") @db.Uuid
  configLevel  String   @map("config_level") // 'instance', 'tenant', 'facility'
  configKey    String   @map("config_key")
  entityId     String?  @map("entity_id") @db.Uuid // tenantId or facilityId (null for instance)
  oldValue     Json?    @map("old_value")
  newValue     Json     @map("new_value")
  changedBy    String   @map("changed_by") @db.Uuid
  changedAt    DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  changeReason String?  @map("change_reason")

  @@index([configLevel, entityId])
  @@index([configKey])
  @@index([changedBy])
  @@map("config_audit_log")
}

// ============================================
// ValueSet / Reference Data Models
// ============================================

model ValueSet {
  id           String   @id @default(uuid()) @map("id") @db.Uuid
  code         String   @unique @db.VarChar(100)
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  category     String?  @db.VarChar(50)
  version      String?  @db.VarChar(20)
  status       String   @default("active") @db.VarChar(20)
  isSystem     Boolean  @default(false) @map("is_system")
  isExtensible Boolean  @default(true) @map("is_extensible")
  source       String?  @db.VarChar(255)
  sourceUrl    String?  @map("source_url") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid

  concepts        ValueSetConcept[]
  conceptsByCode  ValueSetConcept[]        @relation("ValueSetByCode")
  tenantOverrides TenantValueSetOverride[]

  @@index([code])
  @@index([category])
  @@index([status])
  @@map("value_sets")
}

model ValueSetConcept {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  valueSetId    String    @map("value_set_id") @db.Uuid
  valueSetCode  String    @map("value_set_code") @db.VarChar(100)
  code          String    @db.VarChar(100)
  display       String    @db.VarChar(500)
  definition    String?   @db.Text
  systemCode    String?   @map("system_code") @db.VarChar(100)
  parentId      String?   @map("parent_id") @db.Uuid
  sortOrder     Int       @default(0) @map("sort_order")
  isDefault     Boolean   @default(false) @map("is_default")
  status        String    @default("active") @db.VarChar(20)
  effectiveFrom DateTime? @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid

  valueSet        ValueSet                     @relation(fields: [valueSetId], references: [id], onDelete: Cascade)
  valueSetByCode  ValueSet                     @relation("ValueSetByCode", fields: [valueSetCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  parent          ValueSetConcept?             @relation("ConceptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        ValueSetConcept[]            @relation("ConceptHierarchy")
  translations    ValueSetConceptTranslation[]
  tenantOverrides TenantValueSetOverride[]

  @@unique([valueSetCode, code])
  @@index([valueSetId])
  @@index([valueSetCode])
  @@index([code])
  @@index([parentId])
  @@index([status])
  @@index([valueSetId, sortOrder])
  @@map("value_set_concepts")
}

model ValueSetConceptTranslation {
  id           String   @id @default(uuid()) @map("id") @db.Uuid
  conceptId    String   @map("concept_id") @db.Uuid
  languageCode String   @map("language_code") @db.VarChar(10)
  display      String   @db.VarChar(500)
  definition   String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  concept ValueSetConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([conceptId, languageCode], map: "unique_concept_language")
  @@index([conceptId])
  @@index([languageCode])
  @@map("value_set_concept_translations")
}

model TenantValueSetOverride {
  id             String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  valueSetId     String   @map("value_set_id") @db.Uuid
  conceptId      String?  @map("concept_id") @db.Uuid
  overrideType   String   @map("override_type") @db.VarChar(20)
  customDisplay  String?  @map("custom_display") @db.VarChar(500)
  customMetadata Json?    @map("custom_metadata")
