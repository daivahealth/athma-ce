/// Procedure Master (CPT, ICD-10-PCS, local codes)
/// Medical and surgical procedures catalog
model ProcedureMaster {
  id                        String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId                  String?  @map("tenant_id") @db.Uuid // NULL = global procedure
  procedureName             String   @map("procedure_name") @db.VarChar(255)
  cptCode                   String?  @map("cpt_code") @db.VarChar(10) // CPT code for billing
  icd10PcsCode              String?  @map("icd10_pcs_code") @db.VarChar(10) // ICD-10-PCS code
  localCode                 String?  @map("local_code") @db.VarChar(100) // Facility-specific procedure code
  billingCode               String?  @map("billing_code") @db.VarChar(100)
  billingCodeType           String?  @map("billing_code_type") @db.VarChar(50)
  billingDescription        String?  @map("billing_description") @db.VarChar(255)
  procedureCategory         String   @map("procedure_category") @db.VarChar(100) // surgical, diagnostic, therapeutic
  bodySystem                String   @map("body_system") @db.VarChar(100) // cardiovascular, respiratory
  procedureType             String?  @map("procedure_type") @db.VarChar(100) // minor, major, endoscopic
  anesthesiaType            String?  @map("anesthesia_type") @db.VarChar(50) // local, regional, general, none
  facilityRequired          String?  @map("facility_required") @db.VarChar(50) // clinic, hospital, surgery_center
  estimatedDurationMinutes  Int?     @map("estimated_duration_minutes")
  preparationInstructions   String?  @map("preparation_instructions") @db.Text
  postProcedureInstructions String?  @map("post_procedure_instructions") @db.Text
  risksAndComplications     String[] @map("risks_and_complications")
  contraindications         String[] @map("contraindications")
  consentRequired           Boolean  @default(false) @map("consent_required")
  consentType               String?  @map("consent_type") @db.VarChar(100) // informed_consent, anesthesia_consent
  preProcedureRequirements  String[] @map("pre_procedure_requirements")
  postProcedureMonitoring   String?  @map("post_procedure_monitoring") @db.Text
  recoveryTimeHours         Int?     @map("recovery_time_hours")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, cptCode], map: "unique_tenant_procedure_cpt")
  @@unique([tenantId, icd10PcsCode], map: "unique_tenant_procedure_icd10pcs")
  @@unique([tenantId, localCode], map: "unique_tenant_procedure_local_code")
  @@index([tenantId])
  @@index([procedureCategory])
  @@index([bodySystem])
  @@index([isActive])
  @@map("procedure_master")
}

/// Diagnosis Master (ICD catalog)
/// Stores ICD code metadata scoped by version and tenant
model DiagnosisMaster {
  id                String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId          String?   @map("tenant_id") @db.Uuid // NULL = global catalog entry
  versionId         String    @map("version_id") @db.Uuid
  code              String    @db.VarChar(20)
  codeType          String?   @map("code_type") @db.VarChar(50)
  shortDescription  String?   @map("short_description") @db.VarChar(255)
  description       String    @db.Text
  chapter           String?   @db.VarChar(100)
  block             String?   @db.VarChar(100)
  category          String?   @db.VarChar(100)
  subcategory       String?   @db.VarChar(100)
  clinicalConcepts  String[]  @map("clinical_concepts")
  synonyms          String[]
  searchTerms       String[]  @map("search_terms")
  genderRestriction String?   @map("gender_restriction") @db.VarChar(20)
  ageRange          String?   @map("age_range") @db.VarChar(50)
  isBillable        Boolean   @default(true) @map("is_billable")
  isActive          Boolean   @default(true) @map("is_active")
  effectiveFrom     DateTime? @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  version DiagnosisVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, versionId, code], map: "unique_tenant_version_code")
  @@index([tenantId])
  @@index([versionId])
  @@index([code])
  @@index([chapter])
  @@index([isActive])
  @@map("diagnosis_master")
}

/// Diagnosis Version metadata (ICD releases)
model DiagnosisVersion {
  id           String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId     String?   @map("tenant_id") @db.Uuid // NULL = globally shared release
  codeSet      String    @map("code_set") @db.VarChar(50) // ICD-10-CM, ICD-10-PCS, ICD-11
  versionLabel String    @map("version_label") @db.VarChar(100) // e.g., 2024
  releaseDate  DateTime? @map("release_date") @db.Date
  description  String?   @db.Text
  importStatus String    @default("pending") @map("import_status") @db.VarChar(30)
  importNotes  String?   @map("import_notes") @db.Text
  sourceUrl    String?   @map("source_url") @db.VarChar(255)
  checksum     String?   @db.VarChar(128)
  totalCodes   Int       @default(0) @map("total_codes")
  importedBy   String?   @map("imported_by") @db.Uuid
  importedAt   DateTime? @map("imported_at") @db.Timestamptz(6)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  diagnoses DiagnosisMaster[]

  @@unique([tenantId, codeSet, versionLabel], map: "unique_tenant_codeset_version")
  @@index([tenantId])
  @@index([codeSet])
  @@index([importStatus])
  @@map("diagnosis_versions")
}

// ========================================
// NOTE TEMPLATES (Catalog/Master Data)
// ========================================

// Note Templates (Define reusable templates for encounter notes)
model NoteTemplate {
  id          String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String? @map("tenant_id") @db.Uuid // NULL for global templates
  specialtyId String? @map("specialty_id") @db.Uuid

  // Template Details
  name        String  @map("name") @db.VarChar(200)
  description String? @map("description") @db.Text
  status      String  @default("active") @map("status") @db.VarChar(20) // active, inactive, archived

  // Versioning
  currentVersion Int @default(1) @map("current_version")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  tenant    Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  specialty Specialty?            @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  versions  NoteTemplateVersion[]

  @@index([tenantId, status], map: "idx_note_templates_tenant_status")
  @@index([specialtyId], map: "idx_note_templates_specialty")
  @@map("note_templates")
}

// Note Template Versions (Store versioned schemas)
model NoteTemplateVersion {
  id         String @id @default(uuid()) @map("id") @db.Uuid
  templateId String @map("template_id") @db.Uuid

  // Version Details
  version Int  @map("version")
  schema  Json @map("schema") // JSONB schema defining sections + fields

  // Metadata
  changeLog String? @map("change_log") @db.Text
  createdBy String? @map("created_by") @db.Uuid // Staff ID

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  template NoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version], map: "uq_note_template_version")
  @@index([templateId, version], map: "idx_note_template_versions_template")
  @@map("note_template_versions")
}
