/// Medication Master (NDC, ATC, local codes)
/// Supports both global medications and tenant-specific formularies
model MedicationMaster {
  id                   String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId             String?  @map("tenant_id") @db.Uuid // NULL = global medication
  medicationName       String   @map("medication_name") @db.VarChar(255)
  genericName          String?  @map("generic_name") @db.VarChar(255)
  brandName            String?  @map("brand_name") @db.VarChar(255)
  ndcCode              String?  @map("ndc_code") @db.VarChar(20) // National Drug Code
  atcCode              String?  @map("atc_code") @db.VarChar(20) // Anatomical Therapeutic Chemical
  localCode            String?  @map("local_code") @db.VarChar(100) // Facility-specific code
  dosageForm           String   @map("dosage_form") @db.VarChar(50) // tablet, capsule, injection, cream
  strength             String?  @db.VarChar(100) // 500mg, 10mg/ml
  route                String?  @db.VarChar(50) // oral, IV, IM, topical
  manufacturer         String?  @db.VarChar(255)
  drugClass            String?  @map("drug_class") @db.VarChar(100) // ACE inhibitor, antibiotic
  therapeuticClass     String?  @map("therapeutic_class") @db.VarChar(100) // cardiovascular, antimicrobial
  controlledSubstance  Boolean  @default(false) @map("controlled_substance")
  controlledClass      String?  @map("controlled_class") @db.VarChar(50) // Schedule I, II, III
  requiresPrescription Boolean  @default(true) @map("requires_prescription")
  defaultFrequency     String?  @map("default_frequency") @db.VarChar(100) // BID, TID, QID
  defaultDuration      String?  @map("default_duration") @db.VarChar(100) // 7 days, 2 weeks
  contraindications    String[] @map("contraindications")
  commonSideEffects    String[] @map("common_side_effects")
  drugInteractions     String[] @map("drug_interactions")
  storageRequirements  String?  @map("storage_requirements") @db.VarChar(255)
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, localCode], map: "unique_tenant_medication_local_code")
  @@index([tenantId])
  @@index([ndcCode])
  @@index([atcCode])
  @@index([genericName])
  @@index([isActive])
  @@map("medication_master")
}

/// Lab Test Master (LOINC for orders, CPT for billing)
/// Standardized lab test catalog with reference ranges
model LabTestMaster {
  id                      String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId                String?  @map("tenant_id") @db.Uuid // NULL = global test
  testName                String   @map("test_name") @db.VarChar(255)
  loincCode               String   @map("loinc_code") @db.VarChar(20) // LOINC code for test identification
  cptCode                 String?  @map("cpt_code") @db.VarChar(10) // CPT code for billing
  localCode               String?  @map("local_code") @db.VarChar(100) // Facility-specific code
  billingCode             String?  @map("billing_code") @db.VarChar(100)
  billingCodeType         String?  @map("billing_code_type") @db.VarChar(50)
  billingDescription      String?  @map("billing_description") @db.VarChar(255)
  testCategory            String   @map("test_category") @db.VarChar(100) // hematology, chemistry, microbiology
  testSubcategory         String?  @map("test_subcategory") @db.VarChar(100) // CBC, lipid panel
  specimenType            String   @map("specimen_type") @db.VarChar(100) // blood, urine, stool, sputum
  collectionMethod        String?  @map("collection_method") @db.VarChar(100) // venipuncture, fingerstick, clean catch
  fastingRequired         Boolean  @default(false) @map("fasting_required")
  fastingDurationHours    Int?     @map("fasting_duration_hours")
  preparationInstructions String?  @map("preparation_instructions") @db.Text
  normalRangeMale         String?  @map("normal_range_male") @db.VarChar(100)
  normalRangeFemale       String?  @map("normal_range_female") @db.VarChar(100)
  normalRangePediatric    String?  @map("normal_range_pediatric") @db.VarChar(100)
  units                   String?  @db.VarChar(50)
  methodology             String?  @db.VarChar(255)
  turnaroundTimeHours     Int?     @map("turnaround_time_hours")
  referenceLab            String?  @map("reference_lab") @db.VarChar(255)
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, loincCode], map: "unique_tenant_labtest_loinc")
  @@unique([tenantId, localCode], map: "unique_tenant_labtest_local_code")
  @@index([tenantId])
  @@index([testCategory])
  @@index([isActive])
  @@map("lab_test_master")
}

/// Imaging Study Master (CPT, local codes)
/// Radiology and diagnostic imaging catalog
model ImagingStudyMaster {
  id                       String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId                 String?  @map("tenant_id") @db.Uuid // NULL = global study
  studyName                String   @map("study_name") @db.VarChar(255)
  cptCode                  String?  @map("cpt_code") @db.VarChar(10) // CPT code for billing
  localCode                String?  @map("local_code") @db.VarChar(100) // Facility-specific radiology code
  billingCode              String?  @map("billing_code") @db.VarChar(100)
  billingCodeType          String?  @map("billing_code_type") @db.VarChar(50)
  billingDescription       String?  @map("billing_description") @db.VarChar(255)
  modality                 String   @db.VarChar(50) // X-ray, CT, MRI, Ultrasound
  bodyPart                 String   @map("body_part") @db.VarChar(100) // chest, abdomen, head
  studyCategory            String?  @map("study_category") @db.VarChar(100) // diagnostic, screening, interventional
  contrastRequired         Boolean  @default(false) @map("contrast_required")
  contrastType             String?  @map("contrast_type") @db.VarChar(100) // IV, oral, rectal
  preparationInstructions  String?  @map("preparation_instructions") @db.Text
  positioningInstructions  String?  @map("positioning_instructions") @db.Text
