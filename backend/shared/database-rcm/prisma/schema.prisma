generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider   = "postgresql"
  url        = env("RCM_DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model Payer {
  id            String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  payerName     String   @map("payer_name") @db.VarChar(255)
  payerId       String?  @map("payer_id") @db.VarChar(100)
  payerType     String?  @map("payer_type") @db.VarChar(50)
  contactInfo   Json     @default("{}") @map("contact_info")
  configuration Json     @default("{}") @map("configuration")
  status        String   @default("active") @map("status") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  policies           Policy[]
  claims             Claim[]
  encounterCoverages EncounterCoverage[]
  payerContracts     PayerContract[]
  eligibilityRequests EligibilityRequest[]
  preAuthRequests    PreAuthRequest[]
  claimBatches       ClaimBatch[]
  remittances        Remittance[]

  @@index([tenantId, status], map: "idx_payer_tenant_status")
  @@index([payerId], map: "idx_payer_id")
  @@map("payers")
}

model Policy {
  id             String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid // No FK - patients are in Clinical DB
  policyNumber   String    @map("policy_number") @db.VarChar(100)
  groupNumber    String?   @map("group_number") @db.VarChar(100)
  payerName      String    @map("payer_name") @db.VarChar(255)
  payerId        String    @map("payer_id") @db.Uuid
  relationship   String?   @map("relationship") @db.VarChar(50)
  effectiveDate  DateTime? @map("effective_date") @db.Date
  expirationDate DateTime? @map("expiration_date") @db.Date
  benefits       Json      @default("{}") @map("benefits")
  isPrimary      Boolean   @default(false) @map("is_primary")
  status         String    @default("active") @map("status") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  payer              Payer               @relation(fields: [payerId], references: [id], onDelete: Cascade)
  encounterCoverages EncounterCoverage[]
  eligibilityRequests EligibilityRequest[]
  preAuthRequests    PreAuthRequest[]

  @@index([tenantId, patientId], map: "idx_policy_tenant_patient")
  @@index([tenantId, status], map: "idx_policy_tenant_status")
  @@index([payerId], map: "idx_policy_payer")
  @@map("policies")
}

model Claim {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  claimNumber   String    @map("claim_number") @db.VarChar(50)
  status        String    @default("draft")
  payerId       String?   @map("payer_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  encounterId   String?   @map("encounter_id") @db.Uuid
  totalAmount   Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency      String    @default("AED")
  serviceDate   DateTime  @map("service_date") @db.Date
  submittedAt   DateTime? @map("submitted_at") @db.Timestamptz(6)
  adjudicatedAt DateTime? @map("adjudicated_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  payer Payer? @relation(fields: [payerId], references: [id], onDelete: SetNull)

  // Batch Submission
  batchId String? @map("batch_id") @db.Uuid
  batch   ClaimBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  // Medical Coding Integration
  codingSessions CodingSession[]
  claimLines     ClaimLine[]
  claimDiagnoses ClaimDiagnosis[]

  @@unique([tenantId, claimNumber], map: "ux_claim_tenant_number")
  @@index([tenantId, status], map: "idx_claim_status")
  @@index([batchId], map: "idx_claim_batch")
  @@map("claims")
}

model EncounterCoverage {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Cross-database logical FKs
  encounterId String @map("encounter_id") @db.Uuid
  patientId   String @map("patient_id") @db.Uuid

  // Links to RCM entities
  policyId String? @map("policy_id") @db.Uuid
  payerId  String? @map("payer_id") @db.Uuid

  // Financial classification
  financialClass String @map("financial_class") @db.VarChar(30) // 'insurance', 'corporate', 'tpa', 'cash', 'government'
  coverageLevel  String @default("primary") @map("coverage_level") @db.VarChar(20) // 'primary', 'secondary', 'tertiary', 'self_pay'

  // Snapshot fields (frozen at time of encounter)
  planName    String? @map("plan_name") @db.VarChar(255)
  memberId    String? @map("member_id") @db.VarChar(100)
  memberName  String? @map("member_name") @db.VarChar(255)
  networkName String? @map("network_name") @db.VarChar(255)

  // Financial snapshot
  copayAmount        Decimal? @map("copay_amount") @db.Decimal(10, 2)
  coinsurancePct     Decimal? @map("coinsurance_pct") @db.Decimal(5, 2)
  deductibleSnapshot Json?    @map("deductible_snapshot")
  benefitsSnapshot   Json?    @map("benefits_snapshot")

  // Links to other RCM processes
  eligibilityRequestId String? @map("eligibility_request_id") @db.Uuid
  preauthRequestId     String? @map("preauth_request_id") @db.Uuid
  costEstimateId       String? @map("cost_estimate_id") @db.Uuid

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  policy Policy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  payer  Payer?  @relation(fields: [payerId], references: [id], onDelete: SetNull)

  @@index([tenantId, encounterId], map: "idx_enc_cov_encounter")
  @@index([tenantId, patientId], map: "idx_enc_cov_patient")
  @@index([policyId], map: "idx_enc_cov_policy")
  @@index([payerId], map: "idx_enc_cov_payer")
  @@index([financialClass], map: "idx_enc_cov_finclass")
  @@index([coverageLevel], map: "idx_enc_cov_level")
  @@map("encounter_coverages")
}

model BillingItem {
  id                 String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String?  @map("tenant_id") @db.Uuid // NULL = global/authority items

  // Billing codes (CPT, DHA, DOH, MOHAP, INTERNAL)
  billingCode        String   @map("billing_code") @db.VarChar(100)
  billingCodeType    String   @map("billing_code_type") @db.VarChar(50) // INTERNAL, CPT, DHA, DOH, MOHAP
  billingDescription String   @map("billing_description") @db.VarChar(255)

  // Item categorization
  itemType           String   @map("item_type") @db.VarChar(50) // lab, imaging, procedure, consult, registration, pharmacy, package, misc
  chargeType         String   @map("charge_type") @db.VarChar(50) // registration, consultation, lab, radiology, procedure, pharmacy, package
  defaultUnit        String   @default("each") @map("default_unit") @db.VarChar(20)
  listPrice          Decimal? @map("list_price") @db.Decimal(10, 2)

  // DEPRECATED: Use CatalogItemMapping table instead for many-to-many relationships
  clinicalRefId      String?  @map("clinical_ref_id") @db.Uuid // @deprecated - Use catalog_item_mappings table

  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  charges                  Charge[]
  feeScheduleItems         FeeScheduleItem[]
  payerContractAdjustments PayerContractAdjustment[]
  codingProcedures         CodingProcedure[]
  catalogMappings          CatalogItemMapping[]

  @@unique([tenantId, billingCodeType, billingCode], map: "ux_billing_items_tenant_code")
  @@index([tenantId], map: "idx_billing_items_tenant")
  @@index([tenantId, itemType], map: "idx_billing_items_tenant_type")
  @@index([tenantId, chargeType], map: "idx_billing_items_tenant_charge")
  @@index([billingCode], map: "idx_billing_items_code")
  @@index([isActive], map: "idx_billing_items_active")
  @@map("billing_items")
}

model Charge {
  id            String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  patientId     String  @map("patient_id") @db.Uuid // Logical FK to Clinical DB
  encounterId   String? @map("encounter_id") @db.Uuid // Logical FK to Clinical DB, nullable for non-encounter charges
  billingItemId String  @map("billing_item_id") @db.Uuid

  chargeDate  DateTime @default(dbgenerated("CURRENT_DATE")) @map("charge_date") @db.Date
  quantity    Decimal  @default(1) @map("quantity") @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2) // Calculated from FeeSchedule based on patient's payer/contract
  grossAmount Decimal  @map("gross_amount") @db.Decimal(10, 2) // quantity * unit_price

  // Pricing source tracking
  feeScheduleId     String? @map("fee_schedule_id") @db.Uuid // Which fee schedule was used
  feeScheduleItemId String? @map("fee_schedule_item_id") @db.Uuid // Which fee schedule item was used
  payerContractId   String? @map("payer_contract_id") @db.Uuid // If payer contract was applied

  patientResponsibility Decimal? @map("patient_responsibility") @db.Decimal(10, 2)
  payerResponsibility   Decimal? @map("payer_responsibility") @db.Decimal(10, 2)

  status     String  @default("unbilled") @map("status") @db.VarChar(30) // unbilled | invoiced | cancelled
  sourceType String? @map("source_type") @db.VarChar(50) // encounter | order | manual
  sourceId   String? @map("source_id") @db.Uuid
  notes      String? @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Medical Coding Integration
  codingProcedureId     String?   @map("coding_procedure_id") @db.Uuid
  originalBillingItemId String?   @map("original_billing_item_id") @db.Uuid // What posting rules chose
  isCoderModified       Boolean   @default(false) @map("is_coder_modified")
  codedBy               String?   @map("coded_by") @db.Uuid
  codedAt               DateTime? @map("coded_at") @db.Timestamptz(6)
  claimLineSequence     Int?      @map("claim_line_sequence")

  billingItem     BillingItem      @relation(fields: [billingItemId], references: [id], onDelete: Restrict)
  invoiceLines    InvoiceLine[]
  codingProcedure CodingProcedure? @relation(fields: [codingProcedureId], references: [id], onDelete: SetNull)
  claimLines      ClaimLine[]

  @@index([tenantId, encounterId], map: "idx_charges_tenant_encounter")
  @@index([status], map: "idx_charges_status")
  @@index([codingProcedureId], map: "idx_charges_coding_procedure")
  @@map("charges")
}

model Invoice {
  id          String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  patientId   String  @map("patient_id") @db.Uuid // Logical FK to Clinical DB
  encounterId String? @map("encounter_id") @db.Uuid // Logical FK to Clinical DB

  // Denormalized patient fields for easier access
  mrn                String? @map("mrn") @db.VarChar(50)
  patientDisplayName String? @map("patient_display_name") @db.VarChar(255)

  invoiceNumber String    @map("invoice_number") @db.VarChar(50)
  invoiceDate   DateTime  @default(dbgenerated("CURRENT_DATE")) @map("invoice_date") @db.Date
  dueDate       DateTime? @map("due_date") @db.Date

  grossAmount    Decimal @map("gross_amount") @db.Decimal(10, 2) // sum of charges.gross_amount
  totalDiscounts Decimal @default(0) @map("total_discounts") @db.Decimal(10, 2)
  netAmount      Decimal @map("net_amount") @db.Decimal(10, 2) // gross - discounts
  amountPaid     Decimal @default(0) @map("amount_paid") @db.Decimal(10, 2)
  balanceDue     Decimal @map("balance_due") @db.Decimal(10, 2) // net_amount - amount_paid

  status   String @default("unpaid") @map("status") @db.VarChar(30) // unpaid | partial | paid | cancelled
  currency String @default("AED") @map("currency") @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  invoiceLines       InvoiceLine[]
  receiptAllocations ReceiptAllocation[]
  refundAllocations  RefundAllocation[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]

  @@unique([tenantId, invoiceNumber], map: "ux_invoices_tenant_number")
  @@index([tenantId, patientId, status], map: "idx_invoices_patient")
  @@map("invoices")
}

model InvoiceLine {
  id        String @id @default(uuid()) @map("id") @db.Uuid
  invoiceId String @map("invoice_id") @db.Uuid
  chargeId  String @map("charge_id") @db.Uuid

  lineNumber   Int     @map("line_number")
  description  String? @map("description") @db.VarChar(255)
  quantity     Decimal @map("quantity") @db.Decimal(10, 2)
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  lineAmount   Decimal @map("line_amount") @db.Decimal(10, 2) // quantity * unit_price - line_discount
  lineDiscount Decimal @default(0) @map("line_discount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  charge  Charge  @relation(fields: [chargeId], references: [id], onDelete: Restrict)

  @@unique([invoiceId, lineNumber])
  @@index([invoiceId], map: "idx_invoice_lines_invoice")
  @@map("invoice_lines")
}

model Receipt {
  id        String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  patientId String  @map("patient_id") @db.Uuid // Logical FK to Clinical DB
  invoiceId String? @map("invoice_id") @db.Uuid // Nullable for advance payments

  // Denormalized patient fields for easier access
  mrn                String? @map("mrn") @db.VarChar(50)
  patientDisplayName String? @map("patient_display_name") @db.VarChar(255)

  receiptNumber String   @map("receipt_number") @db.VarChar(50)
  receiptDate   DateTime @default(now()) @map("receipt_date") @db.Timestamptz(6)
  amount        Decimal  @map("amount") @db.Decimal(10, 2)
  currency      String   @default("AED") @map("currency") @db.VarChar(10)
  paidAmount    Decimal? @map("paid_amount") @db.Decimal(10, 2)
  paidCurrency  String?  @map("paid_currency") @db.VarChar(10)
  fxRateToBase  Decimal? @map("fx_rate_to_base") @db.Decimal(18, 8)
  paymentMethod String   @map("payment_method") @db.VarChar(30) // cash | card | upi | bank_transfer | wallet
  txnReference  String?  @map("txn_reference") @db.VarChar(100)
  notes         String?  @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  allocations ReceiptAllocation[]
  refunds     Refund[]

  @@unique([tenantId, receiptNumber], map: "ux_receipts_tenant_number")
  @@index([invoiceId], map: "idx_receipts_invoice")
  @@map("receipts")
}

model ReceiptAllocation {
  id              String  @id @default(uuid()) @map("id") @db.Uuid
  receiptId       String  @map("receipt_id") @db.Uuid
  invoiceId       String  @map("invoice_id") @db.Uuid
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([receiptId, invoiceId])
  @@map("receipt_allocations")
}

// ========================================
// CHARGE POSTING RULES ENGINE
// ========================================

model ChargePostingRule {
  id                      String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  ruleName                String   @map("rule_name") @db.VarChar(255)
  eventType               String   @map("event_type") @db.VarChar(100) // lab_test_ordered, medication_dispensed, procedure_performed, etc.
  eventSource             String   @map("event_source") @db.VarChar(50) // encounter, order, pharmacy, scheduler
  billingItemType         String   @map("billing_item_type") @db.VarChar(50) // lab_test, medication, procedure, imaging_study, etc.
  billingItemId           String?  @map("billing_item_id") @db.Uuid // Specific billing item or null for dynamic lookup
  conditions              Json?    @map("conditions") // JSONB conditions for rule matching (e.g., {"labTestCategory": {"$eq": "hematology"}})
  chargeCalculationMethod String   @default("catalog_price") @map("charge_calculation_method") @db.VarChar(50) // fixed, catalog_price, custom_formula, tiered_pricing
  basePrice               Decimal? @map("base_price") @db.Decimal(10, 2) // Used for FIXED method
  priceSource             String   @default("catalog") @map("price_source") @db.VarChar(50) // catalog, custom, event_data, external_api
  quantitySource          String   @default("event") @map("quantity_source") @db.VarChar(50) // event, fixed, calculated
  discountPercentage      Decimal? @map("discount_percentage") @db.Decimal(5, 2) // 0-100
  taxPercentage           Decimal? @map("tax_percentage") @db.Decimal(5, 2) // 0-100
  isActive                Boolean  @default(true) @map("is_active")
  priority                Int      @default(0) @map("priority") // Higher number = higher priority
  autoApprove             Boolean  @default(true) @map("auto_approve") // Auto-approve charges created by this rule
  description             String?  @map("description") @db.Text
  configuration           Json?    @map("configuration") // Additional configuration in JSONB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid // User who created the rule
  updatedBy String?  @map("updated_by") @db.Uuid // User who last updated the rule

  auditRecords ChargePostingAudit[]

  @@index([tenantId, eventType], map: "idx_charge_posting_rules_tenant_event")
  @@index([tenantId, isActive], map: "idx_charge_posting_rules_tenant_active")
  @@index([eventType, eventSource], map: "idx_charge_posting_rules_event")
  @@index([billingItemType], map: "idx_charge_posting_rules_item_type")
  @@map("charge_posting_rules")
}

model ChargePostingEvent {
  id             String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(100) // Same as ChargePostingRule.eventType
  eventSource    String    @map("event_source") @db.VarChar(50) // Same as ChargePostingRule.eventSource
  eventId        String    @map("event_id") @db.Uuid // ID of the event (e.g., order_id, encounter_id)
  eventData      Json      @map("event_data") // Complete event payload in JSONB
  patientId      String    @map("patient_id") @db.Uuid // Logical FK to Clinical DB
  encounterId    String?   @map("encounter_id") @db.Uuid // Logical FK to Clinical DB
  processed      Boolean   @default(false) @map("processed")
  processedAt    DateTime? @map("processed_at") @db.Timestamptz(6)
  rulesMatched   Int       @default(0) @map("rules_matched")
  chargesCreated Int       @default(0) @map("charges_created")
  error          String?   @map("error") @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  auditRecords ChargePostingAudit[]

  @@index([tenantId, processed], map: "idx_charge_posting_events_tenant_processed")
  @@index([tenantId, eventType], map: "idx_charge_posting_events_tenant_event")
  @@index([patientId], map: "idx_charge_posting_events_patient")
  @@index([encounterId], map: "idx_charge_posting_events_encounter")
  @@index([eventId], map: "idx_charge_posting_events_event_id")
  @@map("charge_posting_events")
}

model ChargePostingAudit {
  id                 String @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String @map("tenant_id") @db.Uuid
  chargeId           String @map("charge_id") @db.Uuid // FK to charges table
  eventId            String @map("event_id") @db.Uuid // FK to charge_posting_events table
  ruleId             String @map("rule_id") @db.Uuid // FK to charge_posting_rules table
  conditionsMet      Json?  @map("conditions_met") // JSONB record of which conditions were satisfied
  calculationDetails Json?  @map("calculation_details") // JSONB record of price/quantity calculation

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event ChargePostingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rule  ChargePostingRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([tenantId, chargeId], map: "idx_charge_posting_audit_tenant_charge")
  @@index([eventId], map: "idx_charge_posting_audit_event")
  @@index([ruleId], map: "idx_charge_posting_audit_rule")
  @@map("charge_posting_audit")
}

// ========================================
// FEE SCHEDULES & CONTRACT MANAGEMENT
// ========================================

model FeeSchedule {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String? @map("tenant_id") @db.Uuid // NULL = authority/global schedule
  scheduleName  String  @map("schedule_name") @db.VarChar(255)
  scheduleType  String  @map("schedule_type") @db.VarChar(50) // 'authority' | 'tenant' | 'contract'
  authorityCode String? @map("authority_code") @db.VarChar(20) // 'DHA', 'DOH', 'MOHAP', NULL
  version       String? @db.VarChar(50)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  status        String    @default("active") @db.VarChar(20)

  // Layering support - allows tenant to override authority rates
  baseFeeScheduleId   String?       @map("base_fee_schedule_id") @db.Uuid
  baseFeeSchedule     FeeSchedule?  @relation("FeeScheduleHierarchy", fields: [baseFeeScheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  derivedFeeSchedules FeeSchedule[] @relation("FeeScheduleHierarchy")

  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  feeScheduleItems FeeScheduleItem[]
  payerContracts   PayerContract[]

  @@index([tenantId], map: "idx_fee_schedules_tenant")
  @@index([scheduleType], map: "idx_fee_schedules_type")
  @@index([authorityCode], map: "idx_fee_schedules_authority")
  @@index([effectiveFrom, effectiveTo], map: "idx_fee_schedules_dates")
  @@map("fee_schedules")
}

model FeeScheduleItem {
  id            String @id @default(uuid()) @db.Uuid
  feeScheduleId String @map("fee_schedule_id") @db.Uuid

  // Link to billing catalog
  billingItemId String?      @map("billing_item_id") @db.Uuid
  billingItem   BillingItem? @relation(fields: [billingItemId], references: [id], onDelete: SetNull)

  // Code information
  code     String @db.VarChar(50) // DHA/DOH/CPT code
  codeType String @map("code_type") @db.VarChar(30) // 'DHA', 'DOH', 'CPT', 'MOHAP'

  // Pricing
  baseAmount Decimal @map("base_amount") @db.Decimal(10, 2) // Authority or tenant rate
  currency   String  @default("AED") @db.VarChar(10)
  unit       String? @db.VarChar(50) // 'per_procedure', 'per_day', 'per_hour'

  // Contract-level overrides
  multiplier       Decimal? @db.Decimal(8, 4) // e.g., 0.85 = 85% of base
  discountPct      Decimal? @map("discount_pct") @db.Decimal(5, 2)
  maxAllowedAmount Decimal? @map("max_allowed_amount") @db.Decimal(10, 2)

  // Organization
  serviceGroup String? @map("service_group") @db.VarChar(50) // 'radiology', 'laboratory', etc.
  priority     Int     @default(100) // Lower number = higher priority

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  feeSchedule              FeeSchedule               @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)
  payerContractAdjustments PayerContractAdjustment[]

  @@unique([feeScheduleId, code, codeType], map: "uq_fee_schedule_item_code")
  @@index([feeScheduleId], map: "idx_fee_schedule_items_schedule")
  @@index([code, codeType], map: "idx_fee_schedule_items_code")
  @@index([billingItemId], map: "idx_fee_schedule_items_billing")
  @@map("fee_schedule_items")
}

// ========================================
// PAYER CONTRACTS
// ========================================

model PayerContract {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Payer identification
  payerId        String  @map("payer_id") @db.Uuid
  contractName   String  @map("contract_name") @db.VarChar(255)
  contractNumber String? @map("contract_number") @db.VarChar(100)
  authorityCode  String? @map("authority_code") @db.VarChar(20) // 'DHA','DOH','MOHAP'

  // Link to unified fee_schedules
  baseFeeScheduleId String? @map("base_fee_schedule_id") @db.Uuid

  // Plan / network granularity
  planCode       String? @map("plan_code") @db.VarChar(50)
  networkType    String? @map("network_type") @db.VarChar(50) // 'in_network','out_of_network','tier1','tier2'
  lineOfBusiness String? @map("line_of_business") @db.VarChar(50) // 'OP','IP','Dental','Vision'

  // Contract lifecycle
  contractType        String @default("fee_for_service") @map("contract_type") @db.VarChar(50) // 'fee_for_service','capitation','bundled'
  reimbursementMethod String @default("percentage_of_tariff") @map("reimbursement_method") @db.VarChar(50) // 'percentage_of_tariff','fixed_rate','percentage_of_charges'

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  status        String    @default("active") @db.VarChar(20) // 'active','expired','draft','suspended'

  // Default financial rules
  defaultMultiplier       Decimal? @map("default_multiplier") @db.Decimal(8, 4) // e.g. 0.80 = 80% of base tariff
  defaultDiscountPct      Decimal? @map("default_discount_pct") @db.Decimal(5, 2)
  defaultMaxAllowedAmount Decimal? @map("default_max_allowed_amount") @db.Decimal(10, 2)

  // Free-form complex terms
  terms    Json? @default("{}") @db.JsonB
  metadata Json? @default("{}") @db.JsonB

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  payer           Payer                     @relation(fields: [payerId], references: [id], onDelete: Cascade)
  baseFeeSchedule FeeSchedule?              @relation(fields: [baseFeeScheduleId], references: [id], onDelete: SetNull)
  adjustments     PayerContractAdjustment[]

  @@index([tenantId, payerId], map: "idx_payer_contracts_tenant_payer")
  @@index([tenantId, payerId, status, effectiveFrom, effectiveTo], map: "idx_payer_contracts_effective")
  @@index([tenantId, payerId, planCode, networkType], map: "idx_payer_contracts_plan_network")
  @@map("payer_contracts")
}

model PayerContractAdjustment {
  id         String @id @default(uuid()) @db.Uuid
  contractId String @map("contract_id") @db.Uuid

  // Scope: group-level, item-level, or fee-schedule-item-level
  serviceGroup      String? @map("service_group") @db.VarChar(50) // 'LAB','RAD','CONSULT','PROC','PHYSIO'
  billingItemId     String? @map("billing_item_id") @db.Uuid
  feeScheduleItemId String? @map("fee_schedule_item_id") @db.Uuid

  // Pricing overrides
  multiplier       Decimal? @db.Decimal(8, 4) // e.g. 0.75, 0.90, 1.00
  discountPct      Decimal? @map("discount_pct") @db.Decimal(5, 2)
  maxAllowedAmount Decimal? @map("max_allowed_amount") @db.Decimal(10, 2)
  minAllowedAmount Decimal? @map("min_allowed_amount") @db.Decimal(10, 2)

  // Priority: lower = more specific / applied first
  priority Int @default(100)

  // Optional validity period for the adjustment
  effectiveFrom DateTime? @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  // Optional flags
  isExclusion Boolean @default(false) @map("is_exclusion") // explicitly not covered
  notes       String? @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  contract        PayerContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  billingItem     BillingItem?     @relation(fields: [billingItemId], references: [id], onDelete: SetNull)
  feeScheduleItem FeeScheduleItem? @relation(fields: [feeScheduleItemId], references: [id], onDelete: SetNull)

  @@index([contractId], map: "idx_payer_contract_adj_contract")
  @@index([contractId, billingItemId], map: "idx_payer_contract_adj_item")
  @@index([contractId, serviceGroup], map: "idx_payer_contract_adj_group")
  @@index([contractId, effectiveFrom, effectiveTo], map: "idx_payer_contract_adj_effective")
  @@map("payer_contract_adjustments")
}

// ========================================
// MEDICAL CODING LAYER
// ========================================
// Provides a coding review layer between clinical documentation and claim generation
// Auto-seeded from posting rules, enhanced by medical coders, never blocks claims

model CodingSession {
  id       String @id @default(uuid()) @map("id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Links
  encounterId String  @map("encounter_id") @db.Uuid // Logical FK to Clinical DB
  claimId     String? @map("claim_id") @db.Uuid

  // Workflow state
  status String @default("new") @map("status") @db.VarChar(30)
  // 'new' | 'auto_generated' | 'in_progress' | 'completed' | 'approved' | 'rejected'

  assignedTo  String?   @map("assigned_to") @db.Uuid // Coder user_id (logical FK to Foundation DB)
  assignedAt  DateTime? @map("assigned_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  approvedBy  String?   @map("approved_by") @db.Uuid
  approvedAt  DateTime? @map("approved_at") @db.Timestamptz(6)

  // Session notes
  codingNotes String? @map("coding_notes") @db.Text
  reviewNotes String? @map("review_notes") @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  claim      Claim?            @relation(fields: [claimId], references: [id], onDelete: SetNull)
  diagnoses  CodingDiagnosis[]
  procedures CodingProcedure[]
  auditLogs  CodingAuditLog[]

  @@index([tenantId, encounterId], map: "idx_coding_sessions_encounter")
  @@index([tenantId, status], map: "idx_coding_sessions_status")
  @@index([tenantId, assignedTo, status], map: "idx_coding_sessions_assigned")
  @@index([claimId], map: "idx_coding_sessions_claim")
  @@map("coding_sessions")
}

model CodingDiagnosis {
  id              String @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String @map("tenant_id") @db.Uuid
  codingSessionId String @map("coding_session_id") @db.Uuid

  // Link to source clinical diagnosis (nullable - may be added by coder)
  sourceEncounterDiagnosisId String? @map("source_encounter_diagnosis_id") @db.Uuid // Logical FK to Clinical DB

  // Diagnosis code (snapshot for billing - may differ from clinical)
  diagnosisCatalogItemId String? @map("diagnosis_catalog_item_id") @db.Uuid // Logical FK to Foundation DB
  diagnosisCode          String  @map("diagnosis_code") @db.VarChar(20)
  diagnosisCodeType      String  @default("ICD-10") @map("diagnosis_code_type") @db.VarChar(20)
  diagnosisDisplay       String  @map("diagnosis_display") @db.VarChar(500)
  diagnosisDisplayAr     String? @map("diagnosis_display_ar") @db.VarChar(500)

  // Claim hierarchy
  diagnosisType String @default("secondary") @map("diagnosis_type") @db.VarChar(50)
  // 'principal' | 'secondary' | 'admitting' | 'comorbidity' | 'complication' | 'external_cause'

  sequence       Int // Claim order: 1 = principal, 2+ = secondary
  usedForBilling Boolean @default(true) @map("used_for_billing")

  // UAE/GCC-specific fields
  poaFlag String? @map("poa_flag") @db.VarChar(1) // 'Y'/'N'/'U'/'W'/null

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  codingSession  CodingSession    @relation(fields: [codingSessionId], references: [id], onDelete: Cascade)
  claimDiagnoses ClaimDiagnosis[]

  @@index([codingSessionId], map: "idx_coding_diagnoses_session")
  @@index([codingSessionId, sequence], map: "idx_coding_diagnoses_sequence")
  @@index([diagnosisCode], map: "idx_coding_diagnoses_code")
  @@map("coding_diagnoses")
}

model CodingProcedure {
  id              String @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String @map("tenant_id") @db.Uuid
  codingSessionId String @map("coding_session_id") @db.Uuid

  // Link to source clinical order (nullable - may be manually added)
  sourceClinicalOrderId String? @map("source_clinical_order_id") @db.Uuid // Logical FK to Clinical DB

  // Link to billing item (what we charge internally)
  billingItemId String @map("billing_item_id") @db.Uuid

  // Procedure code (snapshot for billing - what we tell the payer)
  procedureCatalogItemId String? @map("procedure_catalog_item_id") @db.Uuid // Logical FK to Foundation DB
  procedureCode          String  @map("procedure_code") @db.VarChar(50)
  procedureCodeType      String  @map("procedure_code_type") @db.VarChar(30)
  procedureDisplay       String  @map("procedure_display") @db.VarChar(500)
  procedureDisplayAr     String? @map("procedure_display_ar") @db.VarChar(500)

  // Service details
  serviceDate     DateTime @map("service_date") @db.Date
  providerId      String?  @map("provider_id") @db.Uuid // Logical FK to Foundation DB
  revenueCenterId String?  @map("revenue_center_id") @db.Uuid

  // Claim line details
  sequence Int // Claim line number (1, 2, 3, ...)
  units    Decimal @default(1) @map("units") @db.Decimal(10, 2)

  // Procedure modifiers (critical for accurate reimbursement)
  modifier1 String? @map("modifier_1") @db.VarChar(10)
  modifier2 String? @map("modifier_2") @db.VarChar(10)
  modifier3 String? @map("modifier_3") @db.VarChar(10)
  modifier4 String? @map("modifier_4") @db.VarChar(10)

  // Additional billing context
  serviceGroup   String? @map("service_group") @db.VarChar(50)
  placeOfService String? @map("place_of_service") @db.VarChar(10)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  codingSession CodingSession @relation(fields: [codingSessionId], references: [id], onDelete: Cascade)
  billingItem   BillingItem   @relation(fields: [billingItemId], references: [id], onDelete: Restrict)
  charges       Charge[]
  claimLines    ClaimLine[]

  @@index([codingSessionId], map: "idx_coding_procedures_session")
  @@index([codingSessionId, sequence], map: "idx_coding_procedures_sequence")
  @@index([billingItemId], map: "idx_coding_procedures_billing_item")
  @@index([procedureCode], map: "idx_coding_procedures_code")
  @@map("coding_procedures")
}

model ClaimLine {
  id      String @id @default(uuid()) @map("id") @db.Uuid
  claimId String @map("claim_id") @db.Uuid

  // Link to coding procedure (source of codes sent to payer)
  codingProcedureId String? @map("coding_procedure_id") @db.Uuid

  // Link to charge (source of money amounts)
  chargeId String? @map("charge_id") @db.Uuid

  // Claim line details (denormalized for fast claim submission)
  lineNumber Int @map("line_number")

  // Service identification
  procedureCode        String  @map("procedure_code") @db.VarChar(50)
  procedureCodeType    String  @map("procedure_code_type") @db.VarChar(30)
  procedureDescription String? @map("procedure_description") @db.VarChar(500)

  // Modifiers
  modifier1 String? @map("modifier_1") @db.VarChar(10)
  modifier2 String? @map("modifier_2") @db.VarChar(10)
  modifier3 String? @map("modifier_3") @db.VarChar(10)
  modifier4 String? @map("modifier_4") @db.VarChar(10)

  // Service details
  serviceDate DateTime @map("service_date") @db.Date
  units       Decimal  @map("units") @db.Decimal(10, 2)

  // Financial amounts
  chargedAmount    Decimal  @map("charged_amount") @db.Decimal(10, 2)
  allowedAmount    Decimal? @map("allowed_amount") @db.Decimal(10, 2)
  paidAmount       Decimal? @map("paid_amount") @db.Decimal(10, 2)
  adjustmentAmount Decimal? @map("adjustment_amount") @db.Decimal(10, 2)

  // Adjudication
  adjudicationStatus String? @default("pending") @map("adjudication_status") @db.VarChar(30)
  denialReason       String? @map("denial_reason") @db.Text
  remarkCodes        Json?   @map("remark_codes") @db.JsonB

  // Provider & location
  providerId        String? @map("provider_id") @db.Uuid
  placeOfService    String? @map("place_of_service") @db.VarChar(10)
  revenueCenterCode String? @map("revenue_center_code") @db.VarChar(10)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  claim           Claim            @relation(fields: [claimId], references: [id], onDelete: Cascade)
  codingProcedure CodingProcedure? @relation(fields: [codingProcedureId], references: [id], onDelete: SetNull)
  charge          Charge?          @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  @@unique([claimId, lineNumber], map: "ux_claim_lines_claim_line_num")
  @@index([claimId], map: "idx_claim_lines_claim")
  @@index([codingProcedureId], map: "idx_claim_lines_coding_procedure")
  @@index([chargeId], map: "idx_claim_lines_charge")
  @@index([procedureCode], map: "idx_claim_lines_code")
  @@map("claim_lines")
}

model ClaimDiagnosis {
  id      String @id @default(uuid()) @map("id") @db.Uuid
  claimId String @map("claim_id") @db.Uuid

  // Link to coding diagnosis
  codingDiagnosisId String? @map("coding_diagnosis_id") @db.Uuid

  // Diagnosis details (denormalized for fast claim submission)
  sequence          Int // Position on claim (1 = principal)
  diagnosisCode     String @map("diagnosis_code") @db.VarChar(20)
  diagnosisCodeType String @default("ICD-10") @map("diagnosis_code_type") @db.VarChar(20)
  diagnosisDisplay  String @map("diagnosis_display") @db.VarChar(500)
  diagnosisType     String @map("diagnosis_type") @db.VarChar(50)

  poaFlag String? @map("poa_flag") @db.VarChar(1)

  // Audit
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  claim           Claim            @relation(fields: [claimId], references: [id], onDelete: Cascade)
  codingDiagnosis CodingDiagnosis? @relation(fields: [codingDiagnosisId], references: [id], onDelete: SetNull)

  @@unique([claimId, sequence], map: "ux_claim_diagnoses_claim_sequence")
  @@index([claimId], map: "idx_claim_diagnoses_claim")
  @@index([codingDiagnosisId], map: "idx_claim_diagnoses_coding_diagnosis")
  @@index([diagnosisCode], map: "idx_claim_diagnoses_code")
  @@map("claim_diagnoses")
}

model CodingAuditLog {
  id              String @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String @map("tenant_id") @db.Uuid
  codingSessionId String @map("coding_session_id") @db.Uuid

  // What was changed
  entityType String @map("entity_type") @db.VarChar(30) // 'diagnosis' | 'procedure' | 'session'
  entityId   String @map("entity_id") @db.Uuid
  action     String @map("action") @db.VarChar(20) // 'create' | 'update' | 'delete' | 'approve' | 'reject'

  // Change details
  oldValue      Json? @map("old_value") @db.JsonB
  newValue      Json? @map("new_value") @db.JsonB
  changedFields Json? @map("changed_fields") @db.JsonB

  // User context
  changedBy    String  @map("changed_by") @db.Uuid
  changeReason String? @map("change_reason") @db.Text

  // Audit
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  // Relations
  codingSession CodingSession @relation(fields: [codingSessionId], references: [id], onDelete: Cascade)

  @@index([codingSessionId], map: "idx_coding_audit_logs_session")
  @@index([tenantId, changedBy], map: "idx_coding_audit_logs_user")
  @@index([entityType, entityId], map: "idx_coding_audit_logs_entity")
  @@index([changedAt], map: "idx_coding_audit_logs_timestamp")
  @@map("coding_audit_logs")
}

// ============================================================================
// CATALOG TO BILLING ITEM MAPPINGS
// Many-to-many mapping between clinical catalog items and billing items
// Allows one clinical item to map to multiple billing items and vice versa
// ============================================================================

model CatalogItemMapping {
  id        String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid

  // Clinical catalog item reference (logical FK to Clinical DB catalogs)
  catalogType   String  @map("catalog_type") @db.VarChar(50) // medication, lab_test, imaging_study, procedure, package, administrative_service
  catalogItemId String  @map("catalog_item_id") @db.Uuid

  // Billing item reference (FK to RCM DB billing_items)
  billingItemId String  @map("billing_item_id") @db.Uuid

  // Mapping configuration
  quantity          Decimal  @default(1) @map("quantity") @db.Decimal(10, 2) // How many billing items per catalog item
  isAutomatic       Boolean  @default(true) @map("is_automatic") // Auto-create charge when catalog item ordered
  isPrimary         Boolean  @default(false) @map("is_primary") // Primary billing item for this catalog item
  requiresApproval  Boolean  @default(false) @map("requires_approval") // Requires approval before charging

  // Context-based mapping (optional filters)
  facilityIds       String[] @default([]) @map("facility_ids") // Empty = all facilities
  payerIds          String[] @default([]) @map("payer_ids") // Empty = all payers
  patientTypes      String[] @default([]) @map("patient_types") // cash, insurance, vip, etc. Empty = all

  // Metadata
  mappingReason     String?   @map("mapping_reason") @db.Text // Why this mapping exists
  notes             String?   @map("notes") @db.Text
  effectiveDate     DateTime? @map("effective_date") @db.Date // When this mapping becomes active
  expirationDate    DateTime? @map("expiration_date") @db.Date // When this mapping expires

  // Status
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid

  // Relations
  billingItem BillingItem @relation(fields: [billingItemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, catalogType, catalogItemId, billingItemId], map: "ux_catalog_mapping_unique")
  @@index([tenantId], map: "idx_catalog_mapping_tenant")
  @@index([tenantId, catalogType], map: "idx_catalog_mapping_tenant_type")
  @@index([tenantId, catalogType, catalogItemId], map: "idx_catalog_mapping_catalog_item")
  @@index([billingItemId], map: "idx_catalog_mapping_billing_item")
  @@index([isActive], map: "idx_catalog_mapping_active")
  @@index([isPrimary], map: "idx_catalog_mapping_primary")
  @@map("catalog_item_mappings")
}

model CatalogMappingAudit {
  id        String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  mappingId String   @map("mapping_id") @db.Uuid

  // What changed
  action        String  @map("action") @db.VarChar(20) // create, update, delete, activate, deactivate
  oldValue      Json?   @map("old_value") @db.JsonB
  newValue      Json?   @map("new_value") @db.JsonB
  changedFields String[]  @default([]) @map("changed_fields")

  // Who and when
  changedBy    String   @map("changed_by") @db.Uuid
  changeReason String?  @map("change_reason") @db.Text
  changedAt    DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  @@index([mappingId], map: "idx_catalog_mapping_audit_mapping")
  @@index([tenantId], map: "idx_catalog_mapping_audit_tenant")
  @@index([changedAt], map: "idx_catalog_mapping_audit_timestamp")
  @@map("catalog_mapping_audit")
}

// ========================================
// ELIGIBILITY & BENEFITS
// ========================================
model EligibilityRequest {
  id            String    @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  policyId      String?   @map("policy_id") @db.Uuid
  payerId       String    @map("payer_id") @db.Uuid
  encounterId   String?   @map("encounter_id") @db.Uuid

  requestType   String    @default("eligibility") @map("request_type") @db.VarChar(30) // 'eligibility', 'benefits'
  serviceTypes  String[]  @default([]) @map("service_types") // e.g., ['30', '47'] for X12 or ['OP', 'IP'] generic
  serviceDate   DateTime? @map("service_date") @db.Date

  status        String    @default("pending") @map("status") @db.VarChar(30)
  // 'pending', 'submitted', 'accepted', 'rejected', 'error'

  requestPayload  Json?   @map("request_payload") @db.JsonB
  responsePayload Json?   @map("response_payload") @db.JsonB

  // Result Summary
  isEligible       Boolean?  @map("is_eligible")
  eligibilityStart DateTime? @map("eligibility_start") @db.Date
  eligibilityEnd   DateTime? @map("eligibility_end") @db.Date
  benefitsSummary  Json?     @map("benefits_summary") @db.JsonB // Copay, deductible, etc.

  errorCode    String?   @map("error_code") @db.VarChar(50)
  errorMessage String?   @map("error_message") @db.Text

  submittedAt  DateTime? @map("submitted_at") @db.Timestamptz(6)
  respondedAt  DateTime? @map("responded_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid

