// ========================================
// REFUNDS
// ========================================

enum RefundStatus {
  pending
  approved
  rejected
  processed
  voided
}

enum RefundMethod {
  cash
  card_reversal
  bank_transfer
  cheque
  wallet
  other
}

model Refund {
  id                 String       @id @default(uuid()) @map("id") @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  refundNumber       String       @map("refund_number") @db.VarChar(50)
  refundDate         DateTime     @default(now()) @map("refund_date") @db.Timestamptz(6)
  patientId          String       @map("patient_id") @db.Uuid
  receiptId          String?      @map("receipt_id") @db.Uuid

  // Amounts in base currency (AED)
  amount             Decimal      @map("amount") @db.Decimal(10, 2)
  currency           String       @default("AED") @map("currency") @db.VarChar(3)

  // Multi-currency: actual refund given
  refundedAmount     Decimal?     @map("refunded_amount") @db.Decimal(10, 2)
  refundedCurrency   String?      @map("refunded_currency") @db.VarChar(3)
  fxRateToBase       Decimal?     @map("fx_rate_to_base") @db.Decimal(10, 6)

  refundMethod       RefundMethod @map("refund_method")
  txnReference       String?      @map("txn_reference") @db.VarChar(100)
  reason             String?      @map("reason") @db.Text
  notes              String?      @map("notes") @db.Text

  // Workflow
  status             RefundStatus @default(pending) @map("status")
  requestedBy        String?      @map("requested_by") @db.Uuid
  requestedAt        DateTime     @default(now()) @map("requested_at") @db.Timestamptz(6)
  approvedBy         String?      @map("approved_by") @db.Uuid
  approvedAt         DateTime?    @map("approved_at") @db.Timestamptz(6)
  processedBy        String?      @map("processed_by") @db.Uuid
  processedAt        DateTime?    @map("processed_at") @db.Timestamptz(6)
  rejectionReason    String?      @map("rejection_reason") @db.Text

  // Denormalized patient info
  mrn                String?      @map("mrn") @db.VarChar(50)
  patientDisplayName String?      @map("patient_display_name") @db.VarChar(255)

  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  receipt            Receipt?     @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  allocations        RefundAllocation[]
  auditLogs          RefundAuditLog[]

  @@unique([tenantId, refundNumber], map: "ux_refunds_tenant_number")
  @@index([tenantId], map: "idx_refunds_tenant")
  @@index([patientId], map: "idx_refunds_patient")
  @@index([receiptId], map: "idx_refunds_receipt")
  @@index([status], map: "idx_refunds_status")
  @@map("refunds")
}

model RefundAllocation {
  id              String   @id @default(uuid()) @map("id") @db.Uuid
  refundId        String   @map("refund_id") @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  refund          Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([refundId], map: "idx_refund_allocations_refund")
  @@index([invoiceId], map: "idx_refund_allocations_invoice")
  @@map("refund_allocations")
}

model RefundAuditLog {
  id          String   @id @default(uuid()) @map("id") @db.Uuid
  refundId    String   @map("refund_id") @db.Uuid
  action      String   @map("action") @db.VarChar(30) // created, approved, rejected, processed, voided
  performedBy String   @map("performed_by") @db.Uuid
  performedAt DateTime @default(now()) @map("performed_at") @db.Timestamptz(6)
  details     Json?    @map("details") @db.JsonB

  refund      Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId], map: "idx_refund_audit_logs_refund")
  @@map("refund_audit_logs")
}

