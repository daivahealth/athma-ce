generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider   = "postgresql"
  url        = env("ANALYTICS_DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model AuditLog {
  id         String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(150)
  metadata   Json     @default("{}")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@index([tenantId, occurredAt], map: "idx_audit_tenant_occurred")
  @@map("audit_logs")
}

model UsageEvent {
  id         String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  eventType  String   @map("event_type")
  payload    Json     @default("{}")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([tenantId, eventType], map: "idx_usage_tenant_type")
  @@map("usage_events")
}

// ============================================================================
// AI FEATURE AUDIT LOGS
// ============================================================================

/// AI Query Logs - Audit trail for all AI-powered operations
model AiQueryLog {
  id         String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  facilityId String? @map("facility_id") @db.Uuid

  // Feature identification
  feature String @db.VarChar(50) // 'report_builder', 'semantic_search'

  // Query details
  queryText   String  @map("query_text") @db.Text // Original user query
  queryPlan   Json?   @map("query_plan") // Generated JSON plan (for reports)
  compiledSql String? @map("compiled_sql") @db.Text // Final SQL (debugging)

  // Results
  resultCount     Int? @map("result_count")
  executionTimeMs Int? @map("execution_time_ms")

  // LLM usage
  modelUsed    String? @map("model_used") @db.VarChar(100) // 'claude-sonnet-4-20250514'
  inputTokens  Int?    @map("input_tokens")
  outputTokens Int?    @map("output_tokens")

  // Status
  status       String  @default("success") @db.VarChar(20) // 'success', 'error', 'timeout'
  errorMessage String? @map("error_message") @db.Text

  // Metadata
  userAgent String?  @map("user_agent") @db.VarChar(500)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, feature, createdAt], map: "idx_ai_logs_tenant_feature")
  @@index([tenantId, userId, createdAt], map: "idx_ai_logs_tenant_user")
  @@index([tenantId, status, createdAt], map: "idx_ai_logs_tenant_status")
  @@index([modelUsed, createdAt], map: "idx_ai_logs_model")
  @@map("ai_query_logs")
}

/// AI Usage Metrics - Aggregated usage statistics per tenant
model AiUsageMetric {
  id          String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  feature     String   @db.VarChar(50)
  periodType  String   @map("period_type") @db.VarChar(10) // 'daily', 'weekly', 'monthly'
  periodStart DateTime @map("period_start") @db.Date

  // Counts
  queryCount   Int @default(0) @map("query_count")
  successCount Int @default(0) @map("success_count")
  errorCount   Int @default(0) @map("error_count")
  uniqueUsers  Int @default(0) @map("unique_users")

  // Token usage
  totalInputTokens  Int @default(0) @map("total_input_tokens")
  totalOutputTokens Int @default(0) @map("total_output_tokens")

  // Performance
  avgExecutionTimeMs Decimal? @map("avg_execution_time_ms") @db.Decimal(10, 2)
  p95ExecutionTimeMs Decimal? @map("p95_execution_time_ms") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, feature, periodType, periodStart], map: "ux_ai_usage_period")
  @@index([tenantId, periodType, periodStart], map: "idx_ai_usage_tenant_period")
  @@map("ai_usage_metrics")
}

// ============================================================================
// SEMANTIC CATALOG - Report Builder Metadata
// ============================================================================

/// Semantic Metrics - What can be measured in reports
model SemanticMetric {
  id            String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String? @map("tenant_id") @db.Uuid // NULL = global, UUID = tenant-specific
  name          String  @db.VarChar(100) // 'total_revenue'
  displayName   String  @map("display_name") @db.VarChar(255) // 'Total Revenue'
  displayNameAr String? @map("display_name_ar") @db.VarChar(255) // 'إجمالي الإيرادات'
  description   String? @db.Text // For LLM context

  // SQL configuration
  expression String @db.Text // SQL: 'net_amount' or 'COALESCE(amount, 0)'
  database   String @db.VarChar(20) // 'rcm' | 'clinical' | 'foundation'
  baseTable  String @map("base_table") @db.VarChar(100) // 'invoices'

  // Type information
  dataType           String? @map("data_type") @db.VarChar(20) // 'decimal' | 'integer'
  defaultAggregation String? @map("default_aggregation") @db.VarChar(20) // 'SUM'
  format             String? @db.VarChar(50) // 'currency' | 'percentage' | 'number'

  // Access control
  requiredPermission String? @map("required_permission") @db.VarChar(100) // 'rcm.reports.revenue'

  // Organization
  category  String? @db.VarChar(50) // 'Revenue' | 'Clinical' | 'Operations'
  sortOrder Int     @default(0) @map("sort_order")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, name], map: "ux_semantic_metric_name")
  @@index([tenantId, isActive], map: "idx_semantic_metric_tenant")
  @@index([database, baseTable], map: "idx_semantic_metric_table")
  @@map("semantic_metrics")
}

/// Semantic Dimensions - What can be grouped/filtered by
model SemanticDimension {
  id            String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String? @map("tenant_id") @db.Uuid // NULL = global, UUID = tenant-specific
  name          String  @db.VarChar(100) // 'invoice_date'
  displayName   String  @map("display_name") @db.VarChar(255) // 'Invoice Date'
  displayNameAr String? @map("display_name_ar") @db.VarChar(255) // 'تاريخ الفاتورة'
  description   String? @db.Text // For LLM context

  // SQL configuration
  columnRef String @map("column_ref") @db.VarChar(255) // SQL column reference
  database  String @db.VarChar(20) // 'rcm' | 'clinical' | 'foundation'
  baseTable String @map("base_table") @db.VarChar(100) // 'invoices'

  // Type information
  dataType         String?  @map("data_type") @db.VarChar(20) // 'date' | 'string' | 'integer'
  allowedOperators String[] @map("allowed_operators") @db.VarChar(20) // ['eq', 'gte', 'lte', 'between']

  // Lookup values for enums
  isLookup     Boolean  @default(false) @map("is_lookup")
  lookupValues String[] @map("lookup_values") @db.VarChar(100) // ['unpaid', 'paid', 'cancelled']

  // Access control
  requiredPermission String? @map("required_permission") @db.VarChar(100) // 'rcm.reports.invoices'

  // Organization
  category  String? @db.VarChar(50) // 'Time' | 'Geography' | 'Patient'
  sortOrder Int     @default(0) @map("sort_order")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, name], map: "ux_semantic_dimension_name")
  @@index([tenantId, isActive], map: "idx_semantic_dimension_tenant")
  @@index([database, baseTable], map: "idx_semantic_dimension_table")
  @@map("semantic_dimensions")
}

/// Semantic Join Paths - How tables connect for cross-table queries
model SemanticJoinPath {
  id       String  @id @default(uuid()) @map("id") @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid // NULL = global, UUID = tenant-specific
  name     String  @db.VarChar(100) // 'invoices_to_patients'

  // Source table
  fromTable    String @map("from_table") @db.VarChar(100)
  fromDatabase String @map("from_database") @db.VarChar(20)

  // Target table
  toTable    String @map("to_table") @db.VarChar(100)
  toDatabase String @map("to_database") @db.VarChar(20)

  // Join configuration
  joinType      String @default("inner") @map("join_type") @db.VarChar(10) // 'inner' | 'left'
  joinCondition String @map("join_condition") @db.Text // SQL join condition

  // Relationship metadata
  cardinality String? @db.VarChar(20) // 'one-to-one' | 'one-to-many' | 'many-to-one'
  description String? @db.Text

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, name], map: "ux_semantic_join_path_name")
  @@index([fromDatabase, fromTable], map: "idx_semantic_join_from")
  @@index([toDatabase, toTable], map: "idx_semantic_join_to")
  @@map("semantic_join_paths")
}

// ============================================================================
// SAVED REPORTS - User-saved report definitions
// ============================================================================

/// Saved Reports - Persisted report definitions for quick access
model SavedReport {
  id          String @id @default(uuid()) @map("id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  createdById String @map("created_by_id") @db.Uuid // User who created the report

  // Report definition
  name        String  @db.VarChar(255)
  description String? @db.Text
  query       String  @db.Text // Original natural language query
  queryPlan   Json?   @map("query_plan") // Parsed query plan for re-execution

  // Sharing & organization
  isPublic   Boolean @default(false) @map("is_public") // Visible to all users in tenant
  isFavorite Boolean @default(false) @map("is_favorite") // User's favorite

  // Usage tracking
  executionCount Int       @default(0) @map("execution_count")
  lastExecutedAt DateTime? @map("last_executed_at") @db.Timestamptz(6)

  // Metadata
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, createdById], map: "idx_saved_report_tenant_user")
  @@index([tenantId, isPublic], map: "idx_saved_report_public")
  @@index([tenantId, isFavorite], map: "idx_saved_report_favorite")
  @@map("saved_reports")
}

// ============================================================================
// PRE-AGGREGATED CLINICAL ANALYTICS
// ============================================================================

/// Daily aggregated clinical observations - refreshed by scheduled job
model ClinicalObservationDaily {
  id              String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  facilityId      String?  @map("facility_id") @db.Uuid
  departmentId    String?  @map("department_id") @db.Uuid
  observationDate DateTime @map("observation_date") @db.Date

  // What was measured
  code       String @db.VarChar(20) // LOINC code
  codeSystem String @map("code_system") @db.VarChar(20)
  category   String @db.VarChar(50)

  // Aggregates
  recordCount Int      @map("record_count")
  avgValue    Decimal? @map("avg_value") @db.Decimal(12, 4)
  minValue    Decimal? @map("min_value") @db.Decimal(12, 4)
  maxValue    Decimal? @map("max_value") @db.Decimal(12, 4)
  p50Value    Decimal? @map("p50_value") @db.Decimal(12, 4) // Median
  p95Value    Decimal? @map("p95_value") @db.Decimal(12, 4)

  // Abnormal counts
  normalCount       Int @default(0) @map("normal_count")
  abnormalHighCount Int @default(0) @map("abnormal_high_count")
  abnormalLowCount  Int @default(0) @map("abnormal_low_count")
  criticalCount     Int @default(0) @map("critical_count")

  // Unique patients measured
  uniquePatients Int @default(0) @map("unique_patients")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, facilityId, departmentId, observationDate, code], map: "ux_obs_daily_key")
  @@index([tenantId, code, observationDate], map: "idx_obs_daily_tenant_code_date")
  @@index([tenantId, category, observationDate], map: "idx_obs_daily_tenant_cat_date")
  @@map("clinical_observation_daily")
}

/// Daily aggregated diagnosis counts - refreshed by scheduled job
model DiagnosisDailyAggregate {
  id            String   @id @default(uuid()) @map("id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  facilityId    String?  @map("facility_id") @db.Uuid
  departmentId  String?  @map("department_id") @db.Uuid
  diagnosisDate DateTime @map("diagnosis_date") @db.Date

  icdCode       String  @map("icd_code") @db.VarChar(20)
  icdBlock      String? @map("icd_block") @db.VarChar(10) // First 3 chars
  diagnosisName String  @map("diagnosis_name") @db.VarChar(500)
  diagnosisType String  @map("diagnosis_type") @db.VarChar(20)

  encounterCount Int @map("encounter_count")
  uniquePatients Int @map("unique_patients")
  primaryCount   Int @default(0) @map("primary_count")
  chronicCount   Int @default(0) @map("chronic_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, facilityId, departmentId, diagnosisDate, icdCode, diagnosisType], map: "ux_dx_daily_key")
  @@index([tenantId, icdCode, diagnosisDate], map: "idx_dx_daily_tenant_code_date")
  @@map("diagnosis_daily_aggregate")
}
