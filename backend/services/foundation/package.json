{
  "name": "@zeal/foundation",
  "version": "1.0.0",
  "description": "Foundational entities service (tenants, users, facilities, staff)",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "ts-node --project tsconfig.build.json src/main.ts",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^7.5.5",
    "@nestjs/config": "^2.3.4",
    "@nestjs/core": "^7.6.18",
    "@nestjs/jwt": "8.0.1",
    "@nestjs/passport": "8.2.2",
    "@nestjs/platform-express": "^7.6.18",
    "@nestjs/swagger": "^6.1.3",
    "@prisma/client": "^5.7.1",
    "@zeal/contracts": "file:../../contracts",
    "@zeal/database-clinical": "file:../../shared/database-clinical",
    "@zeal/database-foundation": "file:../../shared/database-foundation",
    "@zeal/shared-utils": "file:../../shared/utils",
    "argon2": "^0.31.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nodemailer": "7.0.9",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
