{
  "name": "@zeal/foundation",
  "version": "1.0.0",
  "description": "Foundational entities service (tenants, users, facilities, staff)",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/main.js",
    "dev": "NODE_ENV=development ts-node -r tsconfig-paths/register --project tsconfig.build.json src/main.ts",
    "dev:debug": "NODE_ENV=development LOG_LEVEL=debug ts-node -r tsconfig-paths/register --project tsconfig.build.json src/main.ts",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.7.1",
    "@zeal/contracts": "file:../../contracts",
    "@zeal/database-clinical": "file:../../shared/database-clinical",
    "@zeal/observability": "file:../../shared/observability",
    "@zeal/database-foundation": "file:../../shared/database-foundation",
    "@zeal/shared-utils": "file:../../shared/utils",
    "argon2": "^0.31.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nodemailer": "7.0.9",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/source-map-support": "^0.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
