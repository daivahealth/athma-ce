{
  "name": "@zeal/clinical",
  "version": "0.1.0",
  "description": "Clinical domain service (patients, encounters, scheduling)",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/main.js",
    "dev": "NODE_ENV=development ts-node -r tsconfig-paths/register --project tsconfig.build.json src/main.ts",
    "dev:debug": "NODE_ENV=development LOG_LEVEL=debug ts-node -r tsconfig-paths/register --project tsconfig.build.json src/main.ts",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.0",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/swagger": "^7.4.2",
    "@zeal/config-client": "file:../../shared/config-client",
    "@zeal/contracts": "file:../../contracts",
    "@zeal/observability": "file:../../shared/observability",
    "@zeal/database-clinical": "file:../../shared/database-clinical",
    "@zeal/shared-types": "file:../../shared/types",
    "@zeal/shared-utils": "file:../../shared/utils",
    "axios": "^1.6.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.1.13",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.1",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/source-map-support": "^0.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
