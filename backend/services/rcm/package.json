{
  "name": "@zeal/rcm",
  "version": "0.1.0",
  "description": "Revenue Cycle Management service",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "predev": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema ../../shared/database-rcm/prisma/schema.prisma",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "NODE_ENV=development ts-node -r tsconfig-paths/register --project tsconfig.build.json src/main.ts",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.0",
    "@nestjs/platform-express": "^10.2.0",

    "@nestjs/swagger": "^7.4.2",
    "@zeal/contracts": "file:../../contracts",
    "@zeal/database-rcm": "file:../../shared/database-rcm",
    "@zeal/observability": "file:../../shared/observability",
    "@zeal/shared-utils": "file:../../shared/utils",
    "axios": "^1.13.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
