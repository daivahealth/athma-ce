# Database Configuration
DATABASE_URL="postgresql://zeal_user:zeal_password@localhost:5432/zeal_pms?schema=public"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zeal_pms
POSTGRES_USER=zeal_user
POSTGRES_PASSWORD=zeal_password

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# Application Configuration
NODE_ENV=development
PORT=3002
API_VERSION=v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# UAE Healthcare Configuration
DHA_ECLAIMLINK_URL=https://api.dha.gov.ae/eclaimlink
DHA_ECLAIMLINK_API_KEY=your-dha-api-key
DOH_SHAFAFIYA_URL=https://api.doh.gov.ae/shafafiya
DOH_SHAFAFIYA_API_KEY=your-doh-api-key

# AI/ML Configuration
OPENAI_API_KEY=your-openai-api-key
AI_SERVICE_URL=http://localhost:3003

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Multi-language Support
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar

# Timezone
TZ=Asia/Dubai



