generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("CLINICAL_DATABASE_URL")
  schemas  = ["plugin_oncology"]
}

model CancerDiagnosis {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  patientId             String   @map("patient_id") @db.Uuid
  encounterId           String?  @map("encounter_id") @db.Uuid
  encounterDiagnosisId  String?  @map("encounter_diagnosis_id") @db.Uuid

  cancerType            String   @map("cancer_type") @db.VarChar(200)
  primarySite           String   @map("primary_site") @db.VarChar(200)
  primarySiteCode       String?  @map("primary_site_code") @db.VarChar(20)
  laterality            String?  @db.VarChar(20)
  histologyMorphology   String?  @map("histology_morphology") @db.VarChar(200)
  morphologyCode        String?  @map("morphology_code") @db.VarChar(20)

  icdCode               String?  @map("icd_code") @db.VarChar(20)
  snomedCode            String?  @map("snomed_code") @db.VarChar(20)

  diagnosisDate         DateTime @map("diagnosis_date") @db.Date
  clinicalStatus        String   @default("active") @map("clinical_status") @db.VarChar(30)
  verificationStatus    String   @default("confirmed") @map("verification_status") @db.VarChar(30)
  grade                 String?  @db.VarChar(50)
  metastaticStatus      String   @default("unknown") @map("metastatic_status") @db.VarChar(20)
  isRecurrence          Boolean  @default(false) @map("is_recurrence")

  biomarkers            Json     @default("{}")
  ecogAtDiagnosis       Int?     @map("ecog_at_diagnosis")

  diagnosedBy           String   @map("diagnosed_by") @db.Uuid
  notes                 String?  @db.Text

  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  stagings              TumorStaging[]
  tumorBoardCases       TumorBoardCase[]
  carePlans             OncologyCarePlan[]

  @@index([tenantId, patientId])
  @@index([tenantId, cancerType])
  @@index([tenantId, clinicalStatus])
  @@index([tenantId, diagnosisDate])
  @@map("cancer_diagnoses")
  @@schema("plugin_oncology")
}

model TumorStaging {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  cancerDiagnosisId   String   @map("cancer_diagnosis_id") @db.Uuid
  patientId           String   @map("patient_id") @db.Uuid
  encounterId         String?  @map("encounter_id") @db.Uuid
  providerId          String?  @map("provider_id") @db.Uuid

  stagingSystem       String   @map("staging_system") @db.VarChar(50)
  stagingEdition      String?  @map("staging_edition") @db.VarChar(20)
  stagingType         String   @default("clinical") @map("staging_type") @db.VarChar(20)

  stageGroup          String?  @map("stage_group") @db.VarChar(20)
  tCategory           String?  @map("t_category") @db.VarChar(20)
  nCategory           String?  @map("n_category") @db.VarChar(20)
  mCategory           String?  @map("m_category") @db.VarChar(20)

  bodySite            String?  @map("body_site") @db.VarChar(200)
  grade               String?  @db.VarChar(50)
  histology           String?  @db.VarChar(200)

  stagingDate         DateTime @map("staging_date") @db.Date
  status              String   @default("active") @db.VarChar(20)
  notes               String?  @db.Text

  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cancerDiagnosis     CancerDiagnosis @relation(fields: [cancerDiagnosisId], references: [id])

  @@index([tenantId, patientId])
  @@index([tenantId, cancerDiagnosisId])
  @@index([stagingDate])
  @@map("tumor_staging")
  @@schema("plugin_oncology")
}

model ChemoProtocol {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid

  code            String   @db.VarChar(50)
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  cancerType      String   @map("cancer_type") @db.VarChar(200)
  intent          String   @db.VarChar(50)
  regimen         Json
  totalCycles     Int      @map("total_cycles")
  cycleDurationDays Int    @map("cycle_duration_days")
  premedications  Json     @default("[]")
  supportiveCare  Json     @default("[]")
  emetogenicRisk  String?  @map("emetogenic_risk") @db.VarChar(20)
  doseFormula     String   @default("bsa") @map("dose_formula") @db.VarChar(10)
  labPrerequisites Json    @default("[]") @map("lab_prerequisites")
  hydration        Json    @default("[]")

  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String?  @map("created_by") @db.Uuid

  orders          ChemoOrder[]

  @@unique([tenantId, code])
  @@index([tenantId, cancerType])
  @@map("chemo_protocols")
  @@schema("plugin_oncology")
}

model ChemoOrder {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  patientId       String    @map("patient_id") @db.Uuid
  encounterId     String?   @map("encounter_id") @db.Uuid
  protocolId      String    @map("protocol_id") @db.Uuid
  orderingProvider String   @map("ordering_provider") @db.Uuid

  cycleNumber     Int       @map("cycle_number")
  dayNumber       Int       @map("day_number")
  scheduledDate   DateTime  @map("scheduled_date") @db.Date
  administeredAt  DateTime? @map("administered_at") @db.Timestamptz(6)

  bsa             Decimal?  @db.Decimal(5, 2)
  weight          Decimal?  @db.Decimal(5, 1)
  height          Decimal?  @db.Decimal(5, 1)
  creatinineClearance Decimal? @map("creatinine_clearance") @db.Decimal(6, 2)

  cancerDiagnosisId   String?  @map("cancer_diagnosis_id") @db.Uuid
  oncologyCarePlanId  String?  @map("oncology_care_plan_id") @db.Uuid

  hepaticAdjustmentGrade String? @map("hepatic_adjustment_grade") @db.VarChar(10)
  renalAdjustmentGrade   String? @map("renal_adjustment_grade") @db.VarChar(10)

  doseAdjustments Json     @default("[]") @map("dose_adjustments")
  preChemoChecklist Json   @default("{}") @map("pre_chemo_checklist")

  status          String   @default("pending") @db.VarChar(30)
  verifiedBy      String?  @map("verified_by") @db.Uuid
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz(6)
  secondVerifiedBy String? @map("second_verified_by") @db.Uuid
  approvedBy      String?  @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  administeredBy  String?  @map("administered_by") @db.Uuid
  adverseReactions            Json @default("[]") @map("adverse_reactions")
  administrationDetails       Json @default("[]") @map("administration_details")
  drugPreparationDetails      Json @default("[]") @map("drug_preparation_details")
  nurseVerificationChecklist  Json @default("{}") @map("nurse_verification_checklist")
  notes           String?  @db.Text

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  protocol        ChemoProtocol @relation(fields: [protocolId], references: [id])

  @@index([tenantId, patientId])
  @@index([tenantId, scheduledDate])
  @@index([tenantId, status])
  @@index([tenantId, cancerDiagnosisId])
  @@index([tenantId, oncologyCarePlanId])
  @@map("chemo_orders")
  @@schema("plugin_oncology")
}

model TumorBoardCase {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  cancerDiagnosisId     String    @map("cancer_diagnosis_id") @db.Uuid
  stagingId             String?   @map("staging_id") @db.Uuid

  meetingDate           DateTime  @map("meeting_date") @db.Date
  presentedBy           String    @map("presented_by") @db.Uuid
  attendees             Json      @default("[]")
  clinicalSummary       String?   @map("clinical_summary") @db.Text
  imagingFindings       String?   @map("imaging_findings") @db.Text
  pathologyReport       String?   @map("pathology_report") @db.Text
  molecularProfile      String?   @map("molecular_profile") @db.Text

  mdtRecommendation     String?   @map("mdt_recommendation") @db.Text
  treatmentIntent       String?   @map("treatment_intent") @db.VarChar(50)
  recommendedPathway    Json      @default("[]") @map("recommended_pathway")
  treatmentPlan         Json      @default("{}") @map("treatment_plan")
  decision              String?   @db.VarChar(100)
  reviewOutcome         String?   @map("review_outcome") @db.VarChar(50)

  followUpActions       Json      @default("[]") @map("follow_up_actions")
  status                String    @default("scheduled") @db.VarChar(30)

  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cancerDiagnosis       CancerDiagnosis @relation(fields: [cancerDiagnosisId], references: [id])

  @@index([tenantId, meetingDate])
  @@index([tenantId, patientId])
  @@index([tenantId, cancerDiagnosisId])
  @@index([tenantId, status])
  @@map("tumor_board_cases")
  @@schema("plugin_oncology")
}

// ============================================================
// Oncology Catalog / Master Data
// ============================================================

model OncologyCancerTypeMaster {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid

  code        String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  category    String?  @db.VarChar(100)   // Solid Tumor / Hematologic / CNS / Skin
  description String?  @db.Text
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  siteMappings OncologyCancerTypeSiteMapping[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
  @@map("oncology_cancer_type_master")
  @@schema("plugin_oncology")
}

model OncologyPrimarySiteMaster {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid

  icdoSiteCode         String   @map("icdo_site_code") @db.VarChar(20)
  icdoSiteName         String   @map("icdo_site_name") @db.VarChar(255)
  bodySystem           String?  @map("body_system") @db.VarChar(100)
  lateralityApplicable Boolean  @default(false) @map("laterality_applicable")
  mappingType          String?  @map("mapping_type") @db.VarChar(30) // EXACT / APPROXIMATE / MULTIPLE / UNKNOWN / SYSTEMIC
  active               Boolean  @default(true)

  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  siteMappings OncologyCancerTypeSiteMapping[]

  @@unique([tenantId, icdoSiteCode])
  @@index([tenantId, active])
  @@index([tenantId, bodySystem])
  @@map("oncology_primary_site_master")
  @@schema("plugin_oncology")
}

model OncologyCancerTypeSiteMapping {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid

  cancerTypeId  String   @map("cancer_type_id") @db.Uuid
  primarySiteId String   @map("primary_site_id") @db.Uuid

  isDefault     Boolean  @default(false) @map("is_default")
  active        Boolean  @default(true)

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cancerType    OncologyCancerTypeMaster  @relation(fields: [cancerTypeId], references: [id])
  primarySite   OncologyPrimarySiteMaster @relation(fields: [primarySiteId], references: [id])

  @@unique([tenantId, cancerTypeId, primarySiteId])
  @@index([tenantId, cancerTypeId])
  @@index([tenantId, primarySiteId])
  @@map("oncology_cancer_type_site_mapping")
  @@schema("plugin_oncology")
}

model OncologyHistologyMaster {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid

  morphologyCode String   @map("morphology_code") @db.VarChar(20)
  morphologyName String   @map("morphology_name") @db.VarChar(255)
  behaviorCode   String?  @map("behavior_code") @db.VarChar(10)   // /0 /1 /2 /3
  behaviorName   String?  @map("behavior_name") @db.VarChar(100)  // Benign / Borderline / In situ / Malignant
  description    String?  @db.Text
  active         Boolean  @default(true)

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, morphologyCode])
  @@index([tenantId, active])
  @@index([tenantId, behaviorCode])
  @@map("oncology_histology_master")
  @@schema("plugin_oncology")
}

// ============================================================
// Radiation Oncology
// ============================================================

model RadiationPrescription {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  encounterId        String    @map("encounter_id") @db.Uuid
  cancerProfileId    String?   @map("cancer_profile_id") @db.Uuid
  prescriptionNumber String?   @map("prescription_number") @db.VarChar(50)
  treatmentIntent    String?   @map("treatment_intent") @db.VarChar(50)
  treatmentSiteId    String?   @map("treatment_site_id") @db.Uuid
  laterality         String?   @db.VarChar(30)
  modality           String?   @db.VarChar(50)
  technique          String?   @db.VarChar(50)
  totalDoseGy        Decimal?  @map("total_dose_gy") @db.Decimal(10, 2)
  dosePerFractionGy  Decimal?  @map("dose_per_fraction_gy") @db.Decimal(10, 2)
  plannedFractions   Int?      @map("planned_fractions")
  concurrentChemo    Boolean   @default(false) @map("concurrent_chemo")
  plannedStartDate   DateTime? @map("planned_start_date") @db.Date
  plannedEndDate     DateTime? @map("planned_end_date") @db.Date
  prescriptionNotes  String?   @map("prescription_notes") @db.Text
  prescribedBy       String?   @map("prescribed_by") @db.Uuid
  prescribedAt       DateTime? @map("prescribed_at") @db.Timestamptz(6)
  status             String    @default("DRAFT") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  simulations         RadiationSimulation[]
  treatmentPlans      RadiationTreatmentPlan[]
  reviews             RadiationOnTreatmentReview[]
  completionSummaries RadiationCompletionSummary[]

  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId, plannedStartDate])
  @@map("radiation_prescriptions")
  @@schema("plugin_oncology")
}

model RadiationSimulation {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  prescriptionId       String    @map("prescription_id") @db.Uuid
  simulationDate       DateTime? @map("simulation_date") @db.Timestamptz(6)
  patientPosition      String?   @map("patient_position") @db.VarChar(100)
  immobilizationDevice String?   @map("immobilization_device") @db.VarChar(255)
  contrastUsed         Boolean   @default(false) @map("contrast_used")
  scanRegion           String?   @map("scan_region") @db.VarChar(255)
  setupReference       String?   @map("setup_reference") @db.Text
  tattooMarkingDone    Boolean   @default(false) @map("tattoo_marking_done")
  simulationNotes      String?   @map("simulation_notes") @db.Text
  performedBy          String?   @map("performed_by") @db.Uuid
  status               String    @default("COMPLETED") @db.VarChar(50)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  prescription  RadiationPrescription  @relation(fields: [prescriptionId], references: [id])
  treatmentPlans RadiationTreatmentPlan[]

  @@index([tenantId, prescriptionId])
  @@map("radiation_simulations")
  @@schema("plugin_oncology")
}

model RadiationTreatmentPlan {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  prescriptionId        String    @map("prescription_id") @db.Uuid
  simulationId          String?   @map("simulation_id") @db.Uuid
  externalPlanReference String?   @map("external_plan_reference") @db.VarChar(255)
  planningSystem        String?   @map("planning_system") @db.VarChar(100)
  planningStatus        String?   @map("planning_status") @db.VarChar(50)
  plannerId             String?   @map("planner_id") @db.Uuid
  physicistId           String?   @map("physicist_id") @db.Uuid
  radiationOncologistId String?   @map("radiation_oncologist_id") @db.Uuid
  contouringCompleted   Boolean   @default(false) @map("contouring_completed")
  physicsQaCompleted    Boolean   @default(false) @map("physics_qa_completed")
  treatmentMachine      String?   @map("treatment_machine") @db.VarChar(100)
  planNotes             String?   @map("plan_notes") @db.Text
  approvedBy            String?   @map("approved_by") @db.Uuid
  approvedAt            DateTime? @map("approved_at") @db.Timestamptz(6)
  status                String    @default("ACTIVE") @db.VarChar(50)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  prescription RadiationPrescription  @relation(fields: [prescriptionId], references: [id])
  simulation   RadiationSimulation?   @relation(fields: [simulationId], references: [id])
  fractions    RadiationFraction[]

  @@index([tenantId, prescriptionId])
  @@index([tenantId, status])
  @@map("radiation_treatment_plans")
  @@schema("plugin_oncology")
}

model RadiationFraction {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  treatmentPlanId       String    @map("treatment_plan_id") @db.Uuid
  fractionNumber        Int       @map("fraction_number")
  plannedDate           DateTime? @map("planned_date") @db.Date
  actualDate            DateTime? @map("actual_date") @db.Timestamptz(6)
  plannedDoseGy         Decimal?  @map("planned_dose_gy") @db.Decimal(10, 2)
  deliveredDoseGy       Decimal?  @map("delivered_dose_gy") @db.Decimal(10, 2)
  treatmentMachine      String?   @map("treatment_machine") @db.VarChar(100)
  radiationTherapistId  String?   @map("radiation_therapist_id") @db.Uuid
  status                String    @default("SCHEDULED") @db.VarChar(50)
  interruptionReason    String?   @map("interruption_reason") @db.Text
  verificationCompleted Boolean   @default(false) @map("verification_completed")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  treatmentPlan RadiationTreatmentPlan @relation(fields: [treatmentPlanId], references: [id])

  @@unique([treatmentPlanId, fractionNumber])
  @@index([tenantId, treatmentPlanId])
  @@index([tenantId, status])
  @@map("radiation_fractions")
  @@schema("plugin_oncology")
}

model RadiationOnTreatmentReview {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  prescriptionId         String    @map("prescription_id") @db.Uuid
  reviewDate             DateTime  @map("review_date") @db.Timestamptz(6)
  weekNumber             Int?      @map("week_number")
  toxicityGrade          String?   @map("toxicity_grade") @db.VarChar(50)
  painScore              Int?      @map("pain_score")
  weightKg               Decimal?  @map("weight_kg") @db.Decimal(10, 2)
  treatmentBreakRequired Boolean   @default(false) @map("treatment_break_required")
  reviewNotes            String?   @map("review_notes") @db.Text
  reviewedBy             String?   @map("reviewed_by") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  prescription RadiationPrescription @relation(fields: [prescriptionId], references: [id])

  @@index([tenantId, prescriptionId])
  @@index([tenantId, reviewDate])
  @@map("radiation_on_treatment_reviews")
  @@schema("plugin_oncology")
}

model RadiationCompletionSummary {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  prescriptionId         String    @map("prescription_id") @db.Uuid
  completionDate         DateTime? @map("completion_date") @db.Date
  plannedTotalDoseGy     Decimal?  @map("planned_total_dose_gy") @db.Decimal(10, 2)
  deliveredTotalDoseGy   Decimal?  @map("delivered_total_dose_gy") @db.Decimal(10, 2)
  plannedFractions       Int?      @map("planned_fractions")
  deliveredFractions     Int?      @map("delivered_fractions")
  interruptions          Boolean   @default(false)
  interruptionNotes      String?   @map("interruption_notes") @db.Text
  acuteToxicitySummary   String?   @map("acute_toxicity_summary") @db.Text
  responseAssessmentPlan String?   @map("response_assessment_plan") @db.Text
  followupPlan           String?   @map("followup_plan") @db.Text
  completedBy            String?   @map("completed_by") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  prescription RadiationPrescription @relation(fields: [prescriptionId], references: [id])

  @@unique([prescriptionId])
  @@index([tenantId, prescriptionId])
  @@map("radiation_completion_summaries")
  @@schema("plugin_oncology")
}

model OncologyCarePlan {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  cancerDiagnosisId     String    @map("cancer_diagnosis_id") @db.Uuid
  tumorBoardCaseId      String?   @map("tumor_board_case_id") @db.Uuid

  planNumber            String    @map("plan_number") @db.VarChar(50)
  version               Int       @default(1)
  parentPlanId          String?   @map("parent_plan_id") @db.Uuid

  treatmentIntent       String    @map("treatment_intent") @db.VarChar(50)
  oncologySubspecialty   String?   @map("oncology_subspecialty") @db.VarChar(50)

  plannedModalities     Json      @default("[]") @map("planned_modalities")
  plannedCycles         Int?      @map("planned_cycles")
  cycleDurationDays     Int?      @map("cycle_duration_days")
  milestones            Json      @default("[]")
  followUpSchedule      Json      @default("[]") @map("follow_up_schedule")

  status                String    @default("draft") @db.VarChar(30)
  startDate             DateTime? @map("start_date") @db.Date
  endDate               DateTime? @map("end_date") @db.Date

  createdBy             String    @map("created_by") @db.Uuid
  approvedBy            String?   @map("approved_by") @db.Uuid
  approvedAt            DateTime? @map("approved_at") @db.Timestamptz(6)

  notes                 String?   @db.Text

  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cancerDiagnosis       CancerDiagnosis @relation(fields: [cancerDiagnosisId], references: [id])

  @@index([tenantId, patientId])
  @@index([tenantId, cancerDiagnosisId])
  @@index([tenantId, status])
